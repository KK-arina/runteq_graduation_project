<%# app/views/user_purposes/_analysis_status_banner.html.erb %>
<%#
  ==============================================================================
  分析状態バナー パーシャル（D-11 更新版）
  ==============================================================================

  【D-11 での変更点】
    failed 状態バナーの改善:
    ① last_error_message を「ユーザーに分かる言葉」に変換して表示する
       （エラーコード・英語メッセージをそのまま見せない）
    ② 「AIなしで続行する」リンクを提示する
       （タイムアウト時でも振り返りを完了できることを伝える）
    ③ エラー種別に応じたアイコン・メッセージの出し分け

  【ローカル変数】
    user_purpose : UserPurpose インスタンス（必須）
    ai_analysis  : AiAnalysis インスタンスまたは nil
  ==============================================================================
%>

<%# id="analysis_status_banner": Turbo Stream の target と一致させる（必須） %>
<div id="analysis_status_banner">

  <%# ── pending: AI分析ジョブのエンキュー待ち ────────────────────── %>
  <% if user_purpose.pending? %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-blue-50 border border-blue-200 rounded-xl"
         role="status" aria-live="polite">
      <span class="text-xl" aria-hidden="true">⏳</span>
      <div>
        <p class="text-sm font-semibold text-blue-800">AI分析待機中...</p>
        <p class="text-xs text-blue-600 mt-0.5">まもなく分析が始まります</p>
      </div>
    </div>

  <%# ── analyzing: GoodJob がジョブを実行中 ──────────────────────── %>
  <% elsif user_purpose.analyzing? %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-blue-50 border border-blue-200 rounded-xl"
         role="status" aria-live="polite">
      <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin flex-shrink-0"
           aria-hidden="true"></div>
      <div>
        <p class="text-sm font-semibold text-blue-800">🤖 AIが分析しています（通常30秒以内）</p>
        <p class="text-xs text-blue-600 mt-0.5">しばらくお待ちください</p>
      </div>
    </div>

  <%# ── completed: AI分析が正常完了 ──────────────────────────────── %>
  <% elsif user_purpose.completed? %>
    <div class="mb-6 flex items-center justify-between gap-3 px-4 py-3
                bg-green-50 border border-green-300 rounded-xl"
         role="status">
      <div class="flex items-center gap-3">
        <span class="text-xl" aria-hidden="true">✅</span>
        <div>
          <p class="text-sm font-semibold text-green-800">AI分析が完了しました</p>
          <p class="text-xs text-green-600 mt-0.5">
            <%= l user_purpose.updated_at, format: :long %> 完了
          </p>
        </div>
      </div>
      <% if ai_analysis.present? %>
        <%= link_to "結果を見る →",
                    ai_result_user_purpose_path,
                    class: "px-3 py-1.5 text-xs font-bold text-white bg-green-600
                            rounded-lg hover:bg-green-700 transition-colors whitespace-nowrap
                            focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2" %>
      <% else %>
        <span class="text-xs text-gray-400">結果を準備中...</span>
      <% end %>
    </div>

  <%# ── failed: AI分析が失敗 ──────────────────────────────────────── %>
  <% elsif user_purpose.failed? %>
    <%#
      ============================================================
      D-11 更新: failed 状態 UI の大幅改善
      ============================================================

      【変更前】
        last_error_message をそのまま表示していた。
        例: "Gemini API エラー: HTTP 429 - Too Many Requests"
        → ユーザーには意味不明な英語エラーが表示される

      【変更後】
        1. human_readable_error ヘルパーでエラーメッセージを日本語に変換する
        2. エラー種別（タイムアウト・レート制限・認証など）に応じたアイコンを表示
        3. 「AIなしで続行する」選択肢を提示する（D-11要件）
        4. 「再試行する」ボタンは D-10 レート制限と連携済み

      【human_readable_error を View ヘルパーに出さずにここで定義する理由】
        このパーシャルだけで使うロジックなので、
        ApplicationHelper に追加して全体を汚染するよりも
        ここでローカルに定義する方が保守性が高い。
    %>

    <%#
      error_info: エラーメッセージからユーザー向けの情報を生成するローカル変数。
      【なぜ Hash で返すのか】
        icon と message と detail を1つの変数にまとめることで、
        同じ条件分岐を3回書かなくて済む（DRY の原則）。
    %>
    <% error_raw = user_purpose.last_error_message.to_s %>

    <%# エラー種別を判定してアイコンとメッセージを決定する %>
    <% error_info = if error_raw.include?("タイムアウト") || error_raw.include?("timeout")
      {
        icon:   "⏱️",
        title:  "分析がタイムアウトしました",
        detail: "AIサーバーの応答に時間がかかりすぎました。「再試行する」か、AIなしで続行できます。",
        show_without_ai: true
      }
    elsif error_raw.include?("429") || error_raw.include?("レート制限") || error_raw.include?("上限")
      {
        icon:   "🚦",
        title:  "AIの利用制限に達しました",
        detail: "しばらく時間をおいてから再試行してください。通常5〜10分で回復します。",
        show_without_ai: false
      }
    elsif error_raw.include?("401") || error_raw.include?("認証") || error_raw.include?("接続できません")
      {
        icon:   "🔑",
        title:  "AIサービスに接続できません",
        detail: "システムの設定に問題が発生しています。しばらくお待ちいただくか、管理者にお問い合わせください。",
        show_without_ai: false
      }
    elsif error_raw.include?("解析") || error_raw.include?("パース") || error_raw.include?("JSON")
      {
        icon:   "📄",
        title:  "AI応答の解析に失敗しました",
        detail: "AIが予期しない形式で応答しました。「再試行する」で再度分析を試みてください。",
        show_without_ai: false
      }
    elsif error_raw.include?("再試行") || error_raw.include?("自動的に")
      {
        icon:   "🔄",
        title:  "一時的なエラーが発生しました",
        detail: "自動的に再試行しています。しばらくお待ちいただくか、「再試行する」をクリックしてください。",
        show_without_ai: false
      }
    else
      {
        icon:   "⚠️",
        title:  "分析に失敗しました",
        detail: "予期しないエラーが発生しました。「再試行する」で再度お試しください。",
        show_without_ai: false
      }
    end %>

    <div class="mb-6 px-4 py-4 bg-red-50 border border-red-200 rounded-xl"
         role="alert">

      <%# ── エラーヘッダー ───────────────────────────────────────────── %>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xl flex-shrink-0" aria-hidden="true"><%= error_info[:icon] %></span>
        <p class="text-sm font-semibold text-red-800"><%= error_info[:title] %></p>
      </div>

      <%# ── エラー詳細（ユーザー向けの言葉で表示） ─────────────────────── %>
      <p class="text-xs text-red-600 mb-4 leading-relaxed">
        <%= error_info[:detail] %>
      </p>

      <%# ── ボタンエリア ─────────────────────────────────────────────── %>
      <div class="flex flex-wrap gap-2">

        <%#
          「再試行する」ボタン（D-10 レート制限と連携）
          D-10 で実装済みの ai-throttle コントローラーを使って
          1分以内の連打を防ぎながら再試行できる。

          【button_to の form: オプションについて】
            button_to は <form> タグを生成する。
            form: { data: { ... } } で <form> タグに data 属性を付けられる。
            data-controller と data-action は <form> に付ける必要がある
            （<button> ではなく <form> が submit イベントを発火するため）。
        %>
        <%= button_to "🔄 再試行する",
                      retry_analysis_user_purpose_path,
                      method: :post,
                      data: {
                        turbo_confirm: "AI分析を再実行しますか？",
                        "ai-throttle-target": "button"
                      },
                      form: {
                        data: {
                          controller: "ai-throttle",
                          action: "submit->ai-throttle#throttle"
                        }
                      },
                      class: "px-3 py-1.5 text-xs font-semibold text-white
                              bg-red-600 rounded-lg hover:bg-red-700 transition-colors
                              focus:outline-none focus:ring-2 focus:ring-red-500
                              cursor-pointer border-none" %>

        <%#
          D-11 追加: 「目標を更新する」ボタン（既存）
        %>
        <%= link_to "📝 目標を更新する",
                    edit_user_purpose_path,
                    class: "px-3 py-1.5 text-xs font-semibold text-gray-600
                            border border-gray-300 bg-white rounded-lg hover:bg-gray-50
                            transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400" %>

        <%#
          D-11 追加: 「AIなしで続行する」ボタン
          タイムアウト時など「AIがなくても目標は保存済みなので続行できる」
          というフォールバックをユーザーに提示する。

          【show_without_ai フラグについて】
            タイムアウトエラーの場合のみ表示する。
            レート制限・認証エラーの場合は「再試行」を促す方が適切なため
            このボタンは表示しない（error_info[:show_without_ai] で制御）。

          【リンク先が dashboard_path の理由】
            PMVV は既に保存されているため、ダッシュボードで習慣・タスク管理を
            続けることができる。AI提案なしでも日常の習慣管理は使える。
        %>
        <% if error_info[:show_without_ai] %>
          <%= link_to "➡️ AIなしで続行する",
                      dashboard_path,
                      class: "px-3 py-1.5 text-xs font-semibold text-orange-700
                              border border-orange-300 bg-orange-50 rounded-lg
                              hover:bg-orange-100 transition-colors
                              focus:outline-none focus:ring-2 focus:ring-orange-400" %>
        <% end %>
      </div>

      <%#
        D-11 追加: 補足説明テキスト
        「AIなしでもアプリは使える」ことを常に伝えて
        ユーザーの離脱を防ぐ。
      %>
      <p class="text-xs text-gray-500 mt-3 pt-3 border-t border-red-100">
        💡 AI分析がなくても、習慣・タスクの記録は通常通りご利用いただけます。
      </p>
    </div>
  <% end %>

</div>