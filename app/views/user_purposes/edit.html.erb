<%# app/views/user_purposes/edit.html.erb %>
<%#
  ==============================================================================
  17番: PMVV 入力ページ（編集）
  ==============================================================================

  【new.html.erb との違い】
    ① ページタイトルが「目標を更新する」になる
    ② フォームの送信先が PATCH /user_purpose になる
       （form_with model: @user_purpose で自動決定 → persisted? = true → PATCH）
       ただし update アクションは実質「新規作成」であることに注意する。
    ③ 現在の入力値がフォームに初期値として表示される

  【フォームの送信先について】
    @user_purpose が persisted?（DB に保存済み）→ PATCH /user_purpose → update アクション
    update アクションでは新しいレコードを作成して旧バージョンを is_active=false にする。
    フォームの見た目は「更新」だが処理は「新規作成 + 旧バージョン無効化」になる。

  【初期値の表示について】
    form_with model: @user_purpose で f.text_area :purpose とすると
    @user_purpose.purpose の現在値が textarea に初期表示される。
    ユーザーは既存の内容を見ながら編集できる。
  ==============================================================================
%>
<% content_for :title, "目標を更新 | HabitFlow" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ページヘッダー %>
  <div class="mb-6">
    <%= link_to "← 目標管理に戻る",
                user_purpose_path,
                class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">🎯 PMVV目標を更新する</h1>
    <p class="mt-2 text-sm text-gray-500 leading-relaxed">
      目標を更新すると新しいバージョンが作成されます。<br>
      過去のバージョンは履歴として保存されます。
    </p>
  </div>

  <%# バージョン情報 %>
  <div class="mb-6 px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl">
    <p class="text-xs text-gray-500">
      現在のバージョン:
      <span class="font-semibold text-gray-700">Version <%= @user_purpose.version %></span>
      →
      <span class="font-semibold text-violet-600">Version <%= @user_purpose.version + 1 %> に更新されます</span>
    </p>
  </div>

  <%# 情報バナー %>
  <div class="mb-6 flex items-start gap-3 px-4 py-3
              bg-violet-50 border border-violet-200 rounded-xl">
    <span class="text-xl flex-shrink-0">✨</span>
    <p class="text-sm text-violet-700 leading-relaxed">
      更新後、バックグラウンドでAIが再分析を開始します。
    </p>
  </div>

  <%= render "shared/form_errors", model: @user_purpose %>

  <%#
    【なぜ url: の明示が必要なのか】
    
    resource :user_purpose（単数形）の場合:
      form_with model: @user_purpose（保存済み）
      → Rails が user_purpose_path（PATCH）を探すが
        単数形リソースのルーティングを正しく認識しない場合がある
      → url: を明示することで確実に PATCH /user_purpose に送信される
    
    【送信先】
      PATCH /user_purpose → user_purposes#update
  %>
  <%= form_with model: @user_purpose,
                url: user_purpose_path,
                method: :patch,
                local: true,
                class: "space-y-6",
                data: {
                  controller: "form-submit",
                  action: "submit->form-submit#submit"
                } do |f| %>

    <%# PURPOSE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :purpose,
          label_text: "Purpose",
          hint_text: "人生で一番大切にしていることは？",
          placeholder: "人生で一番大切にしていることを自由に書いてください",
          rows: 3,
          maxlength: 1000 %>

    <%# VISION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :vision,
          label_text: "Vision",
          hint_text: "1年後どんな自分になっていたいか？",
          placeholder: "1年後になりたい自分の姿を具体的に書いてください",
          rows: 3,
          maxlength: 1000 %>

    <%# MISSION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :mission,
          label_text: "Mission",
          hint_text: "今の自分に最も必要なことは？",
          placeholder: "今の自分に最も必要なことを書いてください",
          rows: 3,
          maxlength: 1000 %>

    <%# VALUE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :value,
          label_text: "Value",
          hint_text: "絶対に譲れないことは？",
          placeholder: "あなたが大切にしている価値観を書いてください",
          rows: 2,
          maxlength: 500 %>

    <%# CURRENT %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :current_situation,
          label_text: "Current",
          hint_text: "今の自分の現状を教えてください",
          placeholder: "現在の状況や課題を具体的に書いてください",
          rows: 3,
          maxlength: 1000 %>

    <%# ボタンエリア %>
    <div class="flex justify-end items-center gap-4 pt-2">
      <%= link_to "キャンセル",
                  user_purpose_path,
                  class: "px-5 py-3 bg-white border border-gray-300 text-gray-700
                          text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors
                          focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
      <%= f.submit "✨ 保存してAI再分析を開始",
            class: "flex-1 py-3 px-4 bg-violet-600 text-white text-sm font-semibold
                    rounded-xl hover:bg-violet-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500",
            data: {
              "form-submit-target": "button",
              "loading-text": "保存中..."
            } %>
    </div>

  <% end %>
</div>