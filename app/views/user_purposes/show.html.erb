<%# app/views/user_purposes/show.html.erb %>
<%#
  ==============================================================================
  16番: PMVV 目標管理ページ（D-3 更新版）
  ==============================================================================

  【D-3 での変更点】
    分析状態バナーパーシャルに @ai_analysis を渡すように変更する。
    これにより completed 状態のバナーで「結果を見る →」リンクが
    正しく表示されるようになる。

  【Turbo Stream の仕組み（変更なし）】
    turbo_stream_from タグにより、PurposeAnalysisJob が
    分析状態を更新するたびにバナーがリアルタイムで切り替わる。
    @current_purpose が nil の場合は購読しない。

  【@変数の定義（UserPurposesController#show で設定）】
    @current_purpose : UserPurpose インスタンス（is_active=true）または nil
    @ai_analysis     : AiAnalysis インスタンスまたは nil
    @past_purposes   : is_active=false の UserPurpose 配列（バージョン降順）
  ==============================================================================
%>
<% content_for :title, "目標管理 | HabitFlow" %>

<%#
  turbo_stream_from: このページで Turbo Stream を受信するためのタグ
  【引数】
    "user_purpose_#{@current_purpose.id}":
      PurposeAnalysisJob の broadcast_replace_to で指定した stream 名と一致させる。
      ユーザーごとに一意の stream 名にすることで他ユーザーへの更新が混入しない。
  @current_purpose が存在する場合のみ購読する（nil の場合は購読不要）。
%>
<% if @current_purpose %>
  <%= turbo_stream_from "user_purpose_#{@current_purpose.id}" %>
<% end %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ─────────────────────────────────────────────────────────────────
      ページヘッダー
  ───────────────────────────────────────────────────────────────── %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">🎯 PMVV目標管理</h1>
      <p class="mt-1 text-sm text-gray-500">
        あなたの Purpose / Mission / Vision / Value / Current を管理します
      </p>
    </div>
    <% if @current_purpose %>
      <%= link_to "目標を更新する",
                  edit_user_purpose_path,
                  class: "px-3 py-2 text-sm font-semibold text-white bg-violet-600
                          rounded-xl hover:bg-violet-700 transition-colors
                          focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2
                          whitespace-nowrap" %>
    <% end %>
  </div>

  <%# ─────────────────────────────────────────────────────────────────
      PMVV が未入力の場合: Empty State
      【条件】 @current_purpose が nil のとき
  ───────────────────────────────────────────────────────────────── %>
  <% unless @current_purpose %>
    <div class="text-center py-16 px-6 bg-white border border-dashed border-gray-300 rounded-2xl">
      <p class="text-5xl mb-4">🎯</p>
      <h2 class="text-lg font-bold text-gray-700 mb-2">目標がまだ登録されていません</h2>
      <p class="text-sm text-gray-500 mb-6 leading-relaxed">
        PMVVを入力すると、AIがあなたの目標に合わせた<br>
        習慣・タスクを提案します。
      </p>
      <%= link_to "目標を入力する →",
                  new_user_purpose_path,
                  class: "inline-block px-6 py-3 text-sm font-bold text-white
                          bg-violet-600 rounded-xl hover:bg-violet-700 transition-colors
                          focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2" %>
    </div>

  <%# ─────────────────────────────────────────────────────────────────
      PMVV が存在する場合
      【条件】 @current_purpose が存在するとき
  ───────────────────────────────────────────────────────────────── %>
  <% else %>

    <%#
      分析状態バナーをパーシャルで render する
      【D-3 変更点】
        @ai_analysis を追加で渡す。
        completed 状態のバナーで「結果を見る →」リンクを表示するために必要。

      【Turbo Stream の仕組み】
        このパーシャルの内側に id="analysis_status_banner" がある。
        PurposeAnalysisJob が broadcast_replace_to を呼ぶと
        この id の要素が自動的に新しい HTML に置き換えられる。
        ユーザーはページをリロードせずに分析状態の変化を確認できる。
    %>
    <%= render "user_purposes/analysis_status_banner",
               user_purpose: @current_purpose,
               ai_analysis:  @ai_analysis %>

    <%# ── 現在のPMVV 内容表示 ─────────────────────────────────────── %>
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-bold text-gray-800">
          現在の目標
          <span class="ml-2 text-xs font-normal text-gray-400">
            Version <%= @current_purpose.version %>
          </span>
        </h2>
        <span class="text-xs font-bold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">
          有効中
        </span>
      </div>

      <%#
        pmvv_fields: PMVV の5フィールドを配列で定義する。
        each で繰り返すことで同じ構造の HTML を5回書かずに済む（DRY 原則）。
        last:border-0 last:pb-0: 最後の要素のボーダーとパディングを除去する。
      %>
      <% pmvv_fields = [
           { label: "PURPOSE", desc: "人生で大切にしていること", value: @current_purpose.purpose },
           { label: "MISSION", desc: "今最も必要なこと",         value: @current_purpose.mission },
           { label: "VISION",  desc: "1年後の自分",              value: @current_purpose.vision },
           { label: "VALUE",   desc: "絶対に譲れないこと",        value: @current_purpose.value },
           { label: "CURRENT", desc: "今の自分の現状",            value: @current_purpose.current_situation }
         ] %>

      <div class="space-y-4">
        <% pmvv_fields.each do |field| %>
          <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold text-violet-600">
                <%= field[:label] %>
              </span>
              <span class="text-xs text-gray-400">
                <%= field[:desc] %>
              </span>
            </div>
            <% if field[:value].present? %>
              <%#
                whitespace-pre-wrap: テキスト内の改行を HTML で保持する。
                ユーザーが複数行で入力したテキストがそのまま表示される。
              %>
              <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">
                <%= field[:value] %>
              </p>
            <% else %>
              <p class="text-sm text-gray-400 italic">未入力</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── 過去バージョン一覧 ────────────────────────────────────────── %>
    <% if @past_purposes.any? %>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <h2 class="text-base font-bold text-gray-700 mb-4">過去のバージョン</h2>
        <div class="space-y-3">
          <% @past_purposes.each do |past| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
              <div>
                <p class="text-sm font-semibold text-gray-600">
                  Version <%= past.version %>
                </p>
                <p class="text-xs text-gray-400">
                  <%= l past.created_at, format: :long %> 作成
                </p>
              </div>
              <%#
                バッジ: analysis_state に応じて色を変える三項演算子チェーン。
                completed → 緑 / failed → 赤 / それ以外 → グレー
              %>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                          <%= past.completed? ? 'bg-green-100 text-green-700' :
                              past.failed?    ? 'bg-red-100 text-red-700'    :
                                                'bg-gray-100 text-gray-500' %>">
                <% if past.completed? %>
                  分析完了
                <% elsif past.failed? %>
                  分析失敗
                <% elsif past.analyzing? %>
                  分析中
                <% else %>
                  待機中
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  <% end %>
</div>
<%#
  D-5: 危機介入モーダル（PMVV管理ページ）
  UserPurposesController#create/update が crisis 検出時に
  flash[:crisis] = true をセットして user_purpose_path にリダイレクトする。
  show ページでモーダルを表示するために配置する。
%>
<%= render "shared/crisis_intervention_modal" %>
