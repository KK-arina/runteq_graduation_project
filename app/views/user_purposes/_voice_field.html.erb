<%# app/views/user_purposes/_voice_field.html.erb %>
<%#
  ==============================================================================
  PMVV 入力フォームの音声入力付きテキストエリア パーシャル
  ==============================================================================

  【このパーシャルの役割】
    Purpose / Mission / Vision / Value / Current の各フィールドを
    音声入力ボタン（🎤）付きで表示する共通パーシャル。

  【受け取るローカル変数】
    f:           フォームオブジェクト
    field:       フォームのフィールド名（シンボル）例: :purpose
    label_text:  ラベルに表示するテキスト 例: "Purpose"
    hint_text:   ラベル下のヒントテキスト 例: "人生で一番大切にしていることは？"
    placeholder: テキストエリアのプレースホルダー
    example:     入力例のテキスト（フィールド下に表示）
    rows:        テキストエリアの行数（デフォルト3）
    maxlength:   最大文字数（デフォルト1000）

  ============================================================
  【H-6 レスポンシブ調整での変更点】
  ============================================================

  ① textarea に text-base（16px）を追加
     【理由】
       iOS Safari は 16px 未満の textarea をタップするとページがズームされる。
       input と同様に textarea も text-base（16px）を明示することでズームを防止できる。
       このパーシャルは Purpose / Mission / Vision / Value / Current の
       5フィールドすべてで使われるため、ここ1箇所を修正するだけで
       user_purposes/new と onboardings/step5 の全 textarea に適用される（DRY）。

  ② 縦余白は py-3 で維持（既に十分なタップ領域が確保されている）。
  ==============================================================================
%>

<%#
  voice-input コントローラーのスコープ:
    この div の中の button と textarea が voice-input の対象になる。
    data-controller="voice-input" はこの div に設定することで
    他のフィールドの 🎤 ボタンと干渉しないようにする。
%>
<div class="relative" data-controller="voice-input">

  <%# ラベル %>
  <%= f.label field,
        class: "block text-sm font-semibold text-gray-700 mb-1" do %>
    <%= label_text %>
    <span class="font-normal text-xs text-gray-400 ml-1">— <%= hint_text %></span>
  <% end %>

  <div class="relative">
    <%#
      textarea に text-base（16px）を追加する理由（H-6）:
        iOS Safari は 16px 未満の textarea をタップするとページがズームされる。
        text-sm（14px）や指定なし（ブラウザデフォルト）では
        iPhone でタップするたびにページが自動ズームしてしまう。
        text-base（16px）を明示することでズームを防止できる。
      pr-12: 右側の 🎤 ボタンと文字が重ならないよう余白を確保する（変更なし）
    %>
    <%= f.text_area field,
          rows: local_assigns[:rows] || 3,
          placeholder: placeholder,
          maxlength: local_assigns[:maxlength] || 1000,
          class: "w-full px-4 py-3 pr-12 border border-gray-300 rounded-xl text-base
                  focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                  resize-none transition-colors",
          data: { "voice-input-target": "field" } %>

    <%#
      🎤 ボタン（絶対配置で右上に配置）
      absolute right-3 top-3: テキストエリアの右上に配置する
        top-1/2 ではなく top-3 を使う理由:
          テキストエリアは高さが可変なので、top-1/2 だと行が増えたときに
          ボタンが中央に来てしまい使いにくくなる。
          top-3 で常に右上固定にする。
    %>
    <button type="button"
            data-voice-input-target="button"
            data-action="click->voice-input#toggle"
            class="absolute right-3 top-3
                   p-1.5 rounded-lg border border-gray-300
                   text-gray-500 hover:bg-gray-50 transition-colors
                   focus:outline-none focus:ring-2 focus:ring-blue-500"
            aria-label="音声入力を開始する">
      🎤
    </button>
  </div>

  <%# 入力例の表示 %>
  <% if local_assigns[:example].present? %>
    <p class="mt-1.5 text-xs text-gray-400 leading-relaxed">
      <%= example %>
    </p>
  <% end %>

</div>
