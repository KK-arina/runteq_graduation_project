<%# app/views/user_purposes/new.html.erb %>
<%#
  ==============================================================================
  17番: PMVV 入力ページ（新規）
  ==============================================================================

  【このページの役割】
    初めて PMVV を入力するユーザー向けのフォームを表示する。
    5フィールド（Purpose/Mission/Vision/Value/Current）と
    音声入力ボタン（🎤）を備えたフォームを提供する。

  【フォームの送信先】
    form_with model: @user_purpose で送信先が自動決定される。
    @user_purpose が新規（unsaved）→ POST /user_purpose → create アクション

  【スキップについて】
    オンボーディングからの遷移時はスキップできる（D-7 で実装予定）。
    通常の 17 番ページではスキップリンクは表示しない。

  【音声入力について】
    voice-input Stimulus コントローラーと連携する（B-7 実装済み）。
    data-controller="voice-input" で各テキストエリアに紐付ける。
    未対応ブラウザでは 🎤 ボタンが自動的に非表示になる。

  【スマホ・デスクトップ両対応】
    max-w-xl で横幅を制限し中央寄せにする。
    テキストエリアの rows 設定でモバイルでも見やすい高さにする。
  ==============================================================================
%>
<% content_for :title, "目標を入力 | HabitFlow" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ─────────────────────────────────────────────────────────────────
      ページヘッダー
  ───────────────────────────────────────────────────────────────── %>
  <div class="mb-6">
    <%= link_to "← 目標管理に戻る",
                user_purpose_path,
                class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">🎯 PMVV目標を入力する</h1>
    <p class="mt-2 text-sm text-gray-500 leading-relaxed">
      あなたの目標を入力すると、AIがあなたに合った習慣・タスクを提案します。<br>
      すべて任意入力です。多く入力するほど精度が上がります。
    </p>
  </div>

  <%# ─────────────────────────────────────────────────────────────────
      情報バナー
      【役割】保存後に AI 分析が始まることをユーザーに伝える。
  ───────────────────────────────────────────────────────────────── %>
  <div class="mb-6 flex items-start gap-3 px-4 py-3
              bg-violet-50 border border-violet-200 rounded-xl">
    <span class="text-xl flex-shrink-0">✨</span>
    <p class="text-sm text-violet-700 leading-relaxed">
      保存後、バックグラウンドでAI分析を開始します。
      分析完了後にダッシュボードにお知らせします。
    </p>
  </div>

  <%# ─────────────────────────────────────────────────────────────────
      バリデーションエラー表示
      【役割】shared/form_errors パーシャルでエラーを表示する。
      model: @user_purpose を渡すことで UserPurpose のエラーを表示できる。
  ───────────────────────────────────────────────────────────────── %>
  <%= render "shared/form_errors", model: @user_purpose %>

  <%# ─────────────────────────────────────────────────────────────────
      PMVV 入力フォーム
      【form_with の設定】
        model: @user_purpose → 新規（unsaved）なので POST /user_purpose になる
        local: true → Turbo を使わず通常のフォーム送信にする
                      （保存後に redirect_to でページ遷移するため Turbo 不要）
        data-controller="form-submit" → 送信中の二重送信防止（既存コントローラー）
  ───────────────────────────────────────────────────────────────── %>
  <%#
    【なぜ url: の明示が必要なのか】
    
    通常の resources :user_purposes（複数形）の場合:
      form_with model: @user_purpose（新規）
      → Rails が自動で user_purposes_path（POST）を選ぶ ← これは動く
    
    今回の resource :user_purpose（単数形）の場合:
      form_with model: @user_purpose（新規）
      → Rails が user_purposes_path を探しに行く ← 存在しないのでエラーになる
    
    単数形リソースでは url: を明示することで正しいパスを指定する。
    
    【生成されるルートの確認】
      docker compose exec web bin/rails routes | grep user_purpose
      POST /user_purpose → user_purposes#create
      → url: user_purpose_path と method: :post を明示する
  %>
  <%= form_with model: @user_purpose,
                url: user_purpose_path,
                method: :post,
                local: true,
                class: "space-y-6",
                data: {
                  controller: "form-submit",
                  action: "submit->form-submit#submit"
                } do |f| %>

    <%#
      render "user_purposes/voice_field":
        _voice_field.html.erb パーシャルを呼び出す。
        f: フォームオブジェクトをそのまま渡す。
        各フィールド固有の引数（field/label_text/hint_text/placeholder/example/rows/maxlength）を指定する。
    %>

    <%# PURPOSE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :purpose,
          label_text: "Purpose",
          hint_text: "人生で一番大切にしていることは？",
          placeholder: "人生で一番大切にしていることを自由に書いてください",
          example: "例: 家族と過ごす時間を大切にしながら、仕事でも成果を出したい",
          rows: 3,
          maxlength: 1000 %>

    <%# VISION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :vision,
          label_text: "Vision",
          hint_text: "1年後どんな自分になっていたいか？",
          placeholder: "1年後になりたい自分の姿を具体的に書いてください",
          example: "例: 毎朝6時に起きて読書できる習慣が身についた自分",
          rows: 3,
          maxlength: 1000 %>

    <%# MISSION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :mission,
          label_text: "Mission",
          hint_text: "今の自分に最も必要なことは？",
          placeholder: "今の自分に最も必要なことを書いてください",
          example: "例: 睡眠の質を改善して、毎日の集中力を高める",
          rows: 3,
          maxlength: 1000 %>

    <%# VALUE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :value,
          label_text: "Value",
          hint_text: "絶対に譲れないことは？",
          placeholder: "あなたが大切にしている価値観を書いてください",
          example: "例: 家族との夕食時間は削らない。週末の休息は確保する",
          rows: 2,
          maxlength: 500 %>

    <%# CURRENT %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :current_situation,
          label_text: "Current",
          hint_text: "今の自分の現状を教えてください",
          placeholder: "現在の状況や課題を具体的に書いてください（AIの分析精度が上がります）",
          example: "例: 夜11時に寝ているが質が悪く、朝起きるのが辛い。筋トレは週2回できている",
          rows: 3,
          maxlength: 1000 %>

    <%# ── ボタンエリア ───────────────────────────────────────────── %>
    <div class="flex justify-end items-center gap-4 pt-2">
      <%# キャンセルボタン %>
      <%= link_to "キャンセル",
                  user_purpose_path,
                  class: "px-5 py-3 bg-white border border-gray-300 text-gray-700
                          text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors
                          focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
      <%# 保存ボタン %>
      <%#
        f.submit: フォームの送信ボタンを生成する。
        data-form-submit-target="button" と data-loading-text を設定することで
        form_submit_controller.js が送信中に「保存中...」に変更して二重送信を防ぐ。
      %>
      <%= f.submit "✨ 保存してAI分析を開始",
            class: "flex-1 py-3 px-4 bg-violet-600 text-white text-sm font-semibold
                    rounded-xl hover:bg-violet-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500",
            data: {
              "form-submit-target": "button",
              "loading-text": "保存中..."
            } %>
    </div>

  <% end %>
</div>

<%#
  D-5: 危機介入モーダル（17-M）
  UserPurposesController#create が flash[:crisis] = true をセットした場合、
  Stimulus が自動でモーダルを表示する。
%>
<%= render "shared/crisis_intervention_modal" %>