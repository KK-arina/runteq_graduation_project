<%# app/views/user_purposes/new.html.erb %>
<%#
  ==============================================================================
  17番: PMVV 入力ページ（新規）
  ==============================================================================

  【このページの役割】
    初めて PMVV を入力するユーザー向けのフォームを表示する。
    5フィールド（Purpose/Mission/Vision/Value/Current）と
    音声入力ボタン（🎤）を備えたフォームを提供する。

  ============================================================
  【H-6 レスポンシブ調整での変更点】
  ============================================================

  ① voice_field パーシャル（_voice_field.html.erb）内の textarea に text-base が必要
     【理由】
       iOS Safari は 16px 未満の textarea をタップするとページがズームされる。
       このビューは _voice_field.html.erb パーシャルを render しているため、
       パーシャル側に text-base を追加するだけで全フィールドに適用できる。

  【このファイル自体への変更】
     このビューは render "user_purposes/voice_field" で textarea を生成するため、
     このファイル自体の変更は不要。
     _voice_field.html.erb に text-base を追加することで対応する。

  ※ _voice_field.html.erb を修正した上で、このファイルはそのまま維持する。
  ==============================================================================
%>
<% content_for :title, "目標を入力 | HabitFlow" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ─────────────────────────────────────────────────────────────────
      ページヘッダー
  ───────────────────────────────────────────────────────────────── %>
  <div class="mb-6">
    <%= link_to "← 目標管理に戻る",
                user_purpose_path,
                class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">🎯 PMVV目標を入力する</h1>
    <p class="mt-2 text-sm text-gray-500 leading-relaxed">
      あなたの目標を入力すると、AIがあなたに合った習慣・タスクを提案します。<br>
      すべて任意入力です。多く入力するほど精度が上がります。
    </p>
  </div>

  <%# ─────────────────────────────────────────────────────────────────
      情報バナー
  ───────────────────────────────────────────────────────────────── %>
  <div class="mb-6 flex items-start gap-3 px-4 py-3
              bg-violet-50 border border-violet-200 rounded-xl">
    <span class="text-xl flex-shrink-0">✨</span>
    <p class="text-sm text-violet-700 leading-relaxed">
      保存後、バックグラウンドでAI分析を開始します。
      分析完了後にダッシュボードにお知らせします。
    </p>
  </div>

  <%# ─────────────────────────────────────────────────────────────────
      バリデーションエラー表示
  ───────────────────────────────────────────────────────────────── %>
  <%= render "shared/form_errors", model: @user_purpose %>

  <%# ─────────────────────────────────────────────────────────────────
      PMVV 入力フォーム
  ───────────────────────────────────────────────────────────────── %>
  <%= form_with model: @user_purpose,
                url: user_purpose_path,
                method: :post,
                local: true,
                class: "space-y-6",
                data: {
                  controller: "form-submit",
                  action: "submit->form-submit#submit"
                } do |f| %>

    <%# PURPOSE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :purpose,
          label_text: "Purpose",
          hint_text: "人生で一番大切にしていることは？",
          placeholder: "人生で一番大切にしていることを自由に書いてください",
          example: "例: 家族と過ごす時間を大切にしながら、仕事でも成果を出したい",
          rows: 3,
          maxlength: 1000 %>

    <%# VISION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :vision,
          label_text: "Vision",
          hint_text: "1年後どんな自分になっていたいか？",
          placeholder: "1年後になりたい自分の姿を具体的に書いてください",
          example: "例: 毎朝6時に起きて読書できる習慣が身についた自分",
          rows: 3,
          maxlength: 1000 %>

    <%# MISSION %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :mission,
          label_text: "Mission",
          hint_text: "今の自分に最も必要なことは？",
          placeholder: "今の自分に最も必要なことを書いてください",
          example: "例: 睡眠の質を改善して、毎日の集中力を高める",
          rows: 3,
          maxlength: 1000 %>

    <%# VALUE %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :value,
          label_text: "Value",
          hint_text: "絶対に譲れないことは？",
          placeholder: "あなたが大切にしている価値観を書いてください",
          example: "例: 家族との夕食時間は削らない。週末の休息は確保する",
          rows: 2,
          maxlength: 500 %>

    <%# CURRENT %>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :current_situation,
          label_text: "Current",
          hint_text: "今の自分の現状を教えてください",
          placeholder: "現在の状況や課題を具体的に書いてください（AIの分析精度が上がります）",
          example: "例: 夜11時に寝ているが質が悪く、朝起きるのが辛い。筋トレは週2回できている",
          rows: 3,
          maxlength: 1000 %>

    <%# ── ボタンエリア ───────────────────────────────────────────── %>
    <div class="flex justify-end items-center gap-4 pt-2">
      <%= link_to "キャンセル",
                  user_purpose_path,
                  class: "px-5 py-3 bg-white border border-gray-300 text-gray-700
                          text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors
                          focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
      <%= f.submit "✨ 保存してAI分析を開始",
            class: "flex-1 py-3 px-4 bg-violet-600 text-white text-sm font-semibold
                    rounded-xl hover:bg-violet-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500",
            data: {
              "form-submit-target": "button",
              "loading-text": "保存中..."
            } %>
    </div>

  <% end %>
</div>

<%= render "shared/crisis_intervention_modal" %>
