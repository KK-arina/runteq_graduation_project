<%# app/views/weekly_reflections/index.html.erb %>
<%#
  週次振り返り一覧ページのビュー
  Issue #21 で実装

  このファイルの役割:
  - 今週の振り返り作成ボタン（日曜AM4:00以降のみ表示）
  - 今週の習慣達成率のサマリー
  - 過去の振り返り履歴リスト
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ===================================================
      ページタイトルエリア
      =================================================== %>
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">週次振り返り</h1>
      <%# サブタイトルで現在の週を表示します
          week_label メソッドは WeeklyReflection モデルに定義しており
          「2026/02/16 - 02/22」のような文字列を返します %>
      <p class="text-sm text-gray-500 mt-1">
        PDCAサイクルを回して習慣を改善しましょう
      </p>
    </div>
  </div>

  <%# ===================================================
      今週の振り返りカード
      =================================================== %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-8">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      今週の状況
    </h2>

    <%# 今週の日付範囲を表示します
        WeeklyReflection モデルの current_week_start_date を使い
        月曜日〜日曜日の範囲を計算します %>
    <% week_start = WeeklyReflection.current_week_start_date %>
    <% week_end   = week_start + 6.days %>
    <p class="text-base font-semibold text-gray-700 mb-4">
      <%= week_start.strftime("%Y/%m/%d") %>（月）
      〜
      <%= week_end.strftime("%m/%d") %>（日）
    </p>

    <%# --- 今週の習慣達成率サマリー --- %>
    <% if @habits.any? %>
      <%# プログレスバーで全体達成率を視覚的に表示します %>
      <div class="mb-4">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm font-medium text-gray-600">今週の習慣達成率</span>
          <span class="text-sm font-bold text-blue-600"><%= @overall_rate %>%</span>
        </div>
        <%# プログレスバー外側: グレーの背景 %>
        <div class="w-full bg-gray-200 rounded-full h-2.5">
          <%# プログレスバー内側: 達成率に応じて幅が変わる
              style= で動的に幅を設定しています
              Tailwind CSS の動的クラスは JIT モードでないと動作しないため
              style 属性で直接指定するのが確実な方法です %>
          <div class="h-2.5 rounded-full transition-all duration-300
                      <%= @overall_rate >= 70 ? 'bg-green-500' :
                          @overall_rate >= 40 ? 'bg-yellow-400' : 'bg-red-400' %>"
               style="width: <%= @overall_rate %>%">
          </div>
        </div>
      </div>

      <%# 各習慣の達成率を個別に表示します %>
      <div class="space-y-2">
        <% @habits.each do |habit| %>
          <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0 } %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600 truncate max-w-xs"><%= habit.name %></span>
            <div class="flex items-center gap-2 flex-shrink-0 ml-4">
              <span class="text-gray-400 text-xs">
                <%= stats[:completed_count] %>/<%= habit.weekly_target %>日
              </span>
              <span class="font-semibold
                           <%= stats[:rate] >= 70 ? 'text-green-600' :
                               stats[:rate] >= 40 ? 'text-yellow-500' : 'text-red-500' %>">
                <%= stats[:rate] %>%
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# 習慣が0件の場合のメッセージ %>
      <p class="text-sm text-gray-400">
        まだ習慣が登録されていません。
        <%= link_to "習慣を追加する", new_habit_path,
            class: "text-blue-500 hover:text-blue-700 underline" %>
      </p>
    <% end %>

    <%# --- 振り返り作成ボタン or 状態表示 --- %>
    <div class="mt-6 pt-4 border-t border-gray-100">

      <%# @can_create_reflection は WeeklyReflectionsController の
          can_create_reflection? メソッドで計算された値です
          条件: 日曜日 かつ 今週の振り返りが未完了 %>
      <% if @can_create_reflection %>
        <%# 振り返りを作成できる状態（日曜日 かつ 未完了） %>
        <div class="flex items-center gap-3">
          <%# new_weekly_reflection_path は routes.rb で定義した
              GET /weekly_reflections/new へのパスです
              Issue #22 で実装予定のページへ遷移します %>
          <%= link_to new_weekly_reflection_path,
              class: "flex-1 inline-flex items-center justify-center px-6 py-3
                      bg-blue-600 hover:bg-blue-700 text-white font-semibold
                      rounded-lg transition-colors duration-200 gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5
                       m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828
                       l8.586-8.586z" />
            </svg>
            今週を振り返る
          <% end %>
        </div>
        <p class="text-xs text-gray-400 mt-2">
          ✨ 今週の振り返りを記入して、来週につなげましょう
        </p>

      <% elsif @current_week_reflection.completed? %>
        <%# 今週の振り返りが完了済みの場合 %>
        <div class="flex items-center gap-2 text-green-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm font-semibold">今週の振り返りは完了しています</span>
        </div>
        <%# 完了済みの場合は詳細ページへのリンクを表示します
            @current_week_reflection は保存済みなので id が存在します %>
        <% if @current_week_reflection.persisted? %>
          <%= link_to "詳細を見る →", weekly_reflection_path(@current_week_reflection),
              class: "text-sm text-blue-500 hover:text-blue-700 mt-1 inline-block" %>
        <% end %>

      <% else %>
        <%# 日曜日ではない（平日・土曜日）の場合 %>
        <div class="flex items-center gap-2 text-gray-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7
                     a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">
            振り返りは<strong class="text-gray-600">日曜日</strong>に行うことができます
          </span>
        </div>
        <%# 次の日曜日がいつか計算して表示します
            today から次の日曜日（wday: 0）を求めます %>
        <% today = HabitRecord.today_for_record %>
        <% days_until_sunday = (7 - today.wday) % 7 %>
        <% days_until_sunday = 7 if days_until_sunday == 0 && today.wday != 0 %>
        <% next_sunday = today + days_until_sunday.days %>
        <p class="text-xs text-gray-400 mt-1">
          次の振り返り日: <%= next_sunday.strftime("%m/%d（日）") %>
        </p>
      <% end %>
    </div>
  </div>

  <%# ===================================================
      過去の振り返り履歴リスト
      =================================================== %>
  <div>
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      過去の振り返り履歴
    </h2>

    <% if @past_reflections.any? %>
      <div class="space-y-4">
        <% @past_reflections.each do |reflection| %>
          <%# 各振り返りをカード形式で表示します
              weekly_reflection_path(reflection) は
              GET /weekly_reflections/:id へのパスです（Issue #23 で実装予定） %>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm
                      hover:shadow-md transition-shadow duration-200 p-5">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <%# 対象週の日付範囲を表示します
                    week_label メソッドは WeeklyReflection モデルに定義済みです %>
                <h3 class="text-base font-bold text-gray-800 mb-1">
                  <%= reflection.week_label %>
                </h3>

                <%# 振り返り完了日（作成日）を表示します %>
                <p class="text-xs text-gray-400 mb-3">
                  作成日: <%= reflection.created_at.strftime("%Y/%m/%d") %>
                </p>

                <%# 振り返りコメントのプレビュー（存在する場合のみ）
                    truncate は長い文字列を指定文字数で切り詰めるメソッドです %>
                <% if reflection.reflection_comment.present? %>
                  <p class="text-sm text-gray-600 line-clamp-2">
                    <%= truncate(reflection.reflection_comment, length: 80) %>
                  </p>
                <% end %>
              </div>

              <%# 詳細ページへのリンクボタン
                  Issue #23 で詳細ページを実装します %>
              <div class="ml-4 flex-shrink-0">
                <%= link_to "詳細を見る",
                    weekly_reflection_path(reflection),
                    class: "inline-flex items-center px-3 py-2 text-sm font-medium
                            text-gray-600 bg-gray-100 rounded-lg
                            hover:bg-gray-200 transition-colors duration-200" %>
              </div>
            </div>

            <%# 習慣サマリーがある場合は達成率のチップを表示します
                has_many :habit_summaries で関連付けられています %>
            <% if reflection.habit_summaries.any? %>
              <div class="mt-3 pt-3 border-t border-gray-100">
                <div class="flex flex-wrap gap-2">
                  <% reflection.habit_summaries.each do |summary| %>
                    <%# 達成率に応じてバッジの色を変えます
                        clamp で 0〜100 に収めた値を使います %>
                    <% rate = summary.achievement_rate.to_i %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full
                                 text-xs font-medium
                                 <%= rate >= 70 ? 'bg-green-100 text-green-700' :
                                     rate >= 40 ? 'bg-yellow-100 text-yellow-700' :
                                                  'bg-red-100 text-red-600' %>">
                      <%= summary.habit_name %>: <%= rate %>%
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

    <% else %>
      <%# 過去の振り返りが0件の場合の Empty State %>
      <div class="bg-white rounded-xl border-2 border-dashed border-gray-300
                  p-12 text-center">
        <div class="mx-auto w-16 h-16 rounded-full bg-blue-50
                    flex items-center justify-center mb-4">
          <%# カレンダーアイコン（SVG） %>
          <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor"
               viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7
                     a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2
                     M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <h3 class="text-base font-semibold text-gray-700 mb-2">
          まだ振り返りがありません
        </h3>
        <p class="text-sm text-gray-400">
          毎週日曜日に振り返りを行い、<br>
          習慣改善のPDCAサイクルを回しましょう
        </p>
      </div>
    <% end %>
  </div>
</div>