<%# app/views/weekly_reflections/index.html.erb %>
<%#
  ═══════════════════════════════════════════════════════════════════
  【このファイルの役割】
    週次振り返り一覧ページ。
    ・今週の振り返りボタン（未完了時のみ表示）
    ・今週の習慣達成率サマリー
    ・過去の完了済み振り返り一覧

  【単位表示の修正内容】
    修正前: チェック型・数値型どちらも「回」と決め打ちしていた
            例: 「6 / 7 回（85%）」← 数値型（読書/冊）でも「回」になっていた

    修正後: habit.check_type? で分岐して単位を出し分ける
            チェック型 → 「5 / 7 日」（completed_count を使う）
            数値型     → 「6 / 7 冊」（numeric_sum と habit.unit を使う）

  【なぜ分岐が必要なのか】
    チェック型と数値型では「何を記録するか」が異なるため、
    同じ「回」という単位で統一すると誤情報になる。
    habit の種類に応じて「どの数値」を「どの単位」で表示するか切り替える必要がある。
  ═══════════════════════════════════════════════════════════════════
%>

<% content_for :title, "週次振り返り | HabitFlow" %>

<div class="max-w-3xl mx-auto px-4 py-8">

  <%# ── ページヘッダー ── %>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">週次振り返り</h1>
    <p class="mt-1 text-gray-500 text-sm">毎週の習慣達成状況を振り返り、次週の行動を改善しましょう。</p>
  </div>

  <%# ────────────────────────────────────────────────────────────
      今週の振り返りセクション
      ──────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">今週の状況</h2>

    <% if @current_week_reflection.persisted? && @current_week_reflection.is_locked? %>
      <div class="flex items-center justify-between flex-wrap gap-3">
        <p class="text-green-700 text-sm font-medium">
          ✅ 今週の振り返りは完了しています。
        </p>
        <%= link_to "詳細を見る →", @current_week_reflection,
              class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors" %>
      </div>

    <% elsif Time.current >= Time.current.beginning_of_week(:sunday).change(hour: 4) %>
      <div class="text-center py-2">
        <p class="text-gray-600 text-sm mb-4">今週の振り返りを記録しましょう。</p>
        <%= link_to "今週を振り返る ✍️", new_weekly_reflection_path,
              class: "inline-flex items-center justify-center px-6 py-3 bg-indigo-600 text-white rounded-xl text-sm font-semibold hover:bg-indigo-700 transition-colors" %>
      </div>

    <% else %>
      <p class="text-gray-500 text-sm">
        週次振り返りは毎週日曜日の午前4時以降に記録できます。
        <br>
        <span class="text-xs text-gray-400">
          今週の期間：
          <%= WeeklyReflection.current_week_start_date.strftime("%Y/%m/%d") %>
          〜
          <%= (WeeklyReflection.current_week_start_date + 6.days).strftime("%Y/%m/%d") %>
        </span>
      </p>
    <% end %>
  </div>

  <%# ────────────────────────────────────────────────────────────
      今週の習慣達成率サマリー（プログレスバー一覧）
      ──────────────────────────────────────────────────────────── %>
  <% if @habits.any? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">📊 今週の習慣達成状況</h2>

      <div class="space-y-3">
        <% @habits.each do |habit| %>
          <%#
            @habit_stats[habit.id] には以下のキーが入っている（weekly_reflections_controller.rb で設定）:
              チェック型: { rate: 整数, completed_count: 整数, numeric_sum: nil }
              数値型:     { rate: 整数, completed_count: nil, numeric_sum: 小数 }
          %>
          <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0, numeric_sum: nil } %>

          <div>
            <div class="flex justify-between text-sm mb-1">
              <%# 習慣名 %>
              <span class="text-gray-700 font-medium"><%= habit.name %></span>

              <%#
                【変更】habit_progress_text ヘルパーで表記を統一する。
                チェック型の分母を weekly_target → effective_weekly_target に変更し
                ダッシュボード・習慣管理と同じ表記にする。
              %>
              <span class="text-gray-500">
                <%= habit_progress_text(habit, stats) %>
              </span>
              <%# ────────────────────────────────────────────────────────────────── %>
            </div>

            <%#
              プログレスバー
              stats[:rate].to_i: rate が nil や String の場合も整数に変換してから比較する
              [stats[:rate].to_i, 100].min: 100% を超えてバーがはみ出さないようにする
            %>
            <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
              <%#
                【変更】色分けロジックをダッシュボード・習慣管理と統一する。
                変更前: 4段階（100%=緑/70%=青/40%=黄/未満=赤）
                変更後: 3段階（80%=緑/50%=青/未満=赤）
                Tailwind の動的クラスはビルド時に検出されないため
                rate_hex_color でインラインスタイルに変更する。
              %>
              <div class="h-2 rounded-full transition-all duration-500"
                   style="width: <%= [stats[:rate].to_i, 100].min %>%;
                          background-color: <%= rate_hex_color(stats[:rate].to_i) %>">
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ────────────────────────────────────────────────────────────
      過去の完了済み振り返り一覧
      ──────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">📖 過去の振り返り履歴</h2>

    <% if @weekly_reflections.empty? %>
      <div class="text-center py-8">
        <p class="text-gray-400 text-sm">まだ振り返りがありません。</p>
        <p class="text-gray-400 text-xs mt-1">日曜日の午前4時以降に最初の振り返りができます。</p>
      </div>

    <% else %>
      <div class="space-y-3">
        <% @weekly_reflections.each do |reflection| %>
          <%= link_to reflection,
                class: "block border border-gray-100 rounded-xl p-4 hover:border-indigo-200 hover:bg-indigo-50 transition-all group" do %>

            <div class="flex items-center justify-between flex-wrap gap-2">
              <div>
                <p class="font-medium text-gray-800 text-sm group-hover:text-indigo-700 transition-colors">
                  <%= reflection.week_start_date.strftime("%Y年%m月%d日") %>
                  〜
                  <%= reflection.week_end_date.strftime("%m月%d日") %>
                </p>
                <p class="text-xs text-gray-500 mt-0.5">
                  <%= reflection.created_at.strftime("%Y/%m/%d") %> 記録
                </p>
              </div>

              <div class="flex items-center gap-3">
                <% summaries = reflection.habit_summaries.to_a %>
                <% avg_rate = summaries.any? ? (summaries.map(&:achievement_rate).sum / summaries.size.to_f).round(1) : 0 %>

                <span class="text-xs text-gray-500">
                  <%= summaries.size %>習慣
                </span>

                <span class="text-sm font-bold
                  <%= avg_rate >= 100 ? 'text-green-600' :
                      avg_rate >= 70  ? 'text-blue-600' :
                      avg_rate >= 40  ? 'text-yellow-600' : 'text-red-500' %>">
                  <%= avg_rate %>%
                </span>

                <svg class="w-4 h-4 text-gray-400 group-hover:text-indigo-500 transition-colors"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>

            <% if reflection.reflection_comment.present? %>
              <p class="mt-2 text-xs text-gray-500 truncate">
                💬 <%= reflection.reflection_comment.truncate(80) %>
              </p>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

</div>

<%#
  ─────────────────────────────────────────────────────────────────────────────
  D-5: 危機介入モーダル（振り返り一覧ページ）
  ─────────────────────────────────────────────────────────────────────────────
  【なぜ index.html.erb にモーダルを置くのか】
    振り返り保存完了後（completed_at がセット済み）は
    /weekly_reflections/new に戻れないため、
    crisis 検出時のリダイレクト先を weekly_reflections_path（一覧）に変更した。
    flash[:crisis] = true を受け取るページにパーシャルが必要なため追加する。
%>
<%= render "shared/crisis_intervention_modal" %>

<%#
  D-6: AI コスト上限モーダル（14-B）
  complete_without_ai アクション後に weekly_reflections_path に
  リダイレクトされた場合に備えて配置する。
  通常このページでモーダルが開くことはないが、念のため配置しておく。
%>
<%= render "weekly_reflections/ai_limit_modal" %>