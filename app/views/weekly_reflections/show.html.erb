<%# app/views/weekly_reflections/show.html.erb %>
<%#
  ==============================================================================
  週次振り返り詳細ページ（E-1: 気分スコア表示追加）
  ==============================================================================
  【E-1 での変更内容】
    セクション③（振り返りコメント）内の先頭に気分スコア表示を追加する。
    mood カラムの値（1〜5）を星（★☆）と絵文字ラベルで表示する。
    mood が nil（未入力）の場合は「入力されていませんでした」と表示する。
  ==============================================================================
%>

<% content_for :title, "振り返り詳細 | HabitFlow" %>

<div class="max-w-3xl mx-auto px-4 py-8">

  <%# ページヘッダー %>
  <div class="mb-8">
    <%= link_to weekly_reflections_path,
          class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4 transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      振り返り一覧に戻る
    <% end %>

    <div class="flex items-center gap-3 flex-wrap">
      <h1 class="text-2xl font-bold text-gray-900">週次振り返り</h1>
      <% if @weekly_reflection.is_locked? %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800">
          ✓ 完了
        </span>
      <% end %>
    </div>

    <p class="mt-2 text-gray-600">
      対象期間：
      <span class="font-medium text-gray-800">
        <%= @weekly_reflection.week_start_date.strftime("%Y年%m月%d日") %>
        〜
        <%= @weekly_reflection.week_end_date.strftime("%Y年%m月%d日") %>
      </span>
    </p>
  </div>

  <%# セクション①: 全体達成率サマリー %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">📊 今週の総合達成率</h2>

    <div class="flex items-end gap-3 mb-4">
      <span class="text-5xl font-bold
        <%= @overall_achievement_rate >= 100 ? 'text-green-600' :
            @overall_achievement_rate >= 70  ? 'text-blue-600' :
            @overall_achievement_rate >= 40  ? 'text-yellow-600' : 'text-red-500' %>">
        <%= @overall_achievement_rate %>%
      </span>
      <span class="text-gray-500 mb-1 text-sm">(<%= @habit_summaries.size %>個の習慣)</span>
    </div>

    <div class="w-full bg-gray-200 rounded-full h-4 overflow-hidden"
         role="progressbar"
         aria-valuenow="<%= [@overall_achievement_rate, 100].min %>"
         aria-valuemin="0" aria-valuemax="100" aria-label="総合達成率">
      <div class="h-4 rounded-full transition-all duration-500
        <%= @overall_achievement_rate >= 100 ? 'bg-green-500' :
            @overall_achievement_rate >= 70  ? 'bg-blue-500' :
            @overall_achievement_rate >= 40  ? 'bg-yellow-400' : 'bg-red-400' %>"
           style="width: <%= [@overall_achievement_rate, 100].min %>%">
      </div>
    </div>

    <p class="mt-2 text-sm text-gray-500 text-right">
      達成: <%= @habit_summaries.count { |s| s.achievement_rate >= 100 } %> / <%= @habit_summaries.size %> 習慣
    </p>
  </div>

  <%# セクション②: 習慣別 実績サマリー %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-5">📋 習慣別 実績サマリー</h2>

    <% if @habit_summaries.empty? %>
      <div class="text-center py-8 text-gray-400">
        <p class="text-sm">この振り返り期間に登録されていた習慣はありませんでした。</p>
      </div>
    <% else %>
      <div class="space-y-4">
        <% @habit_summaries.each do |summary| %>
          <div class="border border-gray-100 rounded-xl p-4
            <%= summary.achievement_rate >= 100 ? 'bg-green-50 border-green-200' : 'bg-gray-50' %>">
            <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
              <div class="flex items-center gap-2">
                <%= summary.achievement_rate >= 100 ? '<span class="text-green-500 text-lg">✅</span>'.html_safe : '<span class="text-gray-300 text-lg">⬜</span>'.html_safe %>
                <span class="font-medium text-gray-800 text-sm"><%= summary.habit_name %></span>
              </div>
              <span class="text-xs font-semibold px-2 py-1 rounded-full
                <%= summary.achievement_rate >= 100 ? 'bg-green-100 text-green-700' :
                    summary.achievement_rate >= 70  ? 'bg-blue-100 text-blue-700' :
                    summary.achievement_rate >= 40  ? 'bg-yellow-100 text-yellow-700' :
                                                      'bg-red-100 text-red-600' %>">
                <%= summary.achievement_rate %>%
              </span>
            </div>
            <div class="flex items-center justify-between text-xs text-gray-500 mb-2">
              <span><%= summary.actual_count %> / <%= summary.weekly_target %> 回達成</span>
              <span>週<%= summary.weekly_target %>回目標</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
              <div class="h-2 rounded-full transition-all duration-500
                <%= summary.achievement_rate >= 100 ? 'bg-green-500' :
                    summary.achievement_rate >= 70  ? 'bg-blue-500' :
                    summary.achievement_rate >= 40  ? 'bg-yellow-400' : 'bg-red-400' %>"
                   style="width: <%= [summary.achievement_rate, 100].min %>%">
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% achieved_count = @habit_summaries.count { |s| s.achievement_rate >= 100 } %>
      <% if achieved_count > 0 %>
        <p class="mt-4 text-sm text-green-700 bg-green-50 rounded-lg px-4 py-2">
          🎉 <span class="font-semibold"><%= achieved_count %>個</span>の習慣を100%達成しました！
        </p>
      <% end %>
    <% end %>
  </div>

  <%# セクション②-B: タスク実績サマリー %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-5">✅ タスク実績</h2>

    <% if @task_summaries.empty? %>
      <div class="text-center py-8 text-gray-400">
        <p class="text-sm">この振り返り期間に記録されたタスクはありませんでした。</p>
      </div>
    <% else %>
      <% must_tasks   = @task_summaries.select(&:must?)   %>
      <% should_tasks = @task_summaries.select(&:should?) %>
      <% could_tasks  = @task_summaries.select(&:could?)  %>

      <div class="space-y-3 mb-6">
        <% [
          { label: "Must",   color: "red",   tasks: must_tasks   },
          { label: "Should", color: "blue",  tasks: should_tasks },
          { label: "Could",  color: "green", tasks: could_tasks  }
        ].each do |group| %>
          <% next if group[:tasks].empty? %>
          <% completed_count = group[:tasks].count(&:was_completed) %>
          <% total_count     = group[:tasks].size %>
          <% rate = total_count.zero? ? 0 : (completed_count.to_f / total_count * 100).round %>
          <div>
            <div class="flex items-center justify-between text-sm mb-1">
              <div class="flex items-center gap-2">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-bold
                  bg-<%= group[:color] %>-100 text-<%= group[:color] %>-700">
                  <%= group[:label] %>
                </span>
                <span class="text-gray-600 text-xs"><%= completed_count %> / <%= total_count %> 件完了</span>
              </div>
              <span class="font-semibold text-gray-700 text-xs"><%= rate %>%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
              <div class="h-2 rounded-full transition-all duration-500
                <%= rate >= 100 ? "bg-#{group[:color]}-500" :
                    rate >= 70  ? "bg-#{group[:color]}-400" : "bg-#{group[:color]}-300" %>"
                  style="width: <%= [rate, 100].min %>%">
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="space-y-2">
        <% @task_summaries.each do |summary| %>
          <div class="flex items-start gap-3 p-3 rounded-xl border
            <%= summary.was_completed ? 'bg-gray-50 border-gray-100' : 'bg-white border-gray-200' %>">
            <div class="flex-shrink-0 mt-0.5">
              <%= summary.was_completed ? '<span class="text-green-500 text-lg">✅</span>'.html_safe : '<span class="text-gray-300 text-lg">⬜</span>'.html_safe %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium <%= summary.was_completed ? 'text-gray-400 line-through' : 'text-gray-800' %>">
                <%= summary.title %>
              </p>
              <div class="flex items-center gap-2 mt-1 flex-wrap">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-bold <%= summary.priority_color_class %>">
                  <%= summary.priority_label %>
                </span>
                <% if summary.due_date.present? %>
                  <span class="text-xs text-gray-400">期限: <%= summary.due_date.strftime("%m/%d") %></span>
                <% end %>
                <% if summary.was_completed && summary.completed_at.present? %>
                  <span class="text-xs text-gray-400">完了: <%= summary.completed_at.strftime("%m/%d %H:%M") %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% completed_total = @task_summaries.count(&:was_completed) %>
      <% if completed_total > 0 %>
        <p class="mt-4 text-sm text-green-700 bg-green-50 rounded-lg px-4 py-2">
          🎉 <span class="font-semibold"><%= completed_total %>件</span>のタスクを完了しました！
        </p>
      <% end %>
    <% end %>
  </div>

  <%# ──────────────────────────────────────────────────────────
      セクション③: 振り返りコメント（E-1: 気分スコアを先頭に追加）
      ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-5">💬 振り返りコメント</h2>

    <%# ════════════════════════════════════════════════════════
        E-1 追加: 気分スコア表示ブロック
        ════════════════════════════════════════════════════════
        【なぜこの場所に置くのか】
          振り返りコメントセクションの先頭に置くことで、
          「感情状態→振り返り内容」の流れで確認できる。

        【mood の値とラベルの対応】
          1 → 😞 とても悪い
          2 → 😕 悪い
          3 → 😐 普通
          4 → 😊 良い
          5 → 😄 とても良い

        【星表示の実装】
          1〜5 を each でループし、mood 値以下を ★（黄色）、
          mood 値より大きいものを ☆（グレー）で表示する。
          純粋な Ruby 条件分岐で実装するためJSは不要。
    %>
    <div class="mb-5 pb-5 border-b border-gray-100">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-sm font-bold text-gray-700">😊 今週の気分スコア</span>
      </div>
      <% if @weekly_reflection.mood.present? %>
        <% mood_labels = {
          1 => "😞 とても悪い",
          2 => "😕 悪い",
          3 => "😐 普通",
          4 => "😊 良い",
          5 => "😄 とても良い"
        } %>
        <div class="flex items-center gap-3 flex-wrap">
          <%# 星（★☆）を 1〜5 の順に並べる %>
          <div class="flex items-center gap-0.5">
            <% (1..5).each do |score| %>
              <span class="text-2xl leading-none <%= score <= @weekly_reflection.mood ? 'text-yellow-400' : 'text-gray-300' %>"
                    aria-hidden="true">
                <%= score <= @weekly_reflection.mood ? '★' : '☆' %>
              </span>
            <% end %>
          </div>
          <%# スコア数値 %>
          <span class="text-sm font-semibold text-gray-700">
            <%= @weekly_reflection.mood %> / 5
          </span>
          <%# テキストラベル %>
          <span class="text-sm text-gray-500">
            <%= mood_labels[@weekly_reflection.mood] %>
          </span>
        </div>
      <% else %>
        <%# mood が nil（未入力）の場合 %>
        <p class="text-gray-400 text-sm italic px-1">入力されていませんでした。</p>
      <% end %>
    </div>
    <%# ══ E-1 気分スコア表示ブロック ここまで ══ %>

    <%# なぜ？（direct_reason） %>
    <div class="mb-5">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-sm font-bold text-gray-700">なぜ？</span>
        <span class="text-xs text-gray-400">（直接の原因）</span>
      </div>
      <% if @weekly_reflection.direct_reason.present? %>
        <div class="text-gray-700 text-sm leading-relaxed bg-gray-50 rounded-xl p-4">
          <%= simple_format(@weekly_reflection.direct_reason) %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm italic px-1">記入されていませんでした。</p>
      <% end %>
    </div>

    <%# どう？（background_situation） %>
    <div class="mb-5">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-sm font-bold text-gray-700">どう？</span>
        <span class="text-xs text-gray-400">（改善策）</span>
      </div>
      <% if @weekly_reflection.background_situation.present? %>
        <div class="text-gray-700 text-sm leading-relaxed bg-gray-50 rounded-xl p-4">
          <%= simple_format(@weekly_reflection.background_situation) %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm italic px-1">記入されていませんでした。</p>
      <% end %>
    </div>

    <%# からの？（next_action） %>
    <div class="mb-5">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-sm font-bold text-gray-700">からの？</span>
        <span class="text-xs text-gray-400">（次への展開）</span>
      </div>
      <% if @weekly_reflection.next_action.present? %>
        <div class="text-gray-700 text-sm leading-relaxed bg-gray-50 rounded-xl p-4">
          <%= simple_format(@weekly_reflection.next_action) %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm italic px-1">記入されていませんでした。</p>
      <% end %>
    </div>

    <%# 自由コメント（reflection_comment） %>
    <% if @weekly_reflection.reflection_comment.present? %>
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-bold text-gray-700">自由コメント</span>
        </div>
        <div class="text-gray-700 text-sm leading-relaxed bg-gray-50 rounded-xl p-4">
          <%= simple_format(@weekly_reflection.reflection_comment) %>
        </div>
      </div>
    <% end %>
  </div>

  <%# セクション④: メタ情報 %>
  <div class="bg-gray-50 rounded-xl px-5 py-4 mb-8 flex flex-wrap gap-4 text-xs text-gray-500">
    <span>
      📅 振り返り登録日：
      <span class="font-medium text-gray-700">
        <%= @weekly_reflection.created_at.strftime("%Y年%m月%d日 %H:%M") %>
      </span>
    </span>
    <% if @weekly_reflection.updated_at != @weekly_reflection.created_at %>
      <span>
        ✏️ 最終更新：
        <span class="font-medium text-gray-700">
          <%= @weekly_reflection.updated_at.strftime("%Y年%m月%d日 %H:%M") %>
        </span>
      </span>
    <% end %>
  </div>

  <%# フッターボタン %>
  <div class="flex flex-col sm:flex-row gap-3 justify-between">
    <%= link_to "← 振り返り一覧", weekly_reflections_path,
          class: "inline-flex items-center justify-center px-6 py-3 bg-white border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors" %>
    <%= link_to "ダッシュボードへ", dashboard_path,
          class: "inline-flex items-center justify-center px-6 py-3 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors" %>
  </div>

</div>
