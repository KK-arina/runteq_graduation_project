<%# app/views/weekly_reflections/new.html.erb %>
<%#
  【このファイルの役割】
  週次振り返り入力ページのビュー。
  ユーザーが今週の実績を確認しながら振り返りコメントを入力して保存する。

  【使用するインスタンス変数（コントローラーから受け取る）】
  @weekly_reflection   : WeeklyReflection インスタンス（フォームのモデル）
  @habits              : 有効な習慣の一覧
  @habit_stats         : 各習慣の進捗 { habit_id => { rate:, completed_count: } }
  @achieved_habits     : 達成済み習慣（rate >= 100）の配列
  @not_achieved_habits : 未達成習慣（rate < 100）の配列

  【Issue #27 での変更点】
  バリデーションエラー表示を shared/_form_errors パーシャルに統一。

  【Issue #32 での変更点】
    ① フォームタグに form-submit コントローラーを紐付けてローディングを実装
    ② ボタンエリアの「キャンセル」と「振り返りを完了する」の視覚的重みを差別化
       変更前: 両方が flex-1 で同じ幅・同じ重みに見えた
       変更後:
         キャンセル → セカンダリボタン（グレー系、幅 auto）
         完了 → プライマリボタン（青、flex-1 で広く）
         → 主要アクションに目線が誘導され、誤操作リスクが下がる
%>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%# ==========================================
      ページヘッダー
  ========================================== %>
  <div class="mb-8">
    <%= link_to "← 振り返り一覧に戻る",
        weekly_reflections_path,
        class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
    <h1 class="mt-3 text-2xl font-bold text-gray-900">今週を振り返る</h1>
    <p class="mt-1 text-sm text-gray-500">
      対象期間:
      <span class="font-semibold text-gray-700"><%= @weekly_reflection.week_label %></span>
    </p>
  </div>

  <%# ==========================================
      習慣実績セクション
      【なぜ実績を先に表示するか】
      「何を書けばいいかわからない」状態を防ぐため、
      自動集計された今週の実績を目の前に提示する。
      ユーザーが「できたこと・できなかったこと」を言語化しやすくなる。
  ========================================== %>

  <% if @habits.empty? %>
    <div class="mb-8 p-6 bg-gray-50 border border-dashed border-gray-300 rounded-xl text-center">
      <p class="text-gray-500 text-sm">まだ習慣が登録されていません。</p>
      <%= link_to "習慣を登録する", new_habit_path,
          class: "mt-2 inline-block text-blue-600 text-sm font-semibold hover:underline" %>
    </div>

  <% else %>

    <%# -------- 達成できた習慣 -------- %>
    <% unless @achieved_habits.empty? %>
      <section class="mb-6">
        <h2 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-emerald-700 mb-3">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 text-xs">✓</span>
          達成できた習慣
        </h2>
        <div class="space-y-3">
          <% @achieved_habits.each do |habit| %>
            <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0 } %>
            <div class="bg-white border border-emerald-200 rounded-xl p-4 shadow-sm flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-800 truncate"><%= habit.name %></p>
                <p class="text-xs text-gray-500 mt-0.5">
                  <%= stats[:completed_count] %> / <%= habit.weekly_target %> 日達成
                </p>
              </div>
              <span class="flex-shrink-0 inline-block px-3 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700">
                <%= stats[:rate] %>%
              </span>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# -------- 達成できなかった習慣 -------- %>
    <% unless @not_achieved_habits.empty? %>
      <section class="mb-6">
        <h2 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-red-600 mb-3">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-red-100 text-red-500 text-xs font-bold">!</span>
          達成できなかった習慣
        </h2>
        <div class="space-y-3">
          <% @not_achieved_habits.each do |habit| %>
            <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0 } %>
            <div class="bg-white border border-red-200 rounded-xl p-4 shadow-sm">
              <div class="flex items-center justify-between gap-4 mb-2">
                <p class="font-semibold text-gray-800 truncate"><%= habit.name %></p>
                <span class="flex-shrink-0 text-xs font-bold
                             <%= stats[:rate] >= 50 ? 'text-yellow-600' : 'text-red-600' %>">
                  <%= stats[:completed_count] %> / <%= habit.weekly_target %> 日 (<%= stats[:rate] %>%)
                </span>
              </div>
              <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= stats[:rate] >= 50 ? 'bg-yellow-400' : 'bg-red-400' %>"
                     style="width: <%= stats[:rate] %>%;"></div>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

  <% end %>

  <%# ==========================================
      振り返りフォーム

      【form_with の書き方について】
      model: @weekly_reflection だけを渡す。
      Rails は model の状態（new_record? か persisted? か）を自動判断して
      「新規なら POST /weekly_reflections」と正しく設定してくれる。

      local: true: Hotwire/Turbo の Ajax 送信を無効化して通常のHTMLフォーム送信にする。

      【Issue #32 追加】
      data-controller="form-submit": 送信ローディングコントローラーを紐付ける
      data-action="submit->form-submit#submit":
        フォームの submit イベントで form-submit#submit を呼ぶ
  ========================================== %>
  <%= form_with model: @weekly_reflection,
                local: true,
                class: "space-y-6",
                data: {
                  controller: "form-submit",
                  action: "submit->form-submit#submit"
                } do |f| %>

    <%# ---- バリデーションエラーの表示 ---- %>
    <%= render "shared/form_errors", model: @weekly_reflection %>

    <%# ---- 振り返りコメント入力欄 ---- %>
    <div>
      <%= f.label :reflection_comment, "振り返りコメント",
          class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">
        今週の気づき・反省・来週への意気込みなどを自由に書いてください（任意、1000文字以内）
      </p>
      <%#
        text_area: 複数行テキスト入力
        rows: 6: 表示する行数（ユーザーが一定量のテキストを書きやすい高さ）
        maxlength: 1000: ブラウザ側での最大文字数制限（サーバー側バリデーションと二重防御）
        resize-none: ユーザーがリサイズできないようにする
          リサイズするとレイアウトが崩れる可能性があるため
      %>
      <%= f.text_area :reflection_comment,
          rows: 6,
          placeholder: "例: 今週は残業が続いて筋トレができなかった。来週は朝に時間を作りたい。",
          maxlength: 1000,
          class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm
                  focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                  resize-none transition-colors" %>
    </div>

    <%# ---- ボタンエリア ---- %>
    <%#
      【Issue #32 変更点】ボタンの視覚的重みを差別化する

      変更前:
        両ボタンが flex-1 で同じ幅・同じ重みに見えた。
        ユーザーはどちらが主要アクションかわからず、誤クリックリスクがあった。

      変更後:
        「キャンセル」: セカンダリボタン（グレー系, width: auto）
          → 補助的な操作であることを視覚的に示す
        「振り返りを完了する」: プライマリボタン（青, flex-1 で広く）
          → 主要アクションであることを強調し、ユーザーの目線を誘導する

      justify-end: ボタンエリアを右寄せにする
        → 「続ける/完了」を右端に置く慣習的な UI パターン（フォームの流れと合致する）

      gap-4: ボタン間の余白 16px
        → gap-3(12px) から gap-4(16px) に変更。
          モバイルでの誤タップを防ぐため、ボタン間の距離を十分に確保する。
    %>
    <div class="flex justify-end items-center gap-4 pt-2">

      <%#
        キャンセルボタン（セカンダリ）
        link_to でリンクとして実装（フォーム送信ではなくページ遷移）

        px-5 py-3: ボタンとして十分なクリック領域（Apple 推奨の 44px 以上のタップ領域）
        border border-gray-300: 枠線を付けることでボタンらしく見せる
          → 背景色だけだとリンクとの区別がつきにくいため
        bg-white: 白背景（グレー系でありながら border で存在感を出す）
        text-gray-700: グレーテキスト
          【コントラスト確認】
          text-gray-700 (#374151) on bg-white (#ffffff) = 10.7:1 → AAA基準クリア
        hover:bg-gray-50: ホバー時にごく薄いグレー（インタラクティブを示す）
        rounded-xl: フォームカードと同じ角丸
        transition-colors: 色変化を滑らかに

        【レビュー指摘による追加】
        focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400:
          キーボードのTabキーでフォーカスしたときにグレーのリングを表示する。
          マウス操作では表示されない（focus:outline-none で標準のアウトラインを消し、
          focus:ring でカスタムリングに置き換える）。
          キーボード操作ユーザーへのアクセシビリティ必須対応。
      %>
      <%= link_to "キャンセル",
          weekly_reflections_path,
          class: "px-5 py-3 bg-white border border-gray-300 text-gray-700 text-sm font-semibold
                  rounded-xl hover:bg-gray-50 transition-colors
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>

      <%#
        振り返りを完了するボタン（プライマリ）
        flex-1: 残りの幅を全て使う（キャンセルより広く、目立つ）
        py-3 px-4: 十分なクリック領域
        bg-blue-600 text-white: 青背景・白文字（主要アクション）
          【コントラスト確認】
          text-white (#ffffff) on bg-blue-600 (#2563eb) = 4.9:1 → AA基準クリア
        hover:bg-blue-700: ホバー時に一段濃い青
        rounded-xl: カードと同じ角丸
        transition-colors: 色変化を滑らかに
        cursor-pointer: カーソルをポインターに（submit ボタンのデフォルト動作）

        【レビュー指摘による追加】
        focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500:
          キーボードのTabキーでフォーカスしたときに青いリングを表示する。
          キャンセルがグレーリング、完了が青リングと色を変えることで
          キーボード操作でもどちらのボタンにいるか一目でわかる。
        data-form-submit-target="button": コントローラーから参照できるようにする
        data-loading-text="送信中...": 送信後に表示するテキスト
      %>
      <%= f.submit "振り返りを完了する",
          class: "flex-1 py-3 px-4 bg-blue-600 text-white text-sm font-semibold
                  rounded-xl hover:bg-blue-700 transition-colors cursor-pointer
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500",
          data: {
            "form-submit-target": "button",
            "loading-text": "送信中..."
          } %>
    </div>

  <% end %>

</div>