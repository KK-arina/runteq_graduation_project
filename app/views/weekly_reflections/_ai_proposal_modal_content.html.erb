<%# app/views/weekly_reflections/_ai_proposal_modal_content.html.erb %>
<%#
  ==============================================================================
  14-A モーダルのコンテンツ部分（E-3 修正版）
  ==============================================================================

  【E-3修正での変更内容】
    ① habit_indices[] / task_indices[] のインデックスズレバグを修正
       変更前: all_actions.each_with_index で全体index → 型別配列でズレる
       変更後: habit/task 別に独立したカウンタ変数で index を管理する

    ② reflection_id を hidden_field で送信する設計に変更
       変更前: controller 側で find_latest_completed_reflection() を使い不安定
       変更後: ビュー側でDBの reflection.id を hidden_field_tag で確実に送信

    ③ data-task-card 属性で提案カードを識別
       変更前: CSS クラス名（.border.border-gray-200...）で closest() → 脆い
       変更後: data-task-card 属性で DOM を識別 → Tailwind クラス変更に強い

  【受け取るローカル変数】
    ai_analysis  : AiAnalysis インスタンス
    user_purpose : UserPurpose インスタンス or nil
    reflection   : WeeklyReflection インスタンス（reflection_id 送信用・必須）
    mobile       : bool（スマホボトムシートから呼ばれた場合は true）
  ==============================================================================
%>

<%#
  ── actions_json を変換する ─────────────────────────────────────────────────
  with_indifferent_access: 文字列キーとシンボルキーの両方でアクセスできるようにする。
  DB から読み出した JSON は文字列キー（"type", "title"...）になるため、
  この変換でシンボルキー（:type, :title）でもアクセス可能になる。
%>
<% all_actions   = (ai_analysis.actions_json || []).map { |a| a.with_indifferent_access } %>
<% habit_actions = all_actions.select { |a| a[:type] == "habit" } %>
<% task_actions  = all_actions.select { |a| a[:type] == "task" } %>

<%#
  ── タイトルIDをモバイル/デスクトップで切り替える ─────────────────────────
  aria-labelledby で参照する ID と実際の h2 要素の ID を一致させる。
  デスクトップ: "ai-proposal-modal-title"
  スマホ:       "ai-proposal-modal-title-mobile"
%>
<% title_id = local_assigns[:mobile] ? "ai-proposal-modal-title-mobile" : "ai-proposal-modal-title" %>

<div class="p-5 sm:p-6">

  <%# ══════════════════════════════════════════════════════════════════
      セクション 1: ヘッダー
  ══════════════════════════════════════════════════════════════════ %>
  <div class="flex items-start justify-between mb-4 gap-3">
    <div class="flex items-center gap-2 flex-1 min-w-0">
      <span class="text-xl flex-shrink-0" aria-hidden="true">🤖</span>
      <h2 id="<%= title_id %>"
          class="text-base font-bold text-gray-900 leading-snug">
        来週のAI提案
      </h2>
    </div>

    <%#
      閉じる（×）ボタン:
        data-action="click->ai-proposal-modal#close":
          Stimulus の close(event) アクションを呼ぶ。
          モーダルを hidden にして body.overflow-hidden クラスを解除する。
    %>
    <button type="button"
            data-action="click->ai-proposal-modal#close"
            class="flex-shrink-0 p-1.5 text-gray-400 hover:text-gray-600 transition-colors
                   rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-400"
            aria-label="モーダルを閉じる">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <%# ══════════════════════════════════════════════════════════════════
      セクション 2: AI免責バナー（完了条件: 毎回表示）
      render "shared/ai_disclaimer": _ai_disclaimer.html.erb を呼ぶ。
      E-3 完了条件「AI免責バナーが必ず表示される」を満たすために必須。
  ══════════════════════════════════════════════════════════════════ %>
  <%= render "shared/ai_disclaimer" %>

  <%# ══════════════════════════════════════════════════════════════════
      セクション 3: AI分析コメント + PMVVとの整合性
  ══════════════════════════════════════════════════════════════════ %>
  <% if ai_analysis.analysis_comment.present? %>
    <div class="mt-4 bg-indigo-50 border border-indigo-200 rounded-xl p-4">
      <h3 class="text-sm font-bold text-indigo-800 mb-2">🎯 AI分析コメント</h3>
      <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">
        <%= ai_analysis.analysis_comment %>
      </p>

      <%#
        PMVVとの整合性セクション:
          user_purpose が存在する場合のみ表示する（E-3 完了条件）。
          improvement_suggestions は「現状と PMVV のギャップを埋める提案」を
          含んでいるため、目標との整合性を示すフィールドとして使用する。
      %>
      <% if user_purpose.present? && ai_analysis.improvement_suggestions.present? %>
        <div class="mt-3 pt-3 border-t border-indigo-200">
          <p class="text-xs font-bold text-indigo-700 mb-1">🎯 目標（PMVV）との整合性</p>
          <p class="text-xs text-gray-600 leading-relaxed">
            <%= ai_analysis.improvement_suggestions %>
          </p>
        </div>
      <% end %>

      <% if ai_analysis.coaching_message.present? %>
        <div class="mt-3 pt-3 border-t border-indigo-200">
          <p class="text-xs font-bold text-indigo-700 mb-1">💪 コーチングメッセージ</p>
          <p class="text-xs text-gray-600 leading-relaxed whitespace-pre-wrap">
            <%= ai_analysis.coaching_message %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════
      セクション 4: 変更サマリー（追加/変更/削除の差分一覧）
  ══════════════════════════════════════════════════════════════════ %>
  <% if all_actions.any? %>
    <div class="mt-4 bg-gray-50 border border-gray-200 rounded-xl p-4">
      <h3 class="text-sm font-bold text-gray-700 mb-3">📋 変更サマリー</h3>
      <div class="space-y-2">
        <% if habit_actions.any? %>
          <div class="flex items-start gap-2">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full
                         bg-green-100 text-green-700 text-xs font-bold flex-shrink-0 mt-0.5"
                  aria-hidden="true">+</span>
            <div class="flex-1 min-w-0">
              <span class="text-xs font-semibold text-gray-700">
                習慣 <%= habit_actions.size %>件を追加提案:
              </span>
              <span class="text-xs text-gray-500 ml-1">
                <%= habit_actions.first(3).map { |a| a[:title].presence || "（タイトルなし）" }.join("、") %>
                <% if habit_actions.size > 3 %>他<%= habit_actions.size - 3 %>件<% end %>
              </span>
            </div>
          </div>
        <% end %>

        <% if task_actions.any? %>
          <div class="flex items-start gap-2">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full
                         bg-blue-100 text-blue-700 text-xs font-bold flex-shrink-0 mt-0.5"
                  aria-hidden="true">+</span>
            <div class="flex-1 min-w-0">
              <span class="text-xs font-semibold text-gray-700">
                タスク <%= task_actions.size %>件を追加提案:
              </span>
              <span class="text-xs text-gray-500 ml-1">
                <%= task_actions.first(3).map { |a| a[:title].presence || "（タイトルなし）" }.join("、") %>
                <% if task_actions.size > 3 %>他<%= task_actions.size - 3 %>件<% end %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════
      セクション 5: 提案一覧（フォーム）
  ══════════════════════════════════════════════════════════════════ %>
  <% if all_actions.any? %>
    <%#
      form_with:
        url: confirm_proposals_weekly_reflections_path → POST 先
        local: true → Turbo を経由しない通常のフォーム送信
                     モーダル確定後に redirect_to でシンプルにダッシュボードへ遷移する
        data-ai-proposal-modal-target="form":
          Stimulus から参照するための target 名（全選択等の将来拡張用）
    %>
    <%= form_with url: confirm_proposals_weekly_reflections_path,
                  method: :post,
                  local: true,
                  data: { "ai-proposal-modal-target": "form" } do |f| %>

      <%#
        ── reflection_id を hidden field で送信する（修正①）───────────────────
        【変更前の問題】
          Controller 側で find_latest_completed_reflection() を呼んで
          「直近の完了済み振り返り」を推測していたため、
          複数の完了済み振り返りがある場合や非同期処理のタイミングによって
          意図しない振り返りに提案が紐付く可能性があった。

        【変更後の設計】
          ビュー側で @latest_ai_analysis.weekly_reflection_id を
          hidden_field_tag で確実に送信する。
          Controller は params[:reflection_id] で直接 find するだけなので
          「どの振り返りか」が100%確定する。

        value: ai_analysis.weekly_reflection_id
          AiAnalysis が紐付く WeeklyReflection の ID を送る。
          Controller で current_user.weekly_reflections.find(params[:reflection_id]) とすることで
          他ユーザーの振り返り ID を送られても 404 で弾ける（認可チェックを兼ねる）。
      %>
      <%= hidden_field_tag :reflection_id, ai_analysis.weekly_reflection_id %>

      <%# ── 習慣の提案 ───────────────────────────────────────────────── %>
      <% if habit_actions.any? %>
        <div class="mt-4">
          <h3 class="text-sm font-bold text-gray-800 mb-3">
            📋 習慣の提案
            <span class="ml-1 text-xs font-normal text-gray-400">追加したい習慣を選んでください</span>
          </h3>
          <div class="space-y-2">
            <%#
              ── インデックスズレ修正（修正②）───────────────────────────────
              【変更前の問題】
                all_actions.each_with_index で全体の index を使っていた。
                例: actions_json = [habit0, task1, habit2] のとき
                    habit_actions = [habit0, habit2]
                    habit0 の index は 0（全体）だが habit_actions 内では 0（一致）
                    habit2 の index は 2（全体）だが habit_actions 内では 1（ズレ！）
                → Controller で habit_actions[2] を探すと nil になり保存漏れが起きる

              【変更後の設計】
                habit_actions.each_with_index で習慣だけの配列に対して index を振る。
                送信される habit_indices[] の値が habit_actions の index と一致する。
                Controller 側も habit_actions[idx] で確実に取得できる。
            %>
            <% habit_actions.each_with_index do |proposal, idx| %>
              <div class="border border-gray-200 rounded-xl overflow-hidden">
                <label class="flex items-start gap-3 p-3 hover:bg-gray-50 cursor-pointer transition-colors">
                  <%#
                    check_box_tag:
                      name="habit_indices[]": [] 付きで配列として送信される
                      value: idx → habit_actions 内での index 番号（全体 index ではない）
                      false: デフォルト未チェック
                      id: "modal_habit_#{idx}": label の for 属性との対応
                  %>
                  <%= check_box_tag "habit_indices[]",
                                    idx,
                                    false,
                                    id:    "modal_habit_#{idx}",
                                    class: "mt-0.5 h-4 w-4 rounded border-gray-300
                                            text-indigo-600 focus:ring-indigo-500 flex-shrink-0" %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <span class="text-xs font-bold px-2 py-0.5 rounded-full flex-shrink-0
                                   <%= case proposal[:priority].to_s.downcase
                                       when 'must'   then 'bg-red-100 text-red-700'
                                       when 'should' then 'bg-blue-100 text-blue-700'
                                       else               'bg-green-100 text-green-700'
                                       end %>">
                        <%= proposal[:priority].to_s.upcase.presence || "SHOULD" %>
                      </span>
                      <span class="text-sm font-semibold text-gray-800">
                        <%= proposal[:title].presence || "（タイトルなし）" %>
                      </span>
                    </div>
                    <% if proposal[:description].present? %>
                      <p class="text-xs text-gray-500 leading-relaxed"><%= proposal[:description] %></p>
                    <% end %>
                    <% if proposal[:frequency].present? %>
                      <p class="text-xs text-gray-400 mt-1">頻度: <%= proposal[:frequency] %></p>
                    <% end %>
                  </div>
                </label>
                <div class="px-3 pb-3 -mt-1">
                  <p class="text-xs text-gray-400">✏️ チェックして確定後、習慣一覧から詳細を編集できます</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ── タスクの提案 ───────────────────────────────────────────────── %>
      <% if task_actions.any? %>
        <div class="mt-4">
          <h3 class="text-sm font-bold text-gray-800 mb-3">
            ✅ タスクの提案
            <span class="ml-1 text-xs font-normal text-gray-400">追加したいタスクを選んでください</span>
          </h3>
          <div class="space-y-2">
            <%#
              task_actions.each_with_index でタスクだけの配列に対して index を振る。
              習慣と同様に、task_actions 内での index が task_indices[] の値になる。
            %>
            <% task_actions.each_with_index do |proposal, idx| %>
              <%#
                data-task-card 属性（修正③）:
                  変更前: button.closest('.border.border-gray-200.rounded-xl.overflow-hidden')
                          → Tailwind クラス名変更で壊れる脆い実装
                  変更後: data-task-card 属性で識別
                          → クラス変更に影響されない保守性の高い実装
              %>
              <div class="border border-gray-200 rounded-xl overflow-hidden"
                   data-task-card>
                <label class="flex items-start gap-3 p-3 hover:bg-gray-50 cursor-pointer transition-colors">
                  <%#
                    task_indices[]:
                      task_actions 内での index 番号を value にする。
                      全体 index ではないため、Controller の task_actions[idx] と必ず一致する。
                      id: "modal_task_#{idx}" で習慣の "modal_habit_#{idx}" と区別する。
                  %>
                  <%= check_box_tag "task_indices[]",
                                    idx,
                                    false,
                                    id:    "modal_task_#{idx}",
                                    class: "mt-0.5 h-4 w-4 rounded border-gray-300
                                            text-blue-600 focus:ring-blue-500 flex-shrink-0" %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <span class="text-xs font-bold px-2 py-0.5 rounded-full flex-shrink-0
                                   <%= case proposal[:priority].to_s.downcase
                                       when 'must'   then 'bg-red-100 text-red-700'
                                       when 'should' then 'bg-blue-100 text-blue-700'
                                       else               'bg-green-100 text-green-700'
                                       end %>">
                        <%= proposal[:priority].to_s.upcase.presence || "SHOULD" %>
                      </span>
                      <span class="text-sm font-semibold text-gray-800">
                        <%= proposal[:title].presence || "（タイトルなし）" %>
                      </span>
                    </div>
                    <% if proposal[:description].present? %>
                      <p class="text-xs text-gray-500 leading-relaxed"><%= proposal[:description] %></p>
                    <% end %>
                  </div>
                </label>

                <div class="px-3 pb-3 -mt-1 flex items-center gap-3">
                  <%#
                    「この提案を除外する」ボタン:
                      data-action="click->ai-proposal-modal#dismissTask":
                        Stimulus の dismissTask(event) を呼ぶ。
                      data-task-idx="= idx":
                        JS 側でチェックボックスを特定するために使う。
                        全体 index ではなく task_actions 内の index を渡す。
                  %>
                  <button type="button"
                          data-action="click->ai-proposal-modal#dismissTask"
                          data-task-idx="<%= idx %>"
                          class="text-xs text-red-500 hover:text-red-700 hover:underline
                                 transition-colors focus:outline-none focus:ring-1 focus:ring-red-400 rounded">
                    この提案を除外する
                  </button>
                  <span class="text-xs text-gray-400">✏️ 確定後、タスク一覧から詳細を編集できます</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ══════════════════════════════════════════════════════════════════
          セクション 6: アクションボタン
      ══════════════════════════════════════════════════════════════════ %>
      <div class="mt-6 space-y-3">
        <%#
          「来週の計画を確定」ボタン（E-3 完了条件）:
            フォームを送信する。
            confirm_proposals_weekly_reflections_path に POST して
            チェックされた提案を DB に保存 + ai_generated: true をタスクにセット。

          data-disable-with: クリック後に disabled にして二重送信を防ぐ。
            Turbo の data-turbo-submits-with と同じ効果を local: true フォームで実現する。
        %>
        <%= f.submit "✅ 来週の計画を確定する",
                     class: "w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-700
                             text-white font-bold text-sm rounded-xl transition-colors
                             cursor-pointer focus:outline-none focus:ring-2
                             focus:ring-offset-2 focus:ring-indigo-500
                             disabled:opacity-50 disabled:cursor-not-allowed",
                     data: { disable_with: "保存中..." } %>

        <%#
          「編集して再解析」ボタン:
            確認ダイアログ（reanalyzeConfirm）を開く。
            振り返り入力ページへ戻るかをユーザーに確認してから遷移する。
            data-action="click->ai-proposal-modal#openReanalyzeConfirm":
              Stimulus の openReanalyzeConfirm(event) を呼ぶ。
        %>
        <button type="button"
                data-action="click->ai-proposal-modal#openReanalyzeConfirm"
                class="w-full py-3 px-4 bg-white border border-gray-300 text-gray-700
                       font-semibold text-sm rounded-xl hover:bg-gray-50 transition-colors
                       focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400">
          🔄 編集して再解析する
        </button>
      </div>
    <% end %>

  <% else %>
    <div class="mt-4 bg-gray-50 border border-gray-200 rounded-xl p-6 text-center">
      <p class="text-sm text-gray-500 mb-3">
        現在表示できる提案がありません。<br>
        AI分析が完了するまでお待ちください。
      </p>
      <button type="button"
              data-action="click->ai-proposal-modal#close"
              class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-xl
                     hover:bg-gray-50 transition-colors">
        閉じる
      </button>
    </div>
  <% end %>

</div>