<%# app/views/weekly_reflections/_ai_proposal_modal.html.erb %>
<%#
  ==============================================================================
  14-A: AI提案プレビューモーダル ラッパー（E-3 修正版）
  ==============================================================================

  【E-3修正での変更内容】
    ① z-60 / z-70 → z-[60] / z-[70] に修正
       Tailwind デフォルトに z-60/z-70 は存在しないため、
       任意値（arbitrary values）記法 z-[60] を使う。

    ② _ai_proposal_modal_content に reflection を渡す
       hidden_field_tag で reflection_id を送信するために必要。

  【受け取るローカル変数】
    ai_analysis  : AiAnalysis インスタンス
    user_purpose : UserPurpose インスタンス or nil
    reflection   : WeeklyReflection インスタンス
  ==============================================================================
%>

<div data-controller="ai-proposal-modal"
     data-ai-proposal-modal-target="wrapper"
     id="ai-proposal-modal"
     hidden>

  <%#
    オーバーレイ（背景の暗幕）:
      fixed inset-0: 画面全体を覆う
      bg-black/50:   半透明の黒（Tailwind v3 の opacity shorthand 記法）
      z-40:          モーダル本体（z-[50]）より後ろに表示する
      data-action: 暗幕クリックでモーダルを閉じる
  %>
  <div class="fixed inset-0 bg-black/50 z-40"
       data-action="click->ai-proposal-modal#closeFromOverlay"
       aria-hidden="true">
  </div>

  <%#
    デスクトップ用モーダル（sm 以上で表示）:
      fixed inset-0 flex items-center justify-center: 画面中央に固定
      z-[50]: z-[50] で任意値指定（Tailwind 標準の z-50 でも可）
      hidden sm:flex: スマホでは非表示、sm（640px）以上で flex 表示
      px-4: モーダル両端に余白
  %>
  <div class="fixed inset-0 flex items-center justify-center z-[50] hidden sm:flex px-4"
       role="dialog"
       aria-modal="true"
       aria-labelledby="ai-proposal-modal-title">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90dvh] overflow-y-auto">
      <%= render "weekly_reflections/ai_proposal_modal_content",
            ai_analysis:  ai_analysis,
            user_purpose: user_purpose,
            reflection:   reflection %>
    </div>
  </div>

  <%#
    スマホ用ボトムシート（sm 未満で表示）:
      fixed bottom-0 left-0 right-0: 画面下部に固定
      sm:hidden: sm（640px）以上では非表示
      z-[50]: 任意値指定（オーバーレイ z-40 より前面）
      rounded-t-2xl: 上部の角を丸くする（ボトムシートらしい見た目）
      max-h-[85dvh]: 画面の 85% まで（dvh で iOS Safari のアドレスバーを考慮）
      overflow-y-auto: スクロール可能
  %>
  <div class="fixed bottom-0 left-0 right-0 bg-white rounded-t-2xl shadow-2xl z-[50]
              sm:hidden max-h-[85dvh] overflow-y-auto"
       role="dialog"
       aria-modal="true"
       aria-labelledby="ai-proposal-modal-title-mobile">
    <div class="flex justify-center pt-3 pb-1">
      <div class="w-10 h-1 bg-gray-300 rounded-full" aria-hidden="true"></div>
    </div>
    <%= render "weekly_reflections/ai_proposal_modal_content",
          ai_analysis:  ai_analysis,
          user_purpose: user_purpose,
          reflection:   reflection,
          mobile:       true %>
  </div>

  <%#
    「編集して再解析」確認ダイアログ（子モーダル）:
      data-ai-proposal-modal-target="reanalyzeConfirm":
        Stimulus から参照するための target 名。
        openReanalyzeConfirm(event) / closeReanalyzeConfirm(event) で hidden を切替する。

      z-[60]: モーダル本体（z-[50]）より前面に表示する
              Tailwind 任意値記法（z-60 は標準にない）。
      z-[70]: 確認ダイアログ本体をオーバーレイより前面に表示する。
  %>
  <div data-ai-proposal-modal-target="reanalyzeConfirm"
       id="reanalyze-confirm-modal"
       hidden>
    <div class="fixed inset-0 bg-black/60 z-[60]" aria-hidden="true"></div>
    <div class="fixed inset-0 flex items-center justify-center z-[70] px-4">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6">
        <h3 class="text-base font-bold text-gray-900 mb-2">🔄 振り返り入力に戻りますか？</h3>
        <p class="text-sm text-gray-600 mb-6 leading-relaxed">
          振り返り入力ページに戻ります。<br>
          現在表示しているAI提案は、再分析後に新しい提案に置き換わります。
        </p>
        <div class="flex gap-3">
          <button type="button"
                  data-action="click->ai-proposal-modal#closeReanalyzeConfirm"
                  class="flex-1 py-2.5 px-4 border border-gray-300 text-gray-700 text-sm
                         font-semibold rounded-xl hover:bg-gray-50 transition-colors
                         focus:outline-none focus:ring-2 focus:ring-gray-400">
            キャンセル
          </button>
          <%= link_to "振り返り入力に戻る",
                      new_weekly_reflection_path,
                      class: "flex-1 py-2.5 px-4 bg-orange-500 text-white text-sm
                              font-semibold rounded-xl hover:bg-orange-600 transition-colors
                              text-center focus:outline-none focus:ring-2 focus:ring-orange-400" %>
        </div>
      </div>
    </div>
  </div>

</div>