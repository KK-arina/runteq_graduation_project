<%# app/views/task_mailer/alarm_notification.html.erb %>
<%#
  タスクアラーム通知メールの HTML ビュー

  【このファイルの役割】
    TaskMailer#alarm_notification から呼び出される HTML メール本文。
    app/views/layouts/mailer.html.erb の yield 部分に挿入される。

  【使用できるインスタンス変数（task_mailer.rb でセット済み）】
    @task             : Task インスタンス
    @user             : User インスタンス（@task.user）
    @scheduled_at_local : ユーザーのタイムゾーンに変換した実施予定日時
%>
<div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; padding: 24px; color: #1e293b;">

  <%# ヘッダーロゴエリア %>
  <div style="background: #2563eb; padding: 16px 24px; border-radius: 8px 8px 0 0;">
    <h1 style="color: #ffffff; margin: 0; font-size: 20px;">HabitFlow</h1>
  </div>

  <%# 本文エリア %>
  <div style="background: #ffffff; border: 1px solid #e2e8f0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;">

    <%# 挨拶文 %>
    <p style="margin: 0 0 16px;">
      <%= @user.name %> さん、こんにちは。
    </p>

    <%# アラーム通知メッセージ %>
    <p style="margin: 0 0 20px;">
      以下のタスクの予定時刻が近づいています。
    </p>

    <%# タスク情報カード %>
    <div style="background: #eff6ff; border-left: 4px solid #2563eb; padding: 16px; border-radius: 4px; margin-bottom: 24px;">
      <p style="margin: 0 0 8px; font-size: 18px; font-weight: bold; color: #1e293b;">
        <%= @task.title %>
      </p>
      <p style="margin: 0 0 4px; color: #475569; font-size: 14px;">
        <%# 実施予定日時をユーザーのタイムゾーンで表示 %>
        📅 実施予定: <%= l @scheduled_at_local, format: :long %>
      </p>
      <%# 期限日が設定されている場合のみ表示 %>
      <% if @task.due_date.present? %>
        <p style="margin: 4px 0 0; color: #475569; font-size: 14px;">
          🗓 期限日: <%= l @task.due_date, format: :long %>
        </p>
      <% end %>
    </div>

    <%# タスク管理ページへのリンク %>
    <%#
      url_for を使う理由:
        メイラー内では link_to の href に使うパスヘルパーは
        ホスト名を含む絶対 URL を生成する必要がある。
        production.rb の default_url_options でホスト名を設定しているため
        tasks_url で "https://habitflow.onrender.com/tasks" が生成される。
    %>
    <div style="text-align: center; margin-bottom: 24px;">
      <%= link_to "タスクを確認する",
            tasks_url,
            style: "background: #2563eb; color: #ffffff; padding: 12px 28px; border-radius: 6px; text-decoration: none; font-weight: bold; font-size: 15px;" %>
    </div>

    <%# フッターメッセージ %>
    <p style="margin: 0; color: #94a3b8; font-size: 12px; text-align: center;">
      このメールは HabitFlow から自動送信されています。<br>
      通知の設定変更は HabitFlow の設定ページから行えます。
    </p>
  </div>
</div>