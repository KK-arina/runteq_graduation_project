<%#
  ==============================================================================
  _habit_record_error.html.erb（エラー表示パーシャル）
  ==============================================================================
  【役割】
    HabitRecord の保存・更新に失敗した場合に表示するエラー UI。
    Turbo Stream で _habit_record.html.erb の代わりにこのパーシャルが
    DOM に差し込まれる。

  【受け取るローカル変数】
    - habit         : Habit インスタンス
    - error_message : エラーメッセージ文字列
  ==============================================================================
%>

<%# Turbo Stream のターゲット: _habit_record パーシャルと同じ id %>
<div id="habit_record_<%= habit.id %>"
     class="flex items-center gap-3 py-3 border-b border-gray-100 last:border-b-0">

  <%# エラーアイコン %>
  <div class="w-5 h-5 flex-shrink-0 text-red-500">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
         aria-hidden="true">
      <path fill-rule="evenodd"
            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
            clip-rule="evenodd" />
    </svg>
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium text-gray-900 truncate">
      <%= habit.name %>
    </p>
    <p class="text-xs text-red-600 mt-0.5">
      <%# h() で XSS（クロスサイトスクリプティング）対策のためエスケープ %>
      <%= h(error_message) %> — ページをリロードしてください
    </p>
  </div>
</div>