<%# app/views/habit_records/_habit_record_error.html.erb %>
<%# =============================================================
    習慣記録の保存に失敗した際にTurbo Streamで返すエラー表示パーシャル
    habit変数が必要（呼び出し元から渡される）
    ============================================================= %>

<div id="habit_record_<%= habit.id %>"
     class="flex items-center gap-3 py-3">
  <%# エラーメッセージを赤色で表示 %>
  <span class="text-xs text-red-500">⚠ 保存に失敗しました。再度お試しください。</span>
</div>