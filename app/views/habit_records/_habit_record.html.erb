<%# パーシャル: app/views/habit_records/_habit_record.html.erb %>
<%# 受け取る変数: habit（Habitインスタンス）、habit_record（HabitRecordまたはnil） %>
<%# このdivのid="habit_record_<habit.id>"がTurbo Streamの置換ターゲット %>
<%# data-controller="habit-record"でhabit_record_controller.jsを紐づける %>

<%
  # habit_recordがnilの場合（今日まだ記録がない）はダミーオブジェクトで代替する
  # HabitRecord.new(completed: false)はDBに保存されていないオブジェクトなので
  # persisted?がfalseになり、update_urlとrecord_idが未作成扱いになる
  record = habit_record || HabitRecord.new(completed: false)

  # POST URL: 新規作成（今日初めてチェックする場合）
  # habit_habit_records_path(habit) → POST /habits/:habit_id/habit_records
  create_url = habit_habit_records_path(habit)

  # PATCH URL: 更新（今日すでにレコードがある場合）
  # persisted?がtrueなら既存レコードのURLを作成、falseなら空文字（JSでcreate_urlを使う）
  update_url = record.persisted? ? habit_habit_record_path(habit, record) : ""

  # record_id: StimulusのJS側でcreate/updateどちらを使うか判断する値
  # persisted?がtrueなら実際のid、falseなら0（新規作成の目印）
  record_id = record.persisted? ? record.id : 0
%>

<div id="habit_record_<%= habit.id %>"
     class="flex items-center gap-3 py-3 border-b border-gray-100 last:border-b-0"
     data-controller="habit-record"
     data-habit-record-create-url-value="<%= create_url %>"
     data-habit-record-update-url-value="<%= update_url %>"
     data-habit-record-record-id-value="<%= record_id %>">

  <%# チェックボックス + ローディングアイコンのラッパー %>
  <div class="relative flex items-center">
    <%# チェックボックス %>
    <%# data-habit-record-target="checkbox": Stimulusからdisabled/enabledを制御するため %>
    <%# data-action="change->habit-record#toggle": チェック変化時にtoggle()メソッドを呼ぶ %>
    <%# checked属性: record.completedがtrueなら"checked"を出力してチェック済み状態にする %>
    <input
      type="checkbox"
      data-habit-record-target="checkbox"
      data-action="change->habit-record#toggle"
      <%= record.completed ? "checked" : "" %>
      class="w-5 h-5 rounded cursor-pointer <%= record.completed ? 'accent-green-500' : 'accent-blue-500' %> disabled:opacity-50 disabled:cursor-not-allowed"
      aria-label="<%= habit.name %>の記録をチェック">

    <%# ローディングアイコン（保存中のみ表示） %>
    <%# hidden属性: 初期状態は非表示。StimulusのsetLoadingState(true)で表示される %>
    <%# animate-spin: Tailwindの回転アニメーション（くるくる回るスピナー） %>
    <span data-habit-record-target="loading" hidden
          class="absolute inset-0 flex items-center justify-center">
      <svg class="animate-spin w-4 h-4 text-blue-500"
           xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </span>
  </div>

  <%# 習慣名 + 週次目標 %>
  <div class="flex-1 min-w-0">
    <%# 習慣名: 完了時はline-through（取り消し線）+グレー、未完了時は通常の黒 %>
    <p class="text-sm font-medium truncate <%= record.completed ? 'line-through text-gray-400' : 'text-gray-900' %>">
      <%= habit.name %>
    </p>
    <p class="text-xs text-gray-500 mt-0.5">週<%= habit.weekly_target %>回目標</p>
  </div>

  <%# 完了バッジ: completedがtrueの時だけ表示する %>
  <% if record.completed %>
    <span class="flex-shrink-0 inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-100 px-2 py-0.5 rounded-full">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd" />
      </svg>
      完了
    </span>
  <% end %>
</div>