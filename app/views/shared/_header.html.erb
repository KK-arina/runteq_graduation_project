<%# app/views/shared/_header.html.erb %>
<%# =============================================================
    全ページ共通で表示されるヘッダー
    logged_in? ヘルパーでログイン状態に応じてナビゲーションを切り替える
    ============================================================= %>

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-14">

      <%# ========== ロゴ ========== %>
      <%# logged_in? によってリンク先を切り替える
          ログイン済み → ダッシュボード
          未ログイン  → ランディングページ %>
      <div class="flex items-center">
        <%= link_to logged_in? ? dashboard_path : root_path,
            class: "text-xl font-bold text-blue-600 tracking-tight hover:text-blue-700 transition-colors" do %>
          HabitFlow
        <% end %>
      </div>

      <%# ========== ナビゲーション ========== %>
      <nav class="flex items-center gap-2">
        <% if logged_in? %>
          <%# ---- ログイン済みユーザー向けナビ ---- %>

          <%# ダッシュボードへのリンク
              current_page? : 現在のページかどうかを判定するRailsヘルパー
              現在のページなら青色、そうでなければグレー %>
          <%= link_to "ダッシュボード", dashboard_path,
              class: "text-sm font-medium px-3 py-2 rounded-md transition-colors #{
                current_page?(dashboard_path) ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
              }" %>

          <%# 習慣一覧へのリンク %>
          <%= link_to "習慣管理", habits_path,
              class: "text-sm font-medium px-3 py-2 rounded-md transition-colors #{
                current_page?(habits_path) ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
              }" %>

          <%# ユーザー名の表示 %>
          <span class="text-sm text-gray-500 px-2">
            <%= current_user.name %> さん
          </span>

          <%# ログアウトボタン
              method: :delete → DELETEリクエストを送信（Turbo対応）
              data-turbo-confirm → 確認ダイアログを表示 %>
          <%= button_to "ログアウト", logout_path,
              method: :delete,
              class: "text-sm font-medium px-3 py-2 rounded-md text-gray-600 border border-gray-300 hover:bg-gray-50 transition-colors",
              data: { turbo_confirm: "ログアウトしますか？" } %>

        <% else %>
          <%# ---- 未ログインユーザー向けナビ ---- %>
          <%= link_to "ログイン", login_path,
              class: "text-sm font-medium px-3 py-2 rounded-md text-gray-600 hover:text-gray-900 transition-colors" %>
          <%= link_to "新規登録", new_user_path,
              class: "text-sm font-medium px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors" %>
        <% end %>
      </nav>

    </div>
  </div>
</header>