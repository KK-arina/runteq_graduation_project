<%# app/views/shared/_google_auth_button.html.erb %>
<%#
  ==============================================================================
  F-1: Google 認証ボタン 共通部分テンプレート
  ==============================================================================

  【無限ループの原因と修正について】
    button_to に do...end ブロックを渡すと、Rails がブロック内のコンテンツを
    レンダリングするため layout を再度呼び出し、無限ループが発生する。
    ブロックを使わず、form_tag + button タグで同じ POST ボタンを安全に実装する。

  【呼び出し方】
    render "shared/google_auth_button", button_text: "Google アカウントでログイン"
    render "shared/google_auth_button", button_text: "Google アカウントで登録"

  【locals】
    button_text: ボタンに表示するテキスト（呼び出し元から渡す）
  ==============================================================================
%>
<% if ENV["GOOGLE_CLIENT_ID"].present? %>
  <%#
    form_tag を使う理由:
      OmniAuth 2.x は認証開始に POST リクエストが必須。
      form_tag は内部で form タグと authenticity_token を生成する。

    data: { turbo: "false" } を文字列で指定する理由:
      Rails 7 の Turbo は外部リダイレクトを Fetch に変換してブロックするため、
      "false" を文字列で渡して data-turbo="false" を確実に出力する。
  %>
  <%= form_tag "/auth/google_oauth2",
               method: :post,
               data: { turbo: "false" } do %>
    <button type="submit"
            class="w-full flex items-center justify-center gap-3
                   px-4 py-2 bg-white border border-gray-300 rounded-md
                   hover:bg-gray-50 transition font-medium text-gray-700
                   shadow-sm">
      <%# Google 公式ブランドカラー準拠 SVG。aria-hidden でスクリーンリーダーから除外 %>
      <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <%= button_text %>
    </button>
  <% end %>
<% end %>
