<%# app/views/shared/_line_auth_button.html.erb %>
<%#
  ==============================================================================
  F-2: LINE 認証ボタン 共通部分テンプレート
  ==============================================================================

  【このパーシャルの役割】
    ログインページ・新規登録ページで共通して使う「LINEでログイン/登録」ボタン。
    Google ボタン（_google_auth_button.html.erb）と同じ設計パターンに従う。

  【無限ループの原因と修正について】
    button_to に do...end ブロックを渡すと、Rails がブロック内のコンテンツを
    レンダリングするため layout を再度呼び出し、無限ループが発生する。
    ブロックを使わず、form_tag + button タグで同じ POST ボタンを安全に実装する。

  【呼び出し方】
    render "shared/line_auth_button", button_text: "LINEでログイン"
    render "shared/line_auth_button", button_text: "LINEで登録"

  【locals】
    button_text: ボタンに表示するテキスト（呼び出し元から渡す）

  【ボタンの色について（LINE ブランドガイドライン準拠）】
    LINE 公式のブランドカラーは #06C755（緑）。
    タスク要件「#06C755 緑」に準拠している。
    参考: https://developers.line.biz/en/docs/line-login/login-button/

  【ENV["LINE_CHANNEL_ID"].present? で囲む理由】
    環境変数が未設定の場合はボタンを非表示にすることで、
    LINE_CHANNEL_ID を設定していない開発環境でもエラーを防ぐ。
    Google ボタンの ENV["GOOGLE_CLIENT_ID"] チェックと同じ設計方針。
  ==============================================================================
%>
<% if ENV["LINE_CHANNEL_ID"].present? %>
  <%#
    "/auth/line_v21" について:
      omniauth-line-v2_1 gem は :line_v21 というストラテジー名を持つ。
      OmniAuth は POST /auth/line_v21 を認証開始エンドポイントとして登録する。
      NG: "/auth/line"     → OmniAuth::Strategies::Line がないため 404 になる
      OK: "/auth/line_v21" → OmniAuth::Strategies::LineV21 が正しく処理する
  %>
  <%= form_tag "/auth/line_v2_1",
               method: :post,
               data: { turbo: "false" } do %>
    <%#
      button タグの style について:
        LINE ブランドガイドライン準拠の緑色（#06C755）を使用する。
        Tailwind CSS のカスタムカラーは設定なしでは使えないため、
        inline style で直接 #06C755 を指定する。
        hover 時は少し暗い緑（#05b04c）に変化させて操作フィードバックを与える。
        これは CSS の filter: brightness(0.92) で実現する。

      type="submit" について:
        form_tag ブロック内の button は type="submit" を明示する。
        省略すると一部ブラウザで type="button" とみなされ、フォームが送信されない。

      aria-label について:
        スクリーンリーダー向けに「LINE でログイン」と読み上げるための属性。
        SVG アイコンが aria-hidden なので、ボタン自体にラベルが必要。
    %>
    <button type="submit"
            style="background-color: #06C755;"
            onmouseover="this.style.filter='brightness(0.92)'"
            onmouseout="this.style.filter=''"
            class="w-full flex items-center justify-center gap-3
                   px-4 py-2 rounded-md
                   transition font-medium text-white
                   shadow-sm"
            aria-label="<%= button_text %>">
      <%#
        LINE 公式ロゴ SVG について:
          LINE ブランドガイドラインに従い、白地に緑の「L」字スピーチバブルロゴを使用。
          aria-hidden="true" でスクリーンリーダーからは除外する（ボタンにaria-labelあり）。
          viewBox="0 0 24 24" は 24x24 ピクセルの座標系を指定する SVG 属性。
          w-5 h-5 で 20x20px に表示する（Tailwind CSS クラス）。
          flex-shrink-0 でテキストが長くてもアイコンが縮まないようにする。
      %>
      <svg class="w-5 h-5 flex-shrink-0"
           viewBox="0 0 24 24"
           fill="white"
           aria-hidden="true"
           xmlns="http://www.w3.org/2000/svg">
        <%#
          LINE のスピーチバブルアイコン（公式ブランド準拠の白抜きパス）。
          LINE アプリのシンボルマーク「L」字が入った吹き出し形状。
        %>
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
      <%= button_text %>
    </button>
  <% end %>
<% end %>