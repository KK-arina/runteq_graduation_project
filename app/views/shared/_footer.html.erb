<%# app/views/shared/_footer.html.erb %>
<%# F-3: フッターに利用規約・プライバシーポリシーリンクを追加 %>

<footer class="mt-auto bg-gray-50 border-t border-gray-200 py-6 pb-20 md:pb-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <%# コピーライト %>
      <p class="text-sm text-gray-500">
        &copy; <%= Time.current.year %> HabitFlow. All rights reserved.
      </p>

      <%# 規約リンク %>
      <%#
        F-3 追加: 利用規約・プライバシーポリシーへのリンク。
        未ログインユーザーも閲覧できる静的ページ（PagesController#terms / #privacy）へ
        リンクする。フッターに常時表示することで法的透明性を確保する。
      %>
      <nav aria-label="フッターナビゲーション">
        <ul class="flex items-center gap-4 text-sm text-gray-500">
          <li>
            <%= link_to "利用規約", terms_path,
                class: "hover:text-gray-700 hover:underline transition-colors" %>
          </li>
          <li>
            <span aria-hidden="true">|</span>
          </li>
          <li>
            <%= link_to "プライバシーポリシー", privacy_path,
                class: "hover:text-gray-700 hover:underline transition-colors" %>
          </li>
        </ul>
      </nav>

    </div>
  </div>
</footer>