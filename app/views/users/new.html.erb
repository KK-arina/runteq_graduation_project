<%# app/views/users/new.html.erb %>
<%# F-3: 利用規約・プライバシーポリシー同意チェックボックスを追加 %>
<% content_for :title, "新規登録 | HabitFlow" %>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <h2 class="text-2xl font-bold mb-6 text-gray-900 text-center">
    新規登録
  </h2>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <%# ============================================================ %>
    <%# F-1 追加: Google 登録ボタン %>
    <%# F-2 追加: LINE 登録ボタン %>
    <%# ============================================================ %>
    <%= render "shared/google_auth_button", button_text: "Google アカウントで登録" %>

    <div class="mt-3">
      <%= render "shared/line_auth_button", button_text: "LINEで登録" %>
    </div>

    <% if ENV["GOOGLE_CLIENT_ID"].present? || ENV["LINE_CHANNEL_ID"].present? %>
      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">またはメールで登録</span>
        </div>
      </div>
    <% end %>

    <%#
      data-controller="terms-agreement form-submit":
        複数の Stimulus コントローラーをスペース区切りで指定できる。
        terms-agreement → チェックボックスとボタンの活性/非活性を制御する
        form-submit     → 送信中にボタンテキストを「登録中...」に変えるローディング制御
    %>
    <%= form_with model: @user,
                  local: true,
                  data: {
                    controller: "terms-agreement form-submit",
                    action: "submit->form-submit#submit"
                  } do |f| %>

      <%= render "shared/form_errors", model: @user %>

      <div class="mb-4">
        <%= f.label :name, "ユーザー名",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name,
            placeholder: "山田太郎",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :email, "メールアドレス",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email,
            placeholder: "email@example.com",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password,
            placeholder: "8文字以上",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, "パスワード（確認）",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password_confirmation,
            placeholder: "パスワードを再入力",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%# ============================================================ %>
      <%# F-3 追加: 利用規約・プライバシーポリシー同意チェックボックス %>
      <%# ============================================================ %>
      <div class="mb-6 p-4 bg-gray-50 rounded-md border border-gray-200">
        <label class="flex items-start gap-3 cursor-pointer">
          <%#
            f.check_box :terms_agreed について:
              Rails の check_box フォームヘルパー。
              チェックあり → params[:user][:terms_agreed] = "1"
              チェックなし → params[:user][:terms_agreed] = "0"
              "0" は falsy として :acceptance バリデーションに失敗する。

            data-terms-agreement-target="checkbox":
              Stimulus の TermsAgreementController が
              this.checkboxTarget としてこの要素を参照するための指定。

            data-action="change->terms-agreement#toggle":
              チェックボックスの値が変わったとき（change イベント）に
              TermsAgreementController の toggle() メソッドを呼び出す指定。
          %>
          <%= f.check_box :terms_agreed,
              class: "mt-0.5 w-4 h-4 text-blue-600 border-gray-300 rounded
                      focus:ring-2 focus:ring-blue-500 flex-shrink-0",
              data: {
                "terms-agreement-target": "checkbox",
                action: "change->terms-agreement#toggle"
              } %>
          <span class="text-sm text-gray-700 leading-relaxed">
            <%= link_to "利用規約", terms_path,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "text-blue-600 hover:text-blue-700 hover:underline font-medium" %>
            および
            <%= link_to "プライバシーポリシー", privacy_path,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "text-blue-600 hover:text-blue-700 hover:underline font-medium" %>
            に同意します
            <span class="text-red-500 ml-1" aria-label="必須">*</span>
          </span>
        </label>
      </div>

      <%#
        送信ボタン（初期状態は非活性）

        disabled: true:
          初期表示時にボタンを非活性にする（チェックなし状態なのでクリック不可にする）。
          JavaScript が無効な環境でもサーバー側バリデーション（:acceptance）で弾くため安全。

        data-terms-agreement-target="button":
          Stimulus コントローラーがこのボタンを参照して disabled / クラスを切り替える。

        data-form-submit-target="button":
          form-submit コントローラーが「送信中...」表示の切り替えに使う。
      %>
      <%= f.submit "登録する",
          disabled: true,
          class: "w-full px-4 py-2 text-white rounded-md
                  transition font-medium bg-gray-400 cursor-not-allowed",
          data: {
            "terms-agreement-target": "button",
            "form-submit-target": "button",
            "loading-text": "登録中..."
          } %>
    <% end %>

  </div>

  <div class="mt-4 text-center text-sm text-gray-600">
    すでにアカウントをお持ちの方は
    <%= link_to "ログイン", login_path,
        class: "text-blue-600 hover:text-blue-700 hover:underline" %>
  </div>

</div>