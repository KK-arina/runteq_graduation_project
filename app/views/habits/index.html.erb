<%# app/views/habits/index.html.erb %>
<%# ==============================================================================
    習慣一覧ページ（B-6: カラー・アイコン・Drag & Drop 並び替え追加）
    ==============================================================================
    【B-6 での変更内容】
      ① グリッドコンテナに data-controller="habit-sort" を追加
         Drag & Drop 並び替えを Stimulus で管理する。
      ② 各カードに data-habit-id と data-sort-handle を追加
         habit-sort コントローラーが習慣 ID を取得し、
         sort-handle でドラッグハンドルを識別する。
      ③ カードの左ボーダーに habit.color を反映する
         style="border-left: 4px solid <%= habit.color"
      ④ カードヘッダーにアイコン（habit.icon）を表示する
    ==============================================================================
%>
<% content_for :title, "習慣管理 | HabitFlow" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# PDCA強制ロック警告バナー（変更なし） %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">⚠️ ロック中：新規追加・削除はできません</p>
          <p class="text-xs text-orange-700 mt-1">先週の振り返りを完了すると解除されます。</p>
          <%= link_to "振り返りページへ →", new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ページヘッダー（変更なし） %>
  <div class="flex flex-wrap justify-between items-center mb-6 gap-3">
    <h1 class="text-2xl font-bold text-gray-900">習慣管理</h1>
    <div class="flex items-center gap-2 flex-wrap">
      <%= link_to archived_habits_path,
            class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium
                    bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors" do %>
        <span>📦</span>
        <span>アーカイブ済みを見る</span>
      <% end %>

      <% if @locked %>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-200 text-gray-400 cursor-not-allowed">
          🔒 + 新しい習慣を追加
        </span>
      <% else %>
        <%= link_to new_habit_path,
              class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
          + 新しい習慣を追加
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @habits.empty? %>
    <div class="text-center py-16 border-2 border-dashed border-gray-300 rounded-xl">
      <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
        <span class="text-3xl">📋</span>
      </div>
      <p class="text-gray-500 mb-4">まだ習慣が登録されていません</p>
      <% unless @locked %>
        <%= link_to "習慣を登録する", new_habit_path,
              class: "px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
      <% end %>
    </div>

  <% else %>
    <%#
      ============================================================
      グリッドコンテナ（B-6 変更: Drag & Drop 用の data 属性を追加）
      ============================================================

      data-controller="habit-sort":
        habit_sort_controller.js をこの div に紐付ける。
        SortableJS の初期化はこの div の直接の子要素（カード）に適用される。

      data-habit-sort-sort-url-value="<%= sort_habits_path":
        habit_sort_controller が fetch で送信する URL。
        sort_habits_path → PATCH /habits/sort
        ハードコードせず Rails のパスヘルパーを使うことで、
        ルーティングが変わっても自動で対応できる。

      【なぜ id="habits-grid" を付けるのか】
        SortableJS のデバッグや他の JS から参照しやすくするため（任意）。
    %>
    <%#
      ==============================================================================
      B-6 レビュー修正内容（index.html.erb）
      ==============================================================================
      ① グリッドコンテナに data-habit-sort-locked-value を追加
        habit_sort_controller.js がロック状態を受け取れるようにする。

      ② カラースウォッチに hover:scale-110 を HTML 側に記述する
        ※ スウォッチは new.html.erb / edit.html.erb にあるため
            ここでは対応不要。記述はフォームファイル側で行う。
      ==============================================================================
    %>

    <%# ── グリッドコンテナ（修正: locked-value を追加） ─────────── %>
    <%#
      data-habit-sort-locked-value="<%= @locked":
        habit_sort_controller の this.lockedValue として参照される。
        @locked が true のとき Stimulus が SortableJS を初期化しない。
        Stimulus の Boolean Value は "true"/"false" 文字列を自動変換する。
    %>
    <div id="habits-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        data-controller="habit-sort"
        data-habit-sort-sort-url-value="<%= sort_habits_path %>"
        data-habit-sort-locked-value="<%= @locked %>">

      <% @habits.each do |habit| %>
        <% stats = @habit_stats[habit.id] || {
             rate:            0,
             completed_count: 0,
             numeric_sum:     nil,
             effective_target: habit.check_type? ? habit.effective_weekly_target : habit.weekly_target
           } %>

        <%#
          ============================================================
          習慣カード（B-6 変更点）
          ============================================================

          data-habit-id="<%= habit.id":
            habit_sort_controller の updateOrder() が
            querySelectorAll("[data-habit-id]") でこの要素を取得し、
            dataset.habitId で習慣 ID を読み取る。
            ドラッグ後の並び順をサーバーに送信するために必要。

          style="border-left: 4px solid <%= habit.color.presence || '#3b82f6'":
            カードの左ボーダーにユーザーが選択した色を適用する。
            Tailwind の静的クラスでは動的なカラーコードを扱えないため
            インラインスタイルを使う。
            habit.color が nil（未設定）の場合はデフォルトの青（#3b82f6）を使う。

          【なぜ Tailwind のクラスで color が使えないのか】
            Tailwind は使用するクラスをビルド時に静的解析して CSS を生成する。
            "border-l-[= habit.color]" のような動的な値は
            Tailwind のパージ対象として認識されず、CSS が生成されない。
            そのため動的な色はインラインスタイルで直接指定する必要がある。
        %>
        <div id="habit_record_<%= habit.id %>"
             data-habit-id="<%= habit.id %>"
             class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow flex flex-col"
             style="border-left: 4px solid <%= habit.color.presence || '#3b82f6' %>">

          <%# カードヘッダー %>
          <div class="flex justify-between items-start p-4 pb-2">
            <div class="flex-1 min-w-0 mr-2">
              <h3 class="text-base font-bold text-gray-800 leading-snug flex items-center gap-2 flex-wrap">

                <%#
                  ── B-6 追加: アイコン表示 ──────────────────────────────────
                  habit.icon.presence || "📋":
                    habit.icon が設定されていればその絵文字を表示する。
                    未設定（nil または空文字）の場合はデフォルトの 📋 を使う。
                  aria-hidden="true":
                    スクリーンリーダーにアイコン（装飾用絵文字）を読み上げさせない。
                    習慣名が後に続くので、アイコンは装飾として扱う。
                %>
                <span aria-hidden="true"><%= habit.icon.presence || "📋" %></span>

                <%= habit.name %>
                <% if habit.numeric_type? %>
                  <span class="text-xs font-normal text-blue-500 bg-blue-50 px-1.5 py-0.5 rounded">
                    数値型
                  </span>
                <% end %>
              </h3>

              <%# ストリークバッジ（変更なし） %>
              <% if habit.current_streak > 0 %>
                <div class="mt-1 flex items-center gap-2 flex-wrap">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold
                               <%= habit.current_streak >= 7 ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700' %>">
                    🔥 <%= habit.current_streak %>日 継続中
                  </span>
                  <% if habit.longest_streak > habit.current_streak %>
                    <span class="text-xs text-gray-400">最高: <%= habit.longest_streak %>日</span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="flex items-center gap-1 flex-shrink-0">

              <%#
                ── B-6 追加: ドラッグハンドル ──────────────────────────────────
                data-sort-handle:
                  habit_sort_controller.js の SortableJS 設定で
                  handle: "[data-sort-handle]" と指定したため、
                  この属性を持つ要素のみがドラッグを開始できる「持ち手」になる。

                cursor-grab / active:cursor-grabbing:
                  マウスカーソルを「手のひら（グラブ）」の形にして
                  「ここを掴んでドラッグできる」とユーザーに視覚的に伝える。
                  active: は要素をクリックしている間だけ適用される Tailwind クラス。

                aria-label="ドラッグして並び替え":
                  スクリーンリーダー用。このボタンの役割を読み上げる。

                title="ドラッグして並び替え":
                  マウスホバー時にツールチップを表示する。
              %>
              <% unless @locked %>
                <button type="button"
                        data-sort-handle
                        class="p-1.5 rounded text-gray-300 hover:text-gray-500
                               cursor-grab active:cursor-grabbing
                               focus:outline-none focus:ring-2 focus:ring-blue-500"
                        aria-label="ドラッグして並び替え"
                        title="ドラッグして並び替え">
                  <%# 6つの点（⠿）でドラッグハンドルを表現する SVG アイコン %>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <circle cx="7"  cy="5"  r="1.5"/>
                    <circle cx="13" cy="5"  r="1.5"/>
                    <circle cx="7"  cy="10" r="1.5"/>
                    <circle cx="13" cy="10" r="1.5"/>
                    <circle cx="7"  cy="15" r="1.5"/>
                    <circle cx="13" cy="15" r="1.5"/>
                  </svg>
                </button>
              <% end %>

              <%# 編集ボタン（変更なし） %>
              <%= link_to "編集", edit_habit_path(habit),
                    class: "text-xs px-2 py-1 rounded bg-blue-50 text-blue-600
                            hover:bg-blue-100 transition-colors
                            focus:outline-none focus:ring-2 focus:ring-blue-500" %>

              <%# ⋯ メニュー（変更なし） %>
              <%= render "habits/habit_card_actions",
                    habit: habit,
                    locked: @locked %>
            </div>
          </div>

          <%# 週次目標と除外日の表示（変更なし） %>
          <div class="px-4 pb-2">
            <% if habit.check_type? %>
              <span class="text-xs text-gray-400">週次目標: <%= habit.effective_weekly_target %>回</span>
            <% else %>
              <span class="text-xs text-gray-400">週次目標: <%= habit.weekly_target %><%= habit.unit.presence || "回" %>/週</span>
            <% end %>
            <% excluded_numbers = habit.excluded_day_numbers %>
            <% if excluded_numbers.any? %>
              <span class="ml-2 text-xs text-orange-500">
                除外: <%= excluded_numbers.map { |n| HabitExcludedDay::DAY_NAMES[n] }.join("・") %>
              </span>
            <% end %>
          </div>

          <%# 今日のチェックボックス or 数値入力（変更なし） %>
          <div class="px-4 pb-3">
            <%= render "habit_records/habit_record",
                  habit: habit,
                  habit_record: @today_records_hash[habit.id] %>
          </div>

          <%# 今週の進捗バー（変更なし） %>
          <div class="px-4 pb-4 mt-auto">
            <div class="flex justify-between items-center mb-1">
              <span class="text-xs text-gray-500">今週の進捗</span>
              <% if habit.check_type? %>
                <span class="text-xs font-bold whitespace-nowrap
                             <%= stats[:rate] >= 80 ? 'text-green-600' : stats[:rate] >= 50 ? 'text-blue-600' : 'text-red-500' %>">
                  <%= stats[:completed_count] %>/<%= stats[:effective_target] %>日（<%= stats[:rate] %>%）
                </span>
              <% else %>
                <% numeric_sum_display = stats[:numeric_sum].nil? ? 0.0 : stats[:numeric_sum] %>
                <span class="text-xs font-bold whitespace-nowrap
                             <%= stats[:rate] >= 80 ? 'text-green-600' : stats[:rate] >= 50 ? 'text-blue-600' : 'text-red-500' %>">
                  <%= format("%g", numeric_sum_display.round(1)) %>/<%= habit.weekly_target %><%= habit.unit.presence || "回" %>（<%= stats[:rate] %>%）
                </span>
              <% end %>
            </div>
            <div class="h-2 bg-gray-200 rounded-full overflow-hidden"
                 role="progressbar"
                 aria-valuenow="<%= stats[:rate] %>"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-label="<%= habit.name %> の今週の達成率">
              <div class="h-2 rounded-full transition-all duration-300
                          <%= stats[:rate] >= 80 ? 'bg-green-500' : stats[:rate] >= 50 ? 'bg-blue-400' : 'bg-red-400' %>"
                   style="width: <%= stats[:rate] %>%">
              </div>
            </div>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>