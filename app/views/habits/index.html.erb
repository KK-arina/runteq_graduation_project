<%# app/views/habits/index.html.erb %>
<%#
  ==============================================================================
  習慣一覧ページ（B-5: ⋯メニュー + 削除確認モーダル追加）
  ==============================================================================
  【B-5 での変更内容】
    ① 各習慣カードの右上にある「編集/📦卒業/削除」ボタン群を廃止する。
    ② 代わりに「⋯」（三点リーダー）メニューボタンを設置する。
    ③ 「⋯」クリックでM-1モーダル（アーカイブ or 完全削除の2択）を表示する。
    ④ モーダルは _habit_card_actions パーシャルとして切り出す。
    ⑤ 「編集」ボタンは削除確認とは別操作のため残す（/habits/:id/edit への遷移）。
  ==============================================================================
%>
<% content_for :title, "習慣管理 | HabitFlow" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# PDCA強制ロック警告バナー（変更なし） %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">⚠️ ロック中：新規追加・削除はできません</p>
          <p class="text-xs text-orange-700 mt-1">先週の振り返りを完了すると解除されます。</p>
          <%= link_to "振り返りページへ →", new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ページヘッダー（変更なし） %>
  <div class="flex flex-wrap justify-between items-center mb-6 gap-3">
    <h1 class="text-2xl font-bold text-gray-900">習慣管理</h1>
    <div class="flex items-center gap-2 flex-wrap">
      <%= link_to archived_habits_path,
            class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium
                    bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors" do %>
        <span>📦</span>
        <span>アーカイブ済みを見る</span>
      <% end %>

      <% if @locked %>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-200 text-gray-400 cursor-not-allowed"
              title="先週の振り返りを完了すると追加できます">
          🔒 + 新しい習慣を追加
        </span>
      <% else %>
        <%= link_to new_habit_path,
              class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
          + 新しい習慣を追加
        <% end %>
      <% end %>
    </div>
  </div>

  <%# 習慣カード一覧 %>
  <% if @habits.empty? %>
    <div class="text-center py-16 border-2 border-dashed border-gray-300 rounded-xl">
      <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
        <span class="text-3xl">📋</span>
      </div>
      <p class="text-gray-500 mb-4">まだ習慣が登録されていません</p>
      <% unless @locked %>
        <%= link_to "習慣を登録する", new_habit_path,
              class: "px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
      <% end %>
    </div>

  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @habits.each do |habit| %>
        <% stats = @habit_stats[habit.id] || {
             rate:            0,
             completed_count: 0,
             numeric_sum:     nil,
             effective_target: habit.check_type? ? habit.effective_weekly_target : habit.weekly_target
           } %>

        <div id="habit_record_<%= habit.id %>"
             class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow flex flex-col">

          <%# ────────────────────────────────────────────────────────────
              カードヘッダー（B-5 変更: ⋯メニューに置き換え）
              ──────────────────────────────────────────────────────────── %>
          <div class="flex justify-between items-start p-4 pb-2">
            <div class="flex-1 min-w-0 mr-2">
              <h3 class="text-base font-bold text-gray-800 leading-snug flex items-center gap-2 flex-wrap">
                <%= habit.name %>
                <% if habit.numeric_type? %>
                  <span class="text-xs font-normal text-blue-500 bg-blue-50 px-1.5 py-0.5 rounded">
                    数値型
                  </span>
                <% end %>
              </h3>

              <%# ストリークバッジ（B-3 追加・変更なし） %>
              <% if habit.current_streak > 0 %>
                <div class="mt-1 flex items-center gap-2 flex-wrap">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold
                               <%= habit.current_streak >= 7 ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700' %>">
                    🔥 <%= habit.current_streak %>日 継続中
                  </span>
                  <% if habit.longest_streak > habit.current_streak %>
                    <span class="text-xs text-gray-400">
                      最高: <%= habit.longest_streak %>日
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%#
              ─────────────────────────────────────────────────────────────
              カード右側のアクションエリア（B-5 変更）

              【変更前（B-4）】
                「編集」「📦 卒業」「削除」の3ボタンが横並び
                → ボタンが3つあって横幅が狭いカードでは崩れやすかった

              【変更後（B-5）】
                「編集」ボタン + 「⋯」メニューボタン の2ボタン構成
                「⋯」をクリックすると M-1 モーダル（アーカイブ or 削除）が開く
                → スッキリしたUIに。削除前に必ず確認モーダルを経由するので誤操作防止にもなる

              【「編集」ボタンをモーダル外に残す理由】
                編集は「現在のページを離れて edit ページへ遷移する」操作。
                削除・アーカイブの「危険操作」とは性質が異なるため、
                モーダルとは別のボタンとして独立させる。
              ─────────────────────────────────────────────────────────────
            %>
            <div class="flex items-center gap-1 flex-shrink-0">

              <%# 編集ボタン（モーダル外に独立して残す） %>
              <%= link_to "編集", edit_habit_path(habit),
                    class: "text-xs px-2 py-1 rounded bg-blue-50 text-blue-600
                            hover:bg-blue-100 transition-colors
                            focus:outline-none focus:ring-2 focus:ring-blue-500" %>

              <%#
                ⋯ メニューボタン + モーダル（_habit_card_actions パーシャル）

                render "habits/habit_card_actions":
                  app/views/habits/_habit_card_actions.html.erb を呼び出す。
                  habit: と locked: の2変数を渡す。

                locked: @locked:
                  @locked は ApplicationController#locked? で計算される値。
                  パーシャル内で「ロック中は⋯ボタン自体を出力しない」判定に使用する。
              %>
              <%= render "habits/habit_card_actions",
                    habit: habit,
                    locked: @locked %>

            </div>
          </div>

          <%# 週次目標と除外日の表示（変更なし） %>
          <div class="px-4 pb-2">
            <% if habit.check_type? %>
              <span class="text-xs text-gray-400">
                週次目標: <%= habit.effective_weekly_target %>回
              </span>
            <% else %>
              <span class="text-xs text-gray-400">
                週次目標: <%= habit.weekly_target %><%= habit.unit.presence || "回" %>/週
              </span>
            <% end %>

            <% excluded_numbers = habit.excluded_day_numbers %>
            <% if excluded_numbers.any? %>
              <span class="ml-2 text-xs text-orange-500">
                除外: <%= excluded_numbers.map { |n| HabitExcludedDay::DAY_NAMES[n] }.join("・") %>
              </span>
            <% end %>
          </div>

          <%# 今日のチェックボックス or 数値入力（変更なし） %>
          <div class="px-4 pb-3">
            <%= render "habit_records/habit_record",
                  habit: habit,
                  habit_record: @today_records_hash[habit.id] %>
          </div>

          <%# 今週の進捗バー（変更なし） %>
          <div class="px-4 pb-4 mt-auto">
            <div class="flex justify-between items-center mb-1">
              <span class="text-xs text-gray-500">今週の進捗</span>

              <% if habit.check_type? %>
                <span class="text-xs font-bold whitespace-nowrap
                             <%= stats[:rate] >= 80 ? 'text-green-600' : stats[:rate] >= 50 ? 'text-blue-600' : 'text-red-500' %>">
                  <%= stats[:completed_count] %>/<%= stats[:effective_target] %>日
                  （<%= stats[:rate] %>%）
                </span>
              <% else %>
                <% numeric_sum_display = stats[:numeric_sum].nil? ? 0.0 : stats[:numeric_sum] %>
                <span class="text-xs font-bold whitespace-nowrap
                             <%= stats[:rate] >= 80 ? 'text-green-600' : stats[:rate] >= 50 ? 'text-blue-600' : 'text-red-500' %>">
                  <%= format("%g", numeric_sum_display.round(1)) %>/<%= habit.weekly_target %><%= habit.unit.presence || "回" %>
                  （<%= stats[:rate] %>%）
                </span>
              <% end %>
            </div>

            <div class="h-2 bg-gray-200 rounded-full overflow-hidden"
                 role="progressbar"
                 aria-valuenow="<%= stats[:rate] %>"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-label="<%= habit.name %> の今週の達成率">
              <div class="h-2 rounded-full transition-all duration-300
                          <%= stats[:rate] >= 80 ? 'bg-green-500' : stats[:rate] >= 50 ? 'bg-blue-400' : 'bg-red-400' %>"
                   style="width: <%= stats[:rate] %>%">
              </div>
            </div>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>