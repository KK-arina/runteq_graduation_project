<%# app/views/habits/archived.html.erb %>
<% content_for :title, "アーカイブ済み習慣 | HabitFlow" %>
<%#
  ==============================================================================
  習慣アーカイブ一覧ページ（8-2番画面）（B-4 新規作成）
  ==============================================================================
  【このページの役割】
    「卒業した習慣」の一覧を表示する。
    各習慣には「復元する」ボタンを配置し、
    誤ってアーカイブした場合などにアクティブ一覧へ戻せる。

  【デザイン方針】
    アーカイブ済みの習慣は「達成済み・卒業済み」という位置づけのため、
    グレートーンを基調にしたカードで表示する。
    アクティブな習慣一覧（index）とは見た目を区別する。

  【スマホ対応】
    grid-cols-1 md:grid-cols-2 lg:grid-cols-3 で
    スマホ: 1列、タブレット: 2列、PC: 3列 のレスポンシブレイアウト。
  ==============================================================================
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ページヘッダー %>
  <%#
    「← 習慣一覧に戻る」リンク:
      habits_path（/habits）へ戻るリンク。
      ユーザーが迷子にならないようにパンくず代わりに設置する。
  %>
  <div class="flex flex-wrap justify-between items-center mb-6 gap-3">
    <div>
      <%= link_to "← 習慣一覧に戻る", habits_path,
            class: "text-sm text-gray-500 hover:text-gray-700 transition-colors mb-2 inline-block" %>
      <h1 class="text-2xl font-bold text-gray-900">📦 アーカイブ済み習慣</h1>
      <p class="text-sm text-gray-500 mt-1">卒業した習慣の一覧です。復元するとアクティブ一覧に戻ります。</p>
    </div>
  </div>

  <%# アーカイブ済み習慣が0件の場合の表示（Empty State） %>
  <%#
    empty state とは:
      一覧ページでデータが0件のときに表示する「空っぽの状態」を示す UI。
      ただ何も表示しないよりも、ユーザーに現状を説明することで
      「バグではない・正常な状態」だと伝えられる。
  %>
  <% if @archived_habits.empty? %>
    <div class="text-center py-16 border-2 border-dashed border-gray-300 rounded-xl">
      <div class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <span class="text-3xl">📦</span>
      </div>
      <p class="text-gray-500 mb-2 font-medium">アーカイブ済みの習慣はありません</p>
      <p class="text-gray-400 text-sm mb-6">習慣一覧の「📦 卒業」ボタンでアーカイブできます</p>
      <%= link_to "習慣一覧へ戻る", habits_path,
            class: "px-6 py-3 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" %>
    </div>

  <% else %>
    <%# アーカイブ済み習慣カード一覧 %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @archived_habits.each do |habit| %>

        <%#
          アーカイブ済み習慣カード
          【デザイン】
            アクティブ習慣カードと区別するため:
            - border-gray-200（薄いグレーの枠線）
            - bg-gray-50（薄いグレーの背景）
            - opacity（テキストを若干薄くする）
          を使う。
        %>
        <div class="bg-gray-50 border border-gray-200 rounded-xl shadow-sm flex flex-col">

          <%# カードヘッダー %>
          <div class="p-4 pb-2">
            <div class="flex justify-between items-start">
              <div class="flex-1 min-w-0 mr-2">
                <%# 習慣名 %>
                <h3 class="text-base font-bold text-gray-600 leading-snug flex items-center gap-2 flex-wrap">
                  <span class="text-gray-400">📦</span>
                  <%= habit.name %>
                  <% if habit.numeric_type? %>
                    <span class="text-xs font-normal text-gray-400 bg-gray-200 px-1.5 py-0.5 rounded">
                      数値型
                    </span>
                  <% end %>
                </h3>

                <%#
                  アーカイブ日の表示
                  【l() メソッドとは】
                    Rails の localize ヘルパー（l はエイリアス）。
                    Date / Time オブジェクトをロケールに合わせた文字列に変換する。
                    format: :long を指定すると「2026年3月29日」のような形式になる。
                    （config/locales/ja.yml の設定に依存する）
                    設定がない場合は strftime で直接フォーマットする方が確実。
                %>
                <p class="text-xs text-gray-400 mt-1">
                  アーカイブ日:
                  <%= habit.archived_at.strftime("%Y年%m月%d日") %>
                </p>

                <%# 最高ストリークが記録されていれば表示 %>
                <% if habit.longest_streak > 0 %>
                  <p class="text-xs text-gray-400 mt-0.5">
                    最高ストリーク: 🔥 <%= habit.longest_streak %>日
                  </p>
                <% end %>
              </div>

              <%#
                「復元する」ボタン（B-4 新規追加）
                【役割】
                  アーカイブ済み習慣をアクティブ状態に戻す。
                【data-turbo-method: :patch】
                  link_to はデフォルトで GET リクエストを送る。
                  PATCH リクエストを送るには data-turbo-method を指定する必要がある。
                  routes.rb で patch :unarchive を定義しているため、
                  PATCH /habits/:id/unarchive が呼ばれる。
                【unarchive_habit_path(habit)】
                  routes.rb の member do ... end 内で定義した
                  patch :unarchive から自動生成されるパスヘルパー。
                  → PATCH /habits/:id/unarchive に対応する。
              %>
              <%= link_to "🔄 復元する", unarchive_habit_path(habit),
                    data: {
                      turbo_method: :patch,
                      turbo_confirm: "「#{habit.name}」を復元しますか？\n習慣一覧に戻ります。"
                    },
                    class: "flex-shrink-0 text-xs px-3 py-1.5 rounded-lg
                            bg-white border border-gray-300 text-gray-600
                            hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600
                            transition-colors whitespace-nowrap" %>
            </div>
          </div>

          <%# 週次目標と除外日の表示 %>
          <div class="px-4 pb-3">
            <% if habit.check_type? %>
              <span class="text-xs text-gray-400">
                目標: <%= habit.effective_weekly_target %>回/週
              </span>
            <% else %>
              <span class="text-xs text-gray-400">
                目標: <%= habit.weekly_target %><%= habit.unit.presence || "回" %>/週
              </span>
            <% end %>

            <%#
              除外日の表示
              アーカイブ済みでも設定していた除外日を確認できるように表示する。
            %>
            <% excluded_numbers = habit.excluded_day_numbers %>
            <% if excluded_numbers.any? %>
              <span class="ml-2 text-xs text-gray-400">
                除外: <%= excluded_numbers.map { |n| HabitExcludedDay::DAY_NAMES[n] }.join("・") %>
              </span>
            <% end %>
          </div>

          <%#
            区切り線（カードフッター上部）
            border-t border-gray-200 で薄いグレーの区切り線を表示する。
          %>
          <div class="border-t border-gray-200 px-4 py-3 mt-auto">
            <p class="text-xs text-gray-400 text-center">
              過去の記録は振り返りで確認できます
            </p>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>