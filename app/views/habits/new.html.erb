<%# app/views/habits/new.html.erb %>
<%# ==============================================================================
    習慣新規作成ページ（B-6: カラー・アイコン選択追加）
    ==============================================================================
    【B-6 での変更内容】
      ① カラーピッカーセクションを追加
      ② アイコン選択セクションを追加

    【C-6 追加修正】
      ③ チェック型選択時は週次目標値フィールドを非表示にする。

    ============================================================
    【H-6 レスポンシブ調整での変更点】
    ============================================================

    ① 習慣名 inputのフォントサイズを text-sm → text-base（16px）に変更
       【理由】iOS Safari では 16px 未満の input をタップするとページがズームされる。
               text-base（16px）にすることでズームを防止できる。

    ② 習慣名 inputの縦余白を py-3 のまま維持（既に44px以上確保済み）

    ③ 単位 inputのフォントサイズを text-sm → text-base（16px）に変更（理由は①と同様）

    ④ 週次目標値 number inputのフォントサイズを text-sm → text-base（16px）に変更

    なお、カラー選択・アイコン選択ボタンは aspect-square / w-9 h-9 で
    44px以上が確保されているため変更不要。
    ==============================================================================
%>
<% content_for :title, "習慣を追加 | HabitFlow" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <%= link_to "← 習慣管理に戻る", habits_path,
          class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">新しい習慣を追加</h1>

  <%= render "shared/form_errors", model: @habit %>

  <%= form_with model: @habit,
                url: habits_path,
                method: :post,
                local: true,
                class: "space-y-6",
                data: { controller: "habit-form" } do |f| %>

    <%# 習慣名（H-3: 音声入力対応、H-6: text-base に変更） %>
    <div class="relative" data-controller="voice-input">
      <%= f.label :name, "習慣名",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <div class="relative">
        <%#
          text-base（16px）に変更する理由（H-6）:
            iOS Safari は 16px 未満の input をタップするとページがズームされる。
            text-sm（14px）から text-base（16px）に変更してズームを防止する。
          pr-12: 右側に音声入力ボタン分の余白を確保する（変更なし）
        %>
        <%= f.text_field :name,
              placeholder: "例: 読書、筋トレ、英語学習",
              maxlength: 50,
              class: "w-full px-4 py-3 pr-12 border border-gray-300 rounded-xl text-base
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                      transition-colors",
              data: { "voice-input-target": "field" } %>
        <%#
          🎤 ボタン（絶対配置で右端に配置）
          absolute right-3 top-1/2 -translate-y-1/2: 右端縦中央に配置する
        %>
        <button type="button"
                data-voice-input-target="button"
                data-action="click->voice-input#toggle"
                class="absolute right-3 top-1/2 -translate-y-1/2
                       p-1.5 rounded-lg border border-gray-300
                       text-gray-500 hover:bg-gray-50 transition-colors
                       focus:outline-none focus:ring-2 focus:ring-blue-500"
                aria-label="音声入力を開始する">
          🎤
        </button>
      </div>
    </div>

    <%# カラー選択（B-6 追加） %>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">カラー</label>
      <p class="text-xs text-gray-500 mb-3">習慣カードの左ボーダーの色を選択してください</p>

      <%= f.hidden_field :color,
            value: @habit.color.presence || "#3b82f6",
            data: { habit_form_target: "colorInput" } %>

      <% habit_colors = [
           { value: "#3b82f6", label: "ブルー",  bg: "bg-blue-500"   },
           { value: "#10b981", label: "グリーン", bg: "bg-emerald-500" },
           { value: "#f59e0b", label: "アンバー", bg: "bg-amber-500"   },
           { value: "#ef4444", label: "レッド",  bg: "bg-red-500"    },
           { value: "#8b5cf6", label: "パープル", bg: "bg-violet-500"  },
           { value: "#ec4899", label: "ピンク",  bg: "bg-pink-500"   },
           { value: "#06b6d4", label: "シアン",  bg: "bg-cyan-500"   },
           { value: "#64748b", label: "スレート", bg: "bg-slate-500"  }
         ] %>

      <% selected_color = @habit.color.presence || "#3b82f6" %>
      <div class="flex gap-3 flex-wrap">
        <% habit_colors.each do |color_item| %>
          <%#
            w-9 h-9 = 36px 正方形。
            スマホのタップ誤差を考慮してカラー選択ボタンは
            gap-3 で間隔を設けることでタップしやすくしている。
            hover:scale-110 は PC のみ意味があるが残しておく。
          %>
          <button type="button"
                  class="w-9 h-9 rounded-full transition-all
                        focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400
                        <%= color_item[:bg] %>
                        <%= selected_color == color_item[:value] ? 'ring-2 ring-offset-2 ring-gray-800 scale-110' : 'hover:scale-110' %>"
                  data-action="click->habit-form#selectColor"
                  data-color-value="<%= color_item[:value] %>"
                  data-habit-form-target="colorSwatch"
                  aria-label="<%= color_item[:label] %>を選択">
          </button>
        <% end %>
      </div>
    </div>

    <%# アイコン選択（B-6 追加） %>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">アイコン</label>
      <p class="text-xs text-gray-500 mb-3">習慣カードに表示する絵文字を選択してください</p>

      <%= f.hidden_field :icon,
            value: @habit.icon.presence || "📋",
            data: { habit_form_target: "iconInput" } %>

      <% habit_icons = ["📚", "💪", "🏃", "🧘", "✍️", "🎵",
                        "💻", "🌱", "🍎", "😴", "🎯", "⭐",
                        "📋", "🔥", "💡", "🎨"] %>

      <%#
        grid-cols-8: スマホ（375px）でも8列に並べる。
          各セル幅 ≈ 375px / 8 ≈ 46px なので WCAG の 44px をギリギリ確保できる。
          aspect-square で正方形にして縦も同じ高さになる。
      %>
      <div class="grid grid-cols-8 sm:grid-cols-8 gap-2">
        <% habit_icons.each do |icon| %>
          <button type="button"
                  class="aspect-square flex items-center justify-center text-xl
                         border-2 rounded-lg transition-all
                         focus:outline-none focus:ring-2 focus:ring-blue-500
                         <%= (@habit.icon.presence || '📋') == icon ? 'border-blue-500 bg-blue-50 scale-110' : 'border-gray-200 hover:border-blue-300 hover:bg-blue-50' %>"
                  data-action="click->habit-form#selectIcon"
                  data-icon-value="<%= icon %>"
                  data-habit-form-target="iconButton"
                  aria-label="<%= icon %>を選択">
            <%= icon %>
          </button>
        <% end %>
      </div>
    </div>

    <%# measurement_type %>
    <div>
      <%= f.label :measurement_type, "記録タイプ",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">習慣をどのように記録するかを選択してください</p>
      <div class="grid grid-cols-2 gap-3">
        <%#
          ラジオカードの高さ: p-4 で十分なタップ領域が確保されている。
          grid-cols-2 で 375px / 2 ≈ 187px 幅になりスマホでも操作しやすい。
        %>
        <label class="relative flex items-center gap-3 p-4 border-2 rounded-xl cursor-pointer
                      border-gray-200 hover:border-gray-300"
               data-habit-form-target="measurementLabel">
          <%= f.radio_button :measurement_type, "check_type",
                checked: @habit.measurement_type.nil? || @habit.check_type?,
                class: "sr-only",
                data: {
                  habit_form_target: "measurementType",
                  action: "change->habit-form#toggleUnit"
                } %>
          <div>
            <span class="text-lg">☑️</span>
            <p class="text-sm font-semibold text-gray-800 mt-1">チェック型</p>
            <p class="text-xs text-gray-500">やった/やらない</p>
          </div>
        </label>
        <label class="relative flex items-center gap-3 p-4 border-2 rounded-xl cursor-pointer
                      border-gray-200 hover:border-gray-300"
               data-habit-form-target="measurementLabel">
          <%= f.radio_button :measurement_type, "numeric_type",
                class: "sr-only",
                data: {
                  habit_form_target: "measurementType",
                  action: "change->habit-form#toggleUnit"
                } %>
          <div>
            <span class="text-lg">🔢</span>
            <p class="text-sm font-semibold text-gray-800 mt-1">数値型</p>
            <p class="text-xs text-gray-500">分・冊・km で記録</p>
          </div>
        </label>
      </div>
    </div>

    <%# unit（数値型のみ表示） %>
    <div data-habit-form-target="unitField"
         <%= @habit.numeric_type? ? "" : "hidden" %>>
      <%= f.label :unit, "単位",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">数値型習慣の単位を入力してください（例: 分、冊、km）</p>
      <%#
        text-base（16px）に変更する理由（H-6）:
          iOS Safari は 16px 未満の input をタップするとページがズームされる。
          text-sm から text-base に変更してズームを防止する。
      %>
      <%= f.text_field :unit,
            placeholder: "例: 分、冊、km",
            maxlength: 10,
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                    transition-colors" %>
    </div>

    <%#
      週次目標値（C-6 変更: チェック型は非表示にする）
      H-6 変更: text-sm → text-base（iOS自動ズーム防止）
    %>
    <div data-habit-form-target="weeklyTargetField"
         <%= @habit.numeric_type? ? "" : "hidden" %>>
      <%= f.label :weekly_target, "週次目標値",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">
        1週間の目標を設定してください（単位: 1以上の数値）
      </p>
      <%#
        text-base（16px）に変更する理由（H-6）:
          iOS Safari は 16px 未満の input をタップするとページがズームされる。
          number_field にも text-base を適用してズームを防止する。
      %>
      <%= f.number_field :weekly_target,
            min: 1,
            value: @habit.weekly_target || 5,
            data: { habit_form_target: "weeklyTargetInput" },
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                    transition-colors" %>
    </div>

    <%# 除外する曜日 %>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">除外する曜日</label>
      <p class="text-xs text-gray-500 mb-3">実施しない曜日を選択してください（達成率の計算から除外されます）</p>
      <% selected_days = Array(params[:excluded_day_numbers]).map(&:to_i) %>
      <%#
        grid-cols-4: スマホ（375px）では4列。各セル幅 ≈ 84px で十分なタップ領域がある。
        sm:grid-cols-7: 640px以上では7列（曜日をすべて1行に並べる）。
      %>
      <div class="grid grid-cols-4 sm:grid-cols-7 gap-2">
        <% HabitExcludedDay::DAY_NAMES_FULL.each do |day_number, day_name| %>
          <label class="flex flex-col items-center gap-1.5 p-2 border-2 rounded-lg cursor-pointer
                        transition-colors hover:border-blue-300 hover:bg-blue-50
                        has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50
                        focus-within:ring-2 focus-within:ring-blue-500 focus-within:ring-offset-1">
            <%= check_box_tag "excluded_day_numbers[]", day_number,
                  selected_days.include?(day_number),
                  id: "excluded_day_#{day_number}",
                  class: "sr-only" %>
            <span class="text-xs font-bold text-gray-600"><%= day_name %></span>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-gray-400 mt-2">※ 例: 土日を除外すると週5日が最大達成日数になります</p>
    </div>

    <%# ボタンエリア %>
    <div class="flex justify-end items-center gap-4 pt-2">
      <%#
        キャンセルボタン: py-3 で 44px 以上のタップ領域を確保する（H-6 変更）
          既存の px-5 py-3 は既に適切なサイズのため変更なし。
      %>
      <%= link_to "キャンセル", habits_path,
            class: "px-5 py-3 bg-white border border-gray-300 text-gray-700 text-sm font-semibold
                    rounded-xl hover:bg-gray-50 transition-colors
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
      <%#
        登録ボタン: py-3 で 44px 以上のタップ領域を確保する（既存のまま）
      %>
      <%= f.submit "登録する",
            class: "flex-1 py-3 px-4 bg-blue-600 text-white text-sm font-semibold
                    rounded-xl hover:bg-blue-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>

  <% end %>
</div>
