<%# app/views/habits/new.html.erb %>
<%#
  【このファイルの役割】
    習慣の新規作成フォームページ。
    HabitsController の new アクション（GET /habits/new）で表示される。

  【Issue #27 での変更点】
    バリデーションエラー表示を shared/_form_errors パーシャルで統一。
%>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ページタイトルと戻るリンクを横並びにする %>
  <div class="flex items-center gap-4 mb-6">
    <%#
      link_to "←", habits_path:
        「←」文字をクリックで習慣一覧へ戻るリンク。
        aria-label で「習慣一覧へ戻る」とスクリーンリーダーに伝える。
    %>
    <%= link_to habits_path,
          class: "text-gray-500 hover:text-gray-700 transition-colors",
          aria: { label: "習慣一覧へ戻る" } do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
           aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>

    <h1 class="text-2xl font-bold text-gray-900">新しい習慣を追加</h1>
  </div>

  <%#
    bg-white rounded-xl shadow-sm p-6:
      白いカード風のコンテナに入れて、フォームを際立たせる。
  %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <%= form_with model: @habit, local: true do |f| %>

      <%#
        共通バリデーションエラーパーシャルの呼び出し
        model: @habit を渡すことで @habit.errors を参照する。
        エラーがない場合は何も表示されない。
      %>
      <%= render "shared/form_errors", model: @habit %>

      <%# 習慣名入力 %>
      <div class="mb-4">
        <%= f.label :name, "習慣名", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :name,
            placeholder: "例: 毎朝30分ウォーキング",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%# 週次目標入力 %>
      <%#
        週次目標（週に何回実施するか）を数値で入力する。
        min="1" max="7": 週7日が最大なのでバリデーションをHTMLレベルでも行う。
      %>
      <div class="mb-6">
        <%= f.label :weekly_target, "週の目標回数", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.number_field :weekly_target,
            min: 1, max: 7, placeholder: "3",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <%# ヒントテキスト %>
        <p class="mt-1 text-xs text-gray-400">週に何回実施するか（1〜7回）を入力してください</p>
      </div>

      <%# 送信ボタン %>
      <%= f.submit "習慣を登録する",
          class: "w-full px-4 py-2 bg-blue-600 text-white rounded-md
                  hover:bg-blue-700 transition font-medium" %>
    <% end %>

  </div>
</div>