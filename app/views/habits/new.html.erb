<%# app/views/habits/new.html.erb %>
<% content_for :title, "習慣を追加 | HabitFlow" %>
<%#
  ==============================================================================
  習慣新規作成ページ（B-1: 数値型習慣対応・ラジオボタンハイライト修正）
  ==============================================================================

  【B-1 での変更内容】
    ① measurement_type の選択フィールドを追加
       - チェック型（0）: やった/やらないで記録
       - 数値型（1）: 数値で記録（分・冊・km など）
    ② unit（単位）の入力フィールドを追加（数値型のみ表示）
    ③ Stimulus コントローラーで measurement_type に応じて unit フィールドを動的表示

  【今回の修正内容】
    ④ ラジオボタンを囲む label タグに data-habit-form-target="measurementLabel" を追加
       → habit_form_controller.js の toggleUnit() からラベルのクラスを切り替えられるように

  【なぜ label タグに target を付けるのか】
    ラジオボタン自体は class="sr-only" で非表示にしており、
    label タグ全体がカード風ボタンとして表示される。
    ユーザーがクリックしたとき「選択中」の青枠を付けるために、
    JavaScript（Stimulus）が label タグを直接操作する必要がある。
    data-habit-form-target="measurementLabel" を付けることで
    this.measurementLabelTargets から参照できるようになる。
  ==============================================================================
%>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# 戻るリンク %>
  <div class="mb-6">
    <%= link_to "← 習慣管理に戻る", habits_path,
          class: "text-sm text-blue-600 hover:text-blue-800 hover:underline transition-colors" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">新しい習慣を追加</h1>

  <%# バリデーションエラーの表示 %>
  <%= render "shared/form_errors", model: @habit %>

  <%#
    data-controller="habit-form":
      このフォーム全体を habit_form_controller.js（Stimulus コントローラー）に紐付ける。
      コントローラーが提供する toggleUnit() メソッドが
      measurement_type の切り替えに応じて UI を更新する。
  %>
  <%= form_with model: @habit,
                url: habits_path,
                method: :post,
                local: true,
                class: "space-y-6",
                data: { controller: "habit-form" } do |f| %>

    <%# 習慣名 %>
    <div>
      <%= f.label :name, "習慣名",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :name,
            placeholder: "例: 読書、筋トレ、英語学習",
            maxlength: 50,
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                    transition-colors" %>
    </div>

    <%# measurement_type（B-1 追加） %>
    <div>
      <%= f.label :measurement_type, "記録タイプ",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">習慣をどのように記録するかを選択してください</p>

      <div class="grid grid-cols-2 gap-3">

        <%# ── チェック型の選択カード ──────────────────────────────────────── %>
        <%#
          【修正箇所】data-habit-form-target="measurementLabel" を追加
          この label タグを habit_form_controller.js の
          this.measurementLabelTargets から参照できるようにする。
          JS が label の border/背景クラスを切り替えて「選択中」を視覚的に示す。

          【初期スタイルについて】
          border-gray-200 を初期値にしている。
          connect() メソッドが読み込み時に自動的に toggleUnit() を呼び出し、
          現在の選択状態に合わせて正しいクラスを付与するため、
          ERB 側でスタイルを条件分岐させる必要がなくなった。
          （以前は = @habit.check_type? ? 'border-blue-500...' : 'border-gray-200...'
            という ERB での条件分岐が必要だったが不要になった）
        %>
        <label class="relative flex items-center gap-3 p-4 border-2 rounded-xl cursor-pointer
                      border-gray-200 hover:border-gray-300"
               data-habit-form-target="measurementLabel">
          <%#
            ラジオボタン本体: class="sr-only" で視覚的には非表示にしている。
            sr-only = Screen Reader Only の略で、スクリーンリーダーには読まれるが
            画面上には表示されない（アクセシビリティを保ちながら非表示にする方法）。

            data-habit-form-target="measurementType":
              JS から this.measurementTypeTargets で参照してチェック状態を取得する。
            data-action="change->habit-form#toggleUnit":
              ラジオボタンの選択が変わったとき（change イベント）に
              habit_form_controller.js の toggleUnit() メソッドを呼び出す。

            checked: @habit.check_type? || @habit.measurement_type.nil?:
              新規作成時（measurement_type が nil）または
              バリデーションエラーでチェック型が選ばれていた場合に
              チェック済み状態で初期表示する。
          %>
          <%= f.radio_button :measurement_type, "check_type",
                checked: @habit.measurement_type.nil? || @habit.check_type?,
                class: "sr-only",
                data: {
                  habit_form_target: "measurementType",
                  action: "change->habit-form#toggleUnit"
                } %>
          <div>
            <span class="text-lg">☑️</span>
            <p class="text-sm font-semibold text-gray-800 mt-1">チェック型</p>
            <p class="text-xs text-gray-500">やった/やらない</p>
          </div>
        </label>

        <%# ── 数値型の選択カード ──────────────────────────────────────────── %>
        <%#
          【修正箇所】data-habit-form-target="measurementLabel" を追加
          チェック型と同様に JS から参照できるようにする。
          クリック時に toggleUnit() が呼ばれ、
          このラベルに border-blue-500 bg-blue-50 が付き、
          チェック型ラベルからは border-blue-500 bg-blue-50 が外れる。
        %>
        <label class="relative flex items-center gap-3 p-4 border-2 rounded-xl cursor-pointer
                      border-gray-200 hover:border-gray-300"
               data-habit-form-target="measurementLabel">
          <%#
            数値型のラジオボタン。
            checked 属性を省略しているため、デフォルトは非選択。
            バリデーションエラーで数値型が選ばれていた場合（@habit.numeric_type?）は
            チェック済みで表示される必要があるが、
            connect() → toggleUnit() が読み込み時に自動実行されるため
            ラベルのハイライトは JS が正しく設定してくれる。
          %>
          <%= f.radio_button :measurement_type, "numeric_type",
                class: "sr-only",
                data: {
                  habit_form_target: "measurementType",
                  action: "change->habit-form#toggleUnit"
                } %>
          <div>
            <span class="text-lg">🔢</span>
            <p class="text-sm font-semibold text-gray-800 mt-1">数値型</p>
            <p class="text-xs text-gray-500">分・冊・km で記録</p>
          </div>
        </label>

      </div>
    </div>

    <%# unit（単位）: 数値型のときのみ表示（B-1 追加） %>
    <%#
      data-habit-form-target="unitField":
        habit_form_controller.js から this.unitFieldTarget で参照できる。
        toggleUnit メソッドで hidden 属性を切り替えてフィールドを表示/非表示する。

      hidden（初期状態）:
        新規作成時はチェック型がデフォルトのため最初から非表示。
        @habit.numeric_type? のとき（バリデーションエラー後の再表示など）は表示する。
        【注意】hidden 属性の付け方:
          ERB で hidden: true と書くと <div hidden="hidden"> になり正しく動く。
          ただし今回は文字列補間で制御している。
    %>
    <div data-habit-form-target="unitField"
         <%= @habit.numeric_type? ? "" : "hidden" %>>
      <%= f.label :unit, "単位",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">数値型習慣の単位を入力してください（例: 分、冊、km）</p>
      <%= f.text_field :unit,
            placeholder: "例: 分、冊、km",
            maxlength: 10,
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                    transition-colors" %>
    </div>

    <%# 週次目標値 %>
    <div>
      <%= f.label :weekly_target, "週次目標値",
            class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%#
        data-habit-form-target="weeklyTargetLabel":
          measurement_type が変わったとき、ヒント文の内容を切り替える。
          チェック型: 「（1〜7回）」 / 数値型: 「（単位: 1以上の数値）」
      %>
      <p class="text-xs text-gray-500 mb-2">
        1週間の目標を設定してください
        <span data-habit-form-target="weeklyTargetLabel">
          <%= @habit.numeric_type? ? "（単位: 1以上の数値）" : "（1〜7回）" %>
        </span>
      </p>
      <%#
        max: @habit.numeric_type? ? nil : 7
          数値型のとき max 属性を付けない（nil にすると Rails は属性を出力しない）。
          チェック型のとき max=7 を設定する。
          JS の toggleUnit() でも max を動的に変更するが、
          ページ初期表示時の HTML も正しい状態にしておくことで
          「JS が動く前の一瞬」もバリデーションが機能する。
      %>
      <%= f.number_field :weekly_target,
            min: 1,
            max: @habit.numeric_type? ? nil : 7,
            value: @habit.weekly_target || 5,
            class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                    transition-colors" %>
    </div>

    <%# ボタンエリア %>
    <div class="flex justify-end items-center gap-4 pt-2">
      <%= link_to "キャンセル", habits_path,
            class: "px-5 py-3 bg-white border border-gray-300 text-gray-700 text-sm font-semibold
                    rounded-xl hover:bg-gray-50 transition-colors
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
      <%= f.submit "登録する",
            class: "flex-1 py-3 px-4 bg-blue-600 text-white text-sm font-semibold
                    rounded-xl hover:bg-blue-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>

  <% end %>

</div>
