<%# app/views/layouts/application.html.erb %>
<%#
  【このファイルの役割】
  すべてのビューに共通するHTMLの「外枠」を定義するレイアウトファイル。

  【Issue #27 での変更点】
  - フラッシュメッセージに Stimulus flash コントローラーを紐付けてトースト通知化
  - アイコン追加・✕ボタン追加
  - message_type.to_s を使って symbol/string 両対応
%>
<!DOCTYPE html>
<html>
  <head>
    <title>HabitFlow</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 flex flex-col">

    <%= render "shared/header" %>

    <%#
      ════════════════════════════════════════════════════
      フラッシュメッセージ（トースト通知）表示エリア
      Issue #27: Stimulus の flash コントローラーと連携
      ════════════════════════════════════════════════════

      flash.each:
        flash ハッシュを1件ずつ処理する。
        flash は Hash のようなオブジェクトで、
        redirect_to ~, notice: "..." で値がセットされる。
    %>
    <% flash.each do |message_type, message| %>
      <%#
        【重要】message_type.to_s で文字列に統一する
        Rails の flash は内部で symbol（:notice）として扱うこともあれば
        string（"notice"）として扱うこともある。
        .to_s で統一しないと when 'notice' が :notice にマッチしない場合がある。
        例: :notice.to_s → "notice"（文字列に変換される）
      %>
      <% type = message_type.to_s %>

      <div class="max-w-7xl mx-auto px-4 mt-4"
           data-controller="flash"
           data-flash-target="message"
           data-flash-duration-value="<%= case type
                                           when 'unlock' then 6000
                                           when 'alert'  then 6000
                                           when 'warning' then 5000
                                           else 4000
                                           end %>"
           role="alert">

        <%#
          relative: ✕ボタンを絶対配置するための基準
          pr-10: ✕ボタンが文字に重ならないよう右側に余白を確保
        %>
        <div class="relative px-4 py-3 rounded-lg border pr-10
          <%= case type
              when 'notice'  then 'bg-blue-50 border-blue-200 text-blue-800'
              when 'alert'   then 'bg-red-50 border-red-200 text-red-800'
              when 'warning' then 'bg-yellow-50 border-yellow-200 text-yellow-800'
              when 'unlock'  then 'bg-green-50 border-green-400 text-green-800 border-2 font-semibold'
              else                'bg-gray-50 border-gray-200 text-gray-800'
              end %>">

          <div class="flex items-start gap-2">
            <%# メッセージタイプ別アイコン %>
            <span class="flex-shrink-0">
              <%= case type
                  when 'notice'  then '✅'
                  when 'alert'   then '❌'
                  when 'warning' then '⚠️'
                  when 'unlock'  then '🔓'
                  else                'ℹ️'
                  end %>
            </span>
            <span class="text-sm leading-relaxed"><%= message %></span>
          </div>

          <%#
            ✕（閉じる）ボタン
            data-action="flash#dismiss":
              クリック時に FlashController の dismiss() を呼び出す。
            absolute top-2 right-2:
              親の relative div の右上に絶対配置する。
          %>
          <button type="button"
                  data-action="flash#dismiss"
                  class="absolute top-2 right-2 p-1 rounded
                         opacity-60 hover:opacity-100 transition-opacity"
                  aria-label="閉じる">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                 aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>

        </div>
      </div>
    <% end %>

    <main class="flex-1">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>

  </body>
</html>