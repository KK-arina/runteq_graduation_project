<%# ファイルパス: app/views/layouts/application.html.erb %>
<%#
  【このファイルの役割】
  すべてのビューに共通するHTMLの「外枠」を定義するレイアウトファイル。
  ヘッダー、フラッシュメッセージ、フッターなどを含む。

  Issue #25 では flash[:unlock] という新しいフラッシュタイプを追加する。
  ロック解除時に通常の notice（青）とは違う、目立つ緑色のバナーを表示する。
%>

<!DOCTYPE html>
<html>
  <head>
    <title>HabitFlow</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">

    <%# ナビゲーションバー %>
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 py-3 flex justify-between items-center">
        <%= link_to "HabitFlow", dashboard_path, class: "text-xl font-bold text-indigo-600" %>

        <% if logged_in? %>
          <div class="flex items-center gap-4">
            <%= link_to "ダッシュボード", dashboard_path,
                class: "text-sm text-gray-600 hover:text-indigo-600" %>
            <%= link_to "習慣一覧", habits_path,
                class: "text-sm text-gray-600 hover:text-indigo-600" %>
            <%= link_to "振り返り", weekly_reflections_path,
                class: "text-sm text-gray-600 hover:text-indigo-600" %>
            <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete },
                class: "text-sm text-gray-500 hover:text-red-500" %>
          </div>
        <% end %>
      </div>
    </nav>

    <%#
      ============================================================
      フラッシュメッセージの表示エリア（Issue #25 で unlock タイプを追加）
      ============================================================

      【フラッシュメッセージとは？】
      アクションの結果（成功・失敗・ロック解除など）をユーザーに一時的に通知する仕組み。
      次のページを表示したときだけ表示され、その後は消える。

      【flash のキーと表示スタイルの対応】
      - flash[:notice]  → 青（情報・成功）
      - flash[:alert]   → 赤（エラー・警告）
      - flash[:warning] → 黄（注意）
      - flash[:unlock]  → 緑（ロック解除 ← Issue #25 で追加）

      【なぜ unlock を分けるのか？】
      ロック解除は「ユーザーにとって嬉しいイベント」なので、
      通常の notice（青）とは異なる目立つ緑色で表示したい。
    %>

    <%# ---- notice: 青いバナー（情報・成功） ---- %>
    <% if flash[:notice] %>
      <div class="max-w-4xl mx-auto px-4 mt-4"
           data-controller="flash"
           data-flash-duration-value="5000">
        <%#
          role="alert" → スクリーンリーダーがこの要素を「通知」として読み上げる（アクセシビリティ対応）
          data-flash-target="message" → Stimulus コントローラーからこの要素を参照するためのターゲット名
        %>
        <div role="alert"
             data-flash-target="message"
             class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-lg flex justify-between items-center">
          <span><%= flash[:notice] %></span>
          <%# ✕ ボタンで手動で閉じられるようにする %>
          <button data-action="flash#dismiss"
                  class="text-blue-400 hover:text-blue-600 ml-4 text-lg leading-none"
                  aria-label="閉じる">×</button>
        </div>
      </div>
    <% end %>

    <%# ---- alert: 赤いバナー（エラー・警告） ---- %>
    <% if flash[:alert] %>
      <div class="max-w-4xl mx-auto px-4 mt-4"
           data-controller="flash"
           data-flash-duration-value="7000">
        <div role="alert"
             data-flash-target="message"
             class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg flex justify-between items-center">
          <span><%= flash[:alert] %></span>
          <button data-action="flash#dismiss"
                  class="text-red-400 hover:text-red-600 ml-4 text-lg leading-none"
                  aria-label="閉じる">×</button>
        </div>
      </div>
    <% end %>

    <%# ---- warning: 黄色いバナー（注意） ---- %>
    <% if flash[:warning] %>
      <div class="max-w-4xl mx-auto px-4 mt-4"
           data-controller="flash"
           data-flash-duration-value="6000">
        <div role="alert"
             data-flash-target="message"
             class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded-lg flex justify-between items-center">
          <span><%= flash[:warning] %></span>
          <button data-action="flash#dismiss"
                  class="text-yellow-500 hover:text-yellow-700 ml-4 text-lg leading-none"
                  aria-label="閉じる">×</button>
        </div>
      </div>
    <% end %>

    <%#
      ---- unlock: 緑のバナー（ロック解除 ← Issue #25 で追加） ----

      【なぜ緑なのか？】
      緑は「成功」「解放」「ポジティブ」を連想させる色。
      ロック解除というユーザーにとって嬉しいイベントにふさわしい。

      【animate-pulse について】
      Tailwind CSS のアニメーションクラス。
      要素が点滅（フェードイン・フェードアウト）するアニメーションを追加する。
      目立たせることで「何かが解除された」ことをユーザーが気づきやすくなる。
      duration-value を長めの 8000ms（8秒）にして読む時間を確保する。
    %>
    <% if flash[:unlock] %>
      <div class="max-w-4xl mx-auto px-4 mt-4"
           data-controller="flash"
           data-flash-duration-value="8000">
        <div role="alert"
             data-flash-target="message"
             class="bg-green-50 border-2 border-green-400 text-green-800 px-4 py-3 rounded-lg flex justify-between items-center animate-pulse">
          <%#
            animate-pulse は数秒後に止めたいので、
            Stimulus の flash コントローラー側で stop-pulse を呼ぶか、
            シンプルに CSS アニメーションを 2秒で止める方法もある。
            今は Tailwind のデフォルト動作（ずっと点滅）のままにする。
          %>
          <span class="font-semibold text-lg"><%= flash[:unlock] %></span>
          <button data-action="flash#dismiss"
                  class="text-green-500 hover:text-green-700 ml-4 text-xl leading-none font-bold"
                  aria-label="閉じる">×</button>
        </div>
      </div>
    <% end %>

    <%# メインコンテンツ %>
    <main class="max-w-4xl mx-auto px-4 py-6">
      <%= yield %>
    </main>

  </body>
</html>
