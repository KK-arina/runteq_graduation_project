<%# app/views/onboardings/step5.html.erb %>
<%#
  ==============================================================================
  オンボーディング 2/2: PMVV目標入力ページ（H-5変更: ステップ表記を1/2・2/2に修正）
  ==============================================================================
  【E-1修正での変更内容】
    UserPurpose の5フィールドが必須化されたため、
    情報バナーの「すべて任意入力です」という文言を削除する。

  【スキップについての重要な設計メモ】
    スキップボタン（button_to onboarding_skip_path）は
    UserPurpose を保存せずにオンボーディングを完了するルート。
    OnboardingsController#skip は UserPurpose のバリデーションを
    通らずに first_login_at を更新するだけのため、
    必須化してもスキップは引き続き正常に動作する。

    一方、完了ボタン（フォーム内の f.submit）は
    POST /onboarding/complete → OnboardingsController#complete を呼び、
    こちらは UserPurpose.create! を経由するため必須バリデーションが走る。

  【_voice_field.html.erb パーシャルへの変更】
    必須バッジ・インラインエラー表示は _voice_field.html.erb に追加済みのため、
    このファイルは情報バナーの文言変更のみ行う。
  ==============================================================================
%>
<% content_for :title, "目標を入力（2/2）| HabitFlow" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ステップインジケーター %>
  <div class="flex justify-center items-center gap-2 mb-8"
      aria-label="オンボーディング進捗: 2ステップ中の2ステップ目">
    <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center
                justify-center text-xs font-bold flex-shrink-0"
        aria-hidden="true">✓</div>
    <div class="w-8 h-1 bg-green-400 flex-shrink-0" aria-hidden="true"></div>
    <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center
                justify-center text-xs font-bold flex-shrink-0
                ring-2 ring-blue-500 ring-offset-2"
        aria-current="step" aria-label="ステップ 2（現在）">2</div>
  </div>

  <%# ページヘッダー %>
  <div class="mb-6 text-center">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">
      ステップ 2 / 2 — 最後のステップです
    </p>
    <h1 class="text-2xl font-bold text-gray-900">🎯 あなたの目標を教えてください</h1>
    <p class="mt-2 text-sm text-gray-500 leading-relaxed">
      PMVV（Purpose / Mission / Vision / Value）を入力すると、<br>
      AIがあなたに合った習慣・タスクを提案します。
    </p>
  </div>

  <%#
    情報バナー（E-1修正: 文言変更）
    ──────────────────────────────────────────────────────────
    【変更前】「すべて任意入力です。スキップして後から入力することもできます。」
    【変更後】任意入力の記述を削除（5フィールドが必須化されたため）
              スキップ自体は引き続き可能なので、スキップの案内は維持する。
  %>
  <div class="mb-6 flex items-start gap-3 px-4 py-3
              bg-violet-50 border border-violet-200 rounded-xl">
    <span class="text-xl flex-shrink-0" aria-hidden="true">✨</span>
    <p class="text-sm text-violet-700 leading-relaxed">
      スキップして後から入力することもできます。<br>
      保存後、バックグラウンドでAI分析を開始します。
    </p>
  </div>

  <%# バリデーションエラー表示 %>
  <%= render "shared/form_errors", model: @user_purpose %>

  <%# PMVV 入力フォーム %>
  <%= form_with model: @user_purpose,
                url: onboarding_complete_path,
                method: :post,
                local: true,
                class: "space-y-6",
                data: {
                  controller: "form-submit",
                  action: "submit->form-submit#submit"
                } do |f| %>

    <%# PURPOSE（人生で大切にしていること）%>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :purpose,
          label_text: "Purpose",
          hint_text: "人生で一番大切にしていることは？",
          placeholder: "人生で一番大切にしていることを自由に書いてください",
          example: "例: 家族と過ごす時間を大切にしながら、仕事でも成果を出したい",
          rows: 3,
          maxlength: 1000 %>

    <%# VISION（1年後の理想の自分）%>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :vision,
          label_text: "Vision",
          hint_text: "1年後どんな自分になっていたいか？",
          placeholder: "1年後になりたい自分の姿を具体的に書いてください",
          example: "例: 毎朝6時に起きて読書できる習慣が身についた自分",
          rows: 3,
          maxlength: 1000 %>

    <%# MISSION（今最も必要なこと）%>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :mission,
          label_text: "Mission",
          hint_text: "今の自分に最も必要なことは？",
          placeholder: "今の自分に最も必要なことを書いてください",
          example: "例: 睡眠の質を改善して、毎日の集中力を高める",
          rows: 3,
          maxlength: 1000 %>

    <%# VALUE（絶対に譲れないこと）%>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :value,
          label_text: "Value",
          hint_text: "絶対に譲れないことは？",
          placeholder: "あなたが大切にしている価値観を書いてください",
          example: "例: 家族との夕食時間は削らない。週末の休息は確保する",
          rows: 2,
          maxlength: 500 %>

    <%# CURRENT（今の自分の現状）%>
    <%= render "user_purposes/voice_field",
          f: f,
          field: :current_situation,
          label_text: "Current",
          hint_text: "今の自分の現状を教えてください",
          placeholder: "現在の状況や課題を具体的に書いてください（AIの分析精度が上がります）",
          example: "例: 夜11時に寝ているが質が悪く、朝起きるのが辛い。筋トレは週2回できている",
          rows: 3,
          maxlength: 1000 %>

    <%# 完了ボタン（フォーム内）%>
    <div class="pt-2">
      <%= f.submit t("onboarding.complete_button"),
            class: "w-full py-3 px-6 bg-violet-600 text-white
                    text-sm font-semibold rounded-xl
                    hover:bg-violet-700 transition-colors cursor-pointer
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500",
            data: {
              "form-submit-target": "button",
              "loading-text": "保存中..."
            } %>
    </div>

  <% end %>

  <%#
    スキップボタン（フォームの外）
    ────────────────────────────────────────────────────────
    【なぜフォームの外に置くのか】
      button_to は独自の <form method="post"> を生成する。
      HTML の仕様では form の中に form を入れることができない。
      フォームの外に出すことでスキップは完全に独立した POST リクエストになる。

    【スキップとバリデーションの関係】
      スキップは POST /onboarding/skip → OnboardingsController#skip
      skip アクションは UserPurpose を保存しないため、
      presence: true バリデーションは走らない。
      必須化してもスキップは引き続き正常に動作する。
  %>
  <div class="mt-3">
    <%= button_to t("onboarding.skip_button"),
          onboarding_skip_path,
          method: :post,
          form: { class: "w-full" },
          class: "w-full px-5 py-3 bg-white border border-gray-300
                  text-gray-500 text-sm font-medium rounded-xl
                  hover:bg-gray-50 hover:text-gray-700 transition-colors
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400" %>
  </div>

  <%# 補足説明 %>
  <p class="mt-4 text-center text-xs text-gray-400 leading-relaxed">
    スキップしても、ダッシュボードの「目標管理」からいつでも入力できます。<br>
    PMVV を入力することで AI 提案の精度が大幅に向上します。
  </p>

</div>

<%= render "shared/crisis_intervention_modal" %>
