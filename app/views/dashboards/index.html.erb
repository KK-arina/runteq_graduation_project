<%# Tailwind の purge 対策: bg-green-500 bg-blue-500 bg-red-400 bg-red-500 text-green-600 text-blue-600 text-red-500 bg-amber-50 border-amber-200 text-amber-800 text-amber-700
  ダッシュボード画面。
  今週の習慣達成率・今日の習慣チェック・タスク優先度別達成率・今日のタスクを表示する。

  【D-7 変更点】
    PMVV AI分析バナーを追加。

  【G-4 変更点】
    お休みモード中のバナーと「😴 休息中」バッジを追加。

  【G-7 変更点】
    ダッシュボード専用 PMVV 完了通知バナーを追加。
    turbo_stream_from "dashboard_notifications_#{current_user.id}" を追加。
    id="dashboard_pmvv_completion_banner" の空 div を追加。
%>
<% content_for :title, "ダッシュボード | HabitFlow" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%#
    D-7: PMVV AI分析状態バナー（16番ページとの共有ストリーム）
    G-7: ダッシュボード専用 PMVV 完了通知バナーの追加
  %>
  <% if @current_purpose %>
    <%#
      ダッシュボード専用のストリーム名を使う。
      PMVVページの "user_purpose_#{id}" とは別ストリームにすることで
      完全に独立した Turbo Stream 制御が可能になる。
    %>
    <%= turbo_stream_from "dashboard_user_purpose_#{@current_purpose.id}" %>
    <div id="analysis_status_banner" class="mb-6">
      <% unless @current_purpose.completed? %>
        <%= render "user_purposes/analysis_status_banner",
              user_purpose: @current_purpose,
              ai_analysis:  @ai_analysis %>
      <% end %>
    </div>
  <% end %>

  <%= turbo_stream_from "dashboard_notifications_#{current_user.id}" %>
  <%#
    H-9 追加: PMVV完了バナーをリロード後も✖を押すまで表示し続ける。
    【なぜ空divの中に描画するのか】
      ライブ配信（PurposeAnalysisJob#broadcast_dashboard_completion）は
      target: "dashboard_pmvv_completion_banner" にこのバナーを流し込む。
      サーバー描画でも同じ id の中に同じパーシャルを描画することで、
      「ページを開いた瞬間から未確認バナーを表示」と「その後のライブ更新」を両立する。
      振り返りバナー（dashboard_reflection_completion_banner）と同じ設計。
    【@show_pmvv_completion_banner が false のとき】
      中身が空になり、バナーは表示されない（✖で閉じた後・未完了・危機検出時）。
  %>
  <div id="dashboard_pmvv_completion_banner">
    <% if @show_pmvv_completion_banner %>
      <%= render "dashboards/pmvv_completion_banner",
            user_purpose: @current_purpose,
            ai_analysis:  @ai_analysis %>
    <% end %>
  </div>
  <%# G-7 追加: 振り返りAI分析完了バナーのプレースホルダー %>
  <%#
    @reflection_analysis_pending: ダッシュボード初期表示時に分析中かを判定する。
    Turbo Stream は完了時のみブロードキャストするため、
    初期表示で分析中の場合はコントローラで判定して直接表示する。
  %>
  <% if @reflection_analysis_pending %>
    <%# ── ブランチ①: AIが分析実行中の「待機中スピナーバナー」 ── %>
    <%# data-testid: テストは文言でなくこの識別子で検証するため、文言変更でテストが壊れない %>
    <div id="dashboard_reflection_completion_banner" data-testid="reflection-analysis-pending">
      <div class="mb-6 flex items-center gap-3 px-4 py-3
                  bg-blue-50 border border-blue-300 rounded-xl"
           role="status" aria-live="polite">
        <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin flex-shrink-0"
             aria-hidden="true"></div>
        <div class="min-w-0">
          <%# t(...) で ja.yml の日本語メッセージを安全に呼び出す（i18n） %>
          <p class="text-sm font-semibold text-blue-800"><%= t("dashboards.index.analysis_pending") %></p>
          <p class="text-xs text-blue-600 mt-0.5"><%= t("dashboards.index.analysis_pending_sub") %></p>
        </div>
      </div>
    </div>
  <% elsif @reflection_crisis_skipped %>
    <%#
      ── ブランチ②【H-10 新設】危機介入によりAI分析を「見送った」ときの温かい案内バナー ──

      【なぜこのブランチが必要か】
        危機ワード検出時（D-5）は AI分析をあえてスキップする。修正前はこのレコードを
        「分析中」と誤判定してスピナーが永久表示された。ここで「分析中」ではなく
        「見送った」ことを、責めない温かい言葉で伝える。

      【id を他ブランチと同じにする理由】
        if / elsif / else はどれか1つしか描画されないため、画面上の
        dashboard_reflection_completion_banner は常に1つだけになる（同一 id が2つ
        存在すると Turbo の DOM 整合性が崩れるため、必ず1つに保つ）。

      【✖ボタン（閉じる）を付けない理由】
        このバナーは「分析中スピナー」の置き換え相当で、閉じ状態を保存する専用カラムを
        持たない最小構成にしている（完了バナーのような dismissible 化は DB 変更を伴うため
        本ISSUEのスコープ外）。
    %>
    <div id="dashboard_reflection_completion_banner" data-testid="reflection-crisis-skipped">
      <div class="mb-6 flex items-start gap-3 px-4 py-3
                  bg-amber-50 border border-amber-200 rounded-xl"
           role="status" aria-live="polite">
        <span class="text-xl flex-shrink-0" aria-hidden="true">💛</span>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-amber-800"><%= t("dashboards.index.crisis_skipped") %></p>
          <p class="text-xs text-amber-700 mt-0.5"><%= t("dashboards.index.crisis_skipped_sub") %></p>
          <% if @latest_completed_reflection %>
            <%# ユーザーが自分の振り返り本文にはいつでもアクセスできるよう詳細ページへのリンクを置く %>
            <%= link_to t("dashboards.index.view_reflection"),
                  weekly_reflection_path(@latest_completed_reflection),
                  class: "mt-1 inline-block text-xs font-bold text-amber-800 hover:underline
                          focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-1 rounded" %>
          <% end %>
        </div>
      </div>
    </div>
  <% elsif @show_reflection_completion_banner %>
    <%#
      ── ブランチ③: H-9。分析完了済み かつ 未確認（✖で閉じていない or 閉じた後に再分析）
      のときだけ完了バナーを復元表示する。危機スキップ時は上の elsif で処理済みのため
      ここには来ない（＝完了バナーの既存挙動は不変）。
    %>
    <div id="dashboard_reflection_completion_banner" data-testid="reflection-completion">
      <%= render "dashboards/reflection_completion_banner",
            reflection:  @latest_completed_reflection,
            ai_analysis: @reflection_ai_analysis %>
    </div>
  <% else %>
    <%# ── ブランチ④: 表示すべきバナーが無い場合。Turbo Stream が後から差し込めるよう空divを残す ── %>
    <div id="dashboard_reflection_completion_banner"></div>
  <% end %>

  <%# ── PDCA強制ロック警告バナー ──────────────────────────────────────── %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">⚠️ 先週の振り返りが未完了のため、一部の操作が制限されています</p>
          <p class="text-xs text-orange-700 mt-1">習慣の新規追加・削除はできません。振り返りを完了すると制限が解除されます。</p>
          <%= link_to "今すぐ振り返る →", new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">ダッシュボード</h1>

  <%# ── 今週の習慣達成率サマリーカード ──────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      今週の習慣達成率（月曜〜今日）
    </h2>

    <% if @habits.empty? %>
      <%#
        習慣0件のとき: 共通 Empty State パーシャルで CTA を表示する。

        【ロック中のガード】
          ロック中は習慣を追加できないため cta_label / cta_path を渡さない。
          _empty_state.html.erb は cta_label が nil のときボタンを非表示にする設計。

        【render partial: locals: を使う理由】
          将来名前空間が増えたときの解決失敗リスクを防ぐため明示的な書き方にする。
          render "shared/empty_state" の省略記法でも動作するが
          partial: locals: の方が「パーシャルにローカル変数を渡している」という
          意図がコードを読む人に明確に伝わる。
      %>
      <% if @locked %>
        <%= render partial: "shared/empty_state", locals: {
              icon:        "📊",
              title:       "まだ習慣が登録されていません",
              description: "振り返りを完了後、習慣を追加できます",
              testid:      "dashboard-habits-empty-state"
            } %>
      <% else %>
        <%= render partial: "shared/empty_state", locals: {
              icon:        "📊",
              title:       "まだ習慣が登録されていません",
              description: "最初の習慣を登録して、記録を始めましょう",
              cta_label:   "最初の習慣を追加する",
              cta_path:    new_habit_path,
              testid:      "dashboard-habits-empty-state"
            } %>
      <% end %>
    <% else %>
      <div class="mb-4">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm text-gray-600">全体達成率</span>
          <span class="text-sm font-bold"
                style="color: <%= rate_hex_color(@overall_rate) %>">
            <%= @overall_rate %>%
          </span>
        </div>
        <div class="h-3 bg-gray-200 rounded-full overflow-hidden"
             role="progressbar"
             aria-valuenow="<%= @overall_rate %>"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-label="全体の習慣達成率">
          <div class="h-3 rounded-full transition-all duration-300"
               style="width: <%= @overall_rate %>%; background-color: <%= rate_hex_color(@overall_rate) %>">
          </div>
        </div>
      </div>

      <% @habits.each do |habit| %>
        <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0, numeric_sum: nil } %>
        <%= render "dashboards/habit_stat_row",
              habit:  habit,
              stats:  stats %>
      <% end %>
    <% end %>
  </div>

  <%# ── C-6: 今週のタスク達成率（Must/Should/Could 別）──────────────── %>
  <% if @task_priority_stats.any? { |_, s| s[:total] > 0 } %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6"
         data-testid="task-priority-stats-section">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">
          今週のタスク達成率
        </h2>
        <%= link_to "すべて見る →", tasks_path,
              class: "text-xs text-blue-600 hover:underline" %>
      </div>

      <% priority_display = {
           "must"   => { label: "Must",   bar_color: "#ef4444", badge_class: "bg-red-100 text-red-700",     testid: "must" },
           "should" => { label: "Should", bar_color: "#3b82f6", badge_class: "bg-blue-100 text-blue-700",   testid: "should" },
           "could"  => { label: "Could",  bar_color: "#10b981", badge_class: "bg-green-100 text-green-700", testid: "could" }
         } %>

      <% priority_display.each do |priority_key, display| %>
        <% stats = @task_priority_stats[priority_key] || { total: 0, done: 0, rate: 0 } %>
        <% next if stats[:total].zero? %>

        <div class="mb-4 last:mb-0"
             data-testid="priority-row-<%= display[:testid] %>">
          <div class="flex justify-between items-center mb-1 gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded flex-shrink-0
                         <%= display[:badge_class] %>"
                  data-testid="priority-badge-<%= display[:testid] %>">
              <%= display[:label] %>
            </span>
            <span class="text-sm text-gray-600 flex-1"
                  data-testid="priority-count-<%= display[:testid] %>">
              <%= stats[:done] %>/<%= stats[:total] %>件 完了
            </span>
            <span class="text-sm font-bold flex-shrink-0"
                  style="color: <%= rate_hex_color(stats[:rate]) %>"
                  data-testid="priority-rate-<%= display[:testid] %>">
              <%= stats[:rate] %>%
            </span>
          </div>
          <div class="h-3 bg-gray-200 rounded-full overflow-hidden"
               role="progressbar"
               aria-valuenow="<%= stats[:rate] %>"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-label="<%= display[:label] %>タスクの達成率">
            <div class="h-3 rounded-full transition-all duration-500"
                 style="width: <%= stats[:rate] %>%;
                        background-color: <%= display[:bar_color] %>;">
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── 今日の習慣チェックリスト ──────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">今日の習慣チェック</h2>
      <% if @locked %>
        <span class="text-xs text-green-600 bg-green-50 px-2 py-1 rounded">✓ 記録は可能です</span>
      <% end %>
    </div>

    <%# G-4 追加: お休みモード中のバナー %>
    <% if @user_setting&.rest_mode_active? %>
      <div class="mb-4 bg-green-50 border border-green-200 rounded-lg p-3
                  flex items-center gap-2"
           data-testid="rest-mode-dashboard-banner">
        <span class="text-base flex-shrink-0" aria-hidden="true">😴</span>
        <div>
          <p class="text-xs font-semibold text-green-800">
            <% until_date = @user_setting.rest_mode_until %>
            お休みモード中
            <% if until_date %>
              （〜<%= l(until_date.to_date, format: :long) %>）
            <% end %>
          </p>
          <p class="text-xs text-green-600">
            適用 ON の習慣のストリークが維持されています 🔥
          </p>
        </div>
        <%= link_to rest_mode_settings_path,
              class: "ml-auto text-xs text-green-700 hover:underline flex-shrink-0" do %>
          設定 →
        <% end %>
      </div>
    <% end %>

    <% @habits.each do |habit| %>
      <% if @user_setting&.rest_mode_active? && habit.allow_rest_mode %>
        <div class="flex items-center gap-2 py-1 px-2 mb-1
                    bg-green-50 border border-green-100 rounded-lg"
             data-testid="rest-mode-habit-badge-<%= habit.id %>">
          <span class="text-sm" aria-hidden="true">
            <%= habit.icon.presence || "📋" %>
          </span>
          <span class="text-xs font-medium text-green-800 flex-1 truncate">
            <%= habit.name %>
          </span>
          <span class="flex-shrink-0 inline-flex items-center gap-1
                       px-2 py-0.5 rounded-full text-xs font-semibold
                       bg-green-100 text-green-700">
            😴 休息中
          </span>
        </div>
      <% end %>

      <%= render "habit_records/habit_record",
            habit: habit,
            habit_record: @today_records_hash[habit.id] %>
    <% end %>
  </div>

  <%# ── 今日のタスク（C-1 追加）────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">今日のタスク</h2>
      <%= link_to "すべて見る →", tasks_path,
            class: "text-xs text-blue-600 hover:underline" %>
    </div>

    <% if @today_tasks.empty? %>
      <p class="text-sm text-gray-400">今日が期限のタスクはありません。</p>
    <% else %>
      <div class="space-y-2">
        <% @today_tasks.each do |task| %>
          <div class="flex items-center gap-3 py-2 border-b border-gray-100 last:border-b-0">
            <input type="checkbox"
                   class="w-4 h-4 rounded border-gray-300 cursor-not-allowed"
                   <%= "checked" if task.done? || task.archived? %>
                   disabled
                   aria-label="<%= task.title %>">
            <span class="flex-shrink-0 text-xs font-bold px-1.5 py-0.5 rounded
                         <%= task.must? ? 'bg-red-100 text-red-700' : task.should? ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
              <%= task.must? ? "Must" : task.should? ? "Should" : "Could" %>
            </span>
            <span class="flex-1 text-sm text-gray-700 truncate
                         <%= task.done? || task.archived? ? 'line-through text-gray-400' : '' %>">
              <%= task.title %>
            </span>
            <% if task.overdue? %>
              <span class="flex-shrink-0 text-xs text-red-600 font-semibold">期限切れ</span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% unless @locked %>
      <div class="mt-3 pt-3 border-t border-gray-100">
        <%= link_to "+ タスクを追加", new_task_path,
              class: "text-xs text-blue-600 hover:underline" %>
      </div>
    <% end %>
  </div>

  <%# ── クイックリンク ──────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to habits_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">📊</span>
        <div>
          <p class="font-bold text-gray-800">習慣管理</p>
          <p class="text-xs text-gray-500">習慣の確認・管理</p>
        </div>
      </div>
    <% end %>
    <%= link_to weekly_reflections_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow #{'border-orange-300 bg-orange-50' if @locked}" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔄</span>
        <div>
          <p class="font-bold text-gray-800">
            週次振り返り
            <% if @locked %>
              <span class="ml-1 text-xs text-orange-600 bg-orange-100 px-1.5 py-0.5 rounded">要対応</span>
            <% end %>
          </p>
          <p class="text-xs text-gray-500">週のPDCAを振り返る</p>
        </div>
      </div>
    <% end %>
  </div>

</div>

<%# D-5: 危機介入モーダル %>
<%= render "shared/crisis_intervention_modal" %>

<%# D-6: AI コスト上限モーダル %>
<%= render "weekly_reflections/ai_limit_modal" %>