<%# app/views/dashboards/index.html.erb %>
<% content_for :title, "ダッシュボード | HabitFlow" %>
<%#
  ═══════════════════════════════════════════════════════════════════
  【このファイルの役割】
    ダッシュボードのメインビュー。
    @locked が true の場合は警告バナーを表示し、
    習慣チェックリストはロック中でも使用できます。

  【単位表示の修正内容】
    修正前: チェック型・数値型どちらも「日」と決め打ちしていた
            例: 「6/7日（85%）」← 数値型（読書/冊）でも「日」になっていた

    修正後: habit.check_type? で分岐して単位を出し分ける
            チェック型 → 「3/7日」（completed_count を使う）
            数値型     → 「6/7冊」（numeric_sum と habit.unit を使う）

  【なぜ分岐が必要なのか】
    チェック型と数値型では「何を記録するか」が根本的に異なる。
      チェック型: やった日数を数える → completed_count（0〜7）
      数値型:     累計値を合計する   → numeric_sum（例: 6.0冊）
    同じ変数・同じ単位で表示すると誤った情報をユーザーに見せてしまうため、
    habit の種類に応じて表示を切り替える必要がある。
  ═══════════════════════════════════════════════════════════════════
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ============================================================ %>
  <%# PDCA強制ロック警告バナー %>
  <%# ============================================================ %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">
            ⚠️ 先週の振り返りが未完了のため、一部の操作が制限されています
          </p>
          <p class="text-xs text-orange-700 mt-1">
            習慣の新規追加・削除はできません。振り返りを完了すると制限が解除されます。
          </p>
          <%= link_to "今すぐ振り返る →",
                new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ============================================================ %>
  <%# ページタイトル %>
  <%# ============================================================ %>
  <h1 class="text-2xl font-bold text-gray-900 mb-6">ダッシュボード</h1>

  <%# ============================================================ %>
  <%# 今週の達成率サマリーカード %>
  <%# ============================================================ %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      今週の達成率（月曜〜今日）
    </h2>

    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">まだ習慣が登録されていません。</p>
    <% else %>
      <%# 全体達成率 %>
      <div class="mb-4">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm text-gray-600">全体達成率</span>
          <span class="text-sm font-bold text-blue-600"><%= @overall_rate %>%</span>
        </div>
        <div class="h-3 bg-gray-200 rounded-full overflow-hidden"
             role="progressbar"
             aria-valuenow="<%= @overall_rate %>"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-label="全体の習慣達成率">
          <div class="h-3 rounded-full transition-all duration-300
                      <%= @overall_rate >= 80 ? 'bg-green-500' : @overall_rate >= 50 ? 'bg-blue-500' : 'bg-red-400' %>"
               style="width: <%= @overall_rate %>%">
          </div>
        </div>
      </div>

      <%# 習慣ごとの達成率 %>
      <% @habits.each do |habit| %>
        <%#
          @habit_stats[habit.id] には以下のキーが入っている（dashboards_controller.rb で設定）:
            チェック型: { rate: 整数, completed_count: 整数, numeric_sum: nil }
            数値型:     { rate: 整数, completed_count: nil, numeric_sum: 小数 }
          || {} はデータが存在しない場合に空ハッシュを返す（エラー防止）。
        %>
        <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0, numeric_sum: nil } %>
        <div class="mb-3">
          <div class="flex justify-between items-center mb-1 gap-2">
            <%#
              習慣名
              flex-1 min-w-0 truncate: 長い名前は「...」で省略してレイアウトを守る
            %>
            <span class="text-sm text-gray-700 flex-1 min-w-0 truncate">
              <%= habit.name %>
            </span>

            <%# ── 【修正箇所】単位を habit の種類に応じて切り替える ──────────────
              修正前: = stats[:completed_count] /= habit.weekly_target 日
                      → チェック型・数値型どちらも「日」と固定されていた
                      → 数値型の読書（冊）でも「日」と表示されてしまっていた

              修正後: habit.check_type? で分岐
                チェック型: completed_count（実施した日数）と「日」を表示
                            例: 「5/7日（71%）」
                数値型:     numeric_sum（今週の累計）と habit.unit（登録した単位）を表示
                            例: 「6.0/7冊（85%）」

              format("%g", ...) とは？
                小数点以下の不要なゼロを削除するフォーマット指定子。
                例: format("%g", 6.0) → "6"（末尾の .0 が消える）
                    format("%g", 6.5) → "6.5"（必要な小数は残る）
                これにより「6.0冊」ではなく「6冊」と自然な表示になる。

              habit.unit.presence || "回":
                unit が nil や空文字の場合は「回」をデフォルト単位として使う。
                presence は nil や "" を nil に統一するメソッド。
            %>
            <span class="text-xs text-gray-500 flex-shrink-0 whitespace-nowrap">
              <% if habit.check_type? %>
                <%# チェック型: 実施した日数を表示 %>
                <%= stats[:completed_count] %>/<%= habit.weekly_target %>日
                （<%= stats[:rate] %>%）
              <% else %>
                <%# 数値型: 今週の累計と登録した単位を表示 %>
                <%= format("%g", (stats[:numeric_sum] || 0).round(1)) %>/<%= habit.weekly_target %><%= habit.unit.presence || "回" %>
                （<%= stats[:rate] %>%）
              <% end %>
            </span>
            <%# ────────────────────────────────────────────────────────────────── %>

          </div>
          <div class="h-2 bg-gray-200 rounded-full overflow-hidden"
               role="progressbar"
               aria-valuenow="<%= stats[:rate] %>"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-label="<%= habit.name %> の今週の達成率">
            <div class="h-2 rounded-full transition-all duration-300
                        <%= stats[:rate] >= 80 ? 'bg-green-500' : stats[:rate] >= 50 ? 'bg-blue-400' : 'bg-red-400' %>"
                 style="width: <%= stats[:rate] %>%">
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ============================================================ %>
  <%# 今日の習慣チェックリスト %>
  <%# ============================================================ %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">
        今日の習慣チェック
      </h2>
      <% if @locked %>
        <span class="text-xs text-green-600 bg-green-50 px-2 py-1 rounded">
          ✓ 記録は可能です
        </span>
      <% end %>
    </div>

    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">
        習慣がまだ登録されていません。
        <% if @locked %>
          <span class="text-gray-400">（振り返り完了後に習慣を追加できます）</span>
        <% else %>
          <%= link_to "習慣を登録する", new_habit_path, class: "text-blue-600 hover:underline" %>
        <% end %>
      </p>
    <% else %>
      <% @habits.each do |habit| %>
        <%= render "habit_records/habit_record",
              habit: habit,
              habit_record: @today_records_hash[habit.id] %>
      <% end %>
    <% end %>
  </div>

  <%# ============================================================ %>
  <%# クイックリンク %>
  <%# grid-cols-1 sm:grid-cols-2: モバイルは1列、640px以上は2列 %>
  <%# ============================================================ %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to habits_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">📊</span>
        <div>
          <p class="font-bold text-gray-800">習慣管理</p>
          <p class="text-xs text-gray-500">習慣の確認・管理</p>
        </div>
      </div>
    <% end %>

    <%= link_to weekly_reflections_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow #{'border-orange-300 bg-orange-50' if @locked}" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔄</span>
        <div>
          <p class="font-bold text-gray-800">
            週次振り返り
            <% if @locked %>
              <span class="ml-1 text-xs text-orange-600 bg-orange-100 px-1.5 py-0.5 rounded">要対応</span>
            <% end %>
          </p>
          <p class="text-xs text-gray-500">週のPDCAを振り返る</p>
        </div>
      </div>
    <% end %>
  </div>

</div>
