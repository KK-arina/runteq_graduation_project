<%# app/views/dashboards/index.html.erb %>
<%#
  ダッシュボード画面。
  今週の習慣達成率・今日の習慣チェック・タスク優先度別達成率・今日のタスクを表示する。

  【C-6 変更点】
    「今週のタスク達成率」セクションを追加。
    @task_priority_stats を使い Must / Should / Could の達成率プログレスバーを表示する。
    total が 0 の優先度は行ごと非表示。全て 0 件の場合はカード全体を非表示にする。
    data-testid 属性を各要素に付与してテストから正確に参照できるようにする。
%>
<% content_for :title, "ダッシュボード | HabitFlow" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ── PDCA強制ロック警告バナー ──────────────────────────────────────── %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">⚠️ 先週の振り返りが未完了のため、一部の操作が制限されています</p>
          <p class="text-xs text-orange-700 mt-1">習慣の新規追加・削除はできません。振り返りを完了すると制限が解除されます。</p>
          <%= link_to "今すぐ振り返る →", new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">ダッシュボード</h1>

  <%# ── 今週の習慣達成率サマリーカード ──────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      今週の習慣達成率（月曜〜今日）
    </h2>

    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">まだ習慣が登録されていません。</p>
    <% else %>
      <div class="mb-4">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm text-gray-600">全体達成率</span>
          <span class="text-sm font-bold text-blue-600"><%= @overall_rate %>%</span>
        </div>
        <div class="h-3 bg-gray-200 rounded-full overflow-hidden"
             role="progressbar"
             aria-valuenow="<%= @overall_rate %>"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-label="全体の習慣達成率">
          <div class="h-3 rounded-full transition-all duration-300
                      <%= @overall_rate >= 80 ? 'bg-green-500' : @overall_rate >= 50 ? 'bg-blue-500' : 'bg-red-400' %>"
               style="width: <%= @overall_rate %>%">
          </div>
        </div>
      </div>

      <% @habits.each do |habit| %>
        <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0, numeric_sum: nil } %>
        <div class="mb-3">
          <div class="flex justify-between items-center mb-1 gap-2">
            <span class="text-sm text-gray-700 flex-1 min-w-0 flex items-center gap-2">
              <span aria-hidden="true" class="flex-shrink-0"><%= habit.icon.presence || "📋" %></span>
              <span class="truncate"><%= habit.name %></span>
              <% if habit.current_streak > 0 %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold flex-shrink-0
                             <%= habit.current_streak >= 7 ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700' %>">
                  🔥 <%= habit.current_streak %>日
                </span>
              <% end %>
            </span>
            <span class="text-xs text-gray-500 flex-shrink-0 whitespace-nowrap">
              <% if habit.check_type? %>
                <%= stats[:completed_count] %>/<%= habit.weekly_target %>日（<%= stats[:rate] %>%）
              <% else %>
                <%= format("%g", (stats[:numeric_sum] || 0).round(1)) %>/<%= habit.weekly_target %><%= habit.unit.presence || "回" %>（<%= stats[:rate] %>%）
              <% end %>
            </span>
          </div>
          <div class="h-2 bg-gray-200 rounded-full overflow-hidden"
               role="progressbar"
               aria-valuenow="<%= stats[:rate] %>"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-label="<%= habit.name %> の今週の達成率">
            <div class="h-2 rounded-full transition-all duration-300"
                 style="width: <%= stats[:rate] %>%;
                        background-color: <%= habit.color.presence || (stats[:rate] >= 80 ? '#22c55e' : stats[:rate] >= 50 ? '#60a5fa' : '#f87171') %>">
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ================================================================== %>
  <%# ── C-6: 今週のタスク達成率（Must/Should/Could 別）──────────────── %>
  <%# ================================================================== %>
  <%#
    @task_priority_stats には優先度別の統計情報が入っている。
    構造例: { "must" => { total: 3, done: 2, rate: 66 }, ... }

    any? { |_, s| s[:total] > 0 } で「1件でも表示対象があるか」を判定する。
    _ はハッシュのキー（使わないので _ で捨てる）、
    s は統計ハッシュ（{ total:, done:, rate: }）。
    全て 0 件の場合はカード全体を非表示にする。

    data-testid="task-priority-stats-section" をカード外枠に付与することで
    テストからセクション全体の表示・非表示を正確に検証できる。
  %>
  <% if @task_priority_stats.any? { |_, s| s[:total] > 0 } %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6"
         data-testid="task-priority-stats-section">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">
          今週のタスク達成率
        </h2>
        <%= link_to "すべて見る →", tasks_path,
              class: "text-xs text-blue-600 hover:underline" %>
      </div>

      <%#
        優先度ごとの表示設定を定義するハッシュ。
        label      : 画面に表示するラベル文字列
        bar_color  : プログレスバーの色（インラインスタイルで使用）
        badge_class: 優先度バッジの Tailwind クラス
        testid     : data-testid の suffix（テストで各行を識別するために使う）

        Tailwind は動的なクラス名をビルド時に静的解析するため、
        変数を使った動的クラスは生成できない。
        そのため badge_class には完全なクラス文字列を直接書く。
        bar_color は CSS の color 値なのでインラインスタイルで指定する。
      %>
      <% priority_display = {
           "must"   => { label: "Must",   bar_color: "#ef4444", badge_class: "bg-red-100 text-red-700",   testid: "must" },
           "should" => { label: "Should", bar_color: "#3b82f6", badge_class: "bg-blue-100 text-blue-700", testid: "should" },
           "could"  => { label: "Could",  bar_color: "#10b981", badge_class: "bg-green-100 text-green-700", testid: "could" }
         } %>

      <% priority_display.each do |priority_key, display| %>
        <%#
          修正④: nil 安全化。
          @task_priority_stats[priority_key] が nil の場合に備えて
          || でデフォルト値を設定する。
          通常は必ず値が入るが、将来のバグ防止のために書いておく。
        %>
        <% stats = @task_priority_stats[priority_key] || { total: 0, done: 0, rate: 0 } %>

        <%#
          total が 0 の優先度はスキップする（行ごと非表示）。
          今週このカテゴリのタスクがない場合はプログレスバーを出さない。
          next はブロックの残り処理をスキップして次のループに進む。
        %>
        <% next if stats[:total].zero? %>

        <%#
          data-testid を各行の外枠 div に付与する。
          例: data-testid="priority-row-must"
          テストでは "[data-testid='priority-row-must']" で行全体を特定できる。
        %>
        <div class="mb-4 last:mb-0"
             data-testid="priority-row-<%= display[:testid] %>">
          <div class="flex justify-between items-center mb-1 gap-2">

            <%#
              優先度ラベルのバッジ。
              data-testid="priority-badge-must" などを付与することで
              テストから「Must バッジが表示されているか」を正確に検証できる。
              "span" だけのセレクタだとページ全体の span にマッチしてしまうため
              data-testid による絞り込みが必要。
            %>
            <span class="text-xs font-bold px-2 py-0.5 rounded flex-shrink-0
                         <%= display[:badge_class] %>"
                  data-testid="priority-badge-<%= display[:testid] %>">
              <%= display[:label] %>
            </span>

            <%#
              達成件数と総件数を表示する（例: 2/3件 完了）。
              data-testid="priority-count-must" で件数表示を特定できる。
            %>
            <span class="text-sm text-gray-600 flex-1"
                  data-testid="priority-count-<%= display[:testid] %>">
              <%= stats[:done] %>/<%= stats[:total] %>件 完了
            </span>

            <%#
              達成率を右端に表示する。
              80% 以上は緑（順調）、50% 以上は青（普通）、未満は赤（要改善）で色分けする。
              data-testid="priority-rate-must" で達成率テキストを特定できる。
            %>
            <span class="text-sm font-bold flex-shrink-0
                         <%= stats[:rate] >= 80 ? 'text-green-600' : stats[:rate] >= 50 ? 'text-blue-600' : 'text-red-500' %>"
                  data-testid="priority-rate-<%= display[:testid] %>">
              <%= stats[:rate] %>%
            </span>
          </div>

          <%#
            プログレスバー本体。

            外枠（グレーの背景）:
              role="progressbar" → スクリーンリーダーに「進捗バー」であることを伝える。
              aria-valuenow     → 現在の達成率をスクリーンリーダーに伝える。
              aria-valuemin/max → 最小値0・最大値100を示す。
              aria-label        → 何の達成率かをスクリーンリーダーに伝える。

            内側（色付きバー）:
              style="width: ..." → 達成率に応じてバーの幅を変える。
              background-color  → 優先度ごとの色をインラインスタイルで指定する。
              transition-all duration-500 → ページ読み込み時にバーが伸びるアニメーション。
          %>
          <div class="h-3 bg-gray-200 rounded-full overflow-hidden"
               role="progressbar"
               aria-valuenow="<%= stats[:rate] %>"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-label="<%= display[:label] %>タスクの達成率">
            <div class="h-3 rounded-full transition-all duration-500"
                 style="width: <%= stats[:rate] %>%;
                        background-color: <%= display[:bar_color] %>;">
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── 今日の習慣チェックリスト ──────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">今日の習慣チェック</h2>
      <% if @locked %>
        <span class="text-xs text-green-600 bg-green-50 px-2 py-1 rounded">✓ 記録は可能です</span>
      <% end %>
    </div>
    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">
        習慣がまだ登録されていません。
        <% if @locked %>
          <span class="text-gray-400">（振り返り完了後に習慣を追加できます）</span>
        <% else %>
          <%= link_to "習慣を登録する", new_habit_path, class: "text-blue-600 hover:underline" %>
        <% end %>
      </p>
    <% else %>
      <% @habits.each do |habit| %>
        <%= render "habit_records/habit_record",
              habit: habit,
              habit_record: @today_records_hash[habit.id] %>
      <% end %>
    <% end %>
  </div>

  <%# ── 今日のタスク（C-1 追加）────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">今日のタスク</h2>
      <%= link_to "すべて見る →", tasks_path,
            class: "text-xs text-blue-600 hover:underline" %>
    </div>

    <% if @today_tasks.empty? %>
      <p class="text-sm text-gray-400">今日が期限のタスクはありません。</p>
    <% else %>
      <div class="space-y-2">
        <% @today_tasks.each do |task| %>
          <div class="flex items-center gap-3 py-2 border-b border-gray-100 last:border-b-0">
            <input type="checkbox"
                   class="w-4 h-4 rounded border-gray-300 cursor-not-allowed"
                   <%= "checked" if task.done? || task.archived? %>
                   disabled
                   aria-label="<%= task.title %>">
            <span class="flex-shrink-0 text-xs font-bold px-1.5 py-0.5 rounded
                         <%= task.must? ? 'bg-red-100 text-red-700' : task.should? ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
              <%= task.must? ? "Must" : task.should? ? "Should" : "Could" %>
            </span>
            <span class="flex-1 text-sm text-gray-700 truncate
                         <%= task.done? || task.archived? ? 'line-through text-gray-400' : '' %>">
              <%= task.title %>
            </span>
            <% if task.overdue? %>
              <span class="flex-shrink-0 text-xs text-red-600 font-semibold">期限切れ</span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% unless @locked %>
      <div class="mt-3 pt-3 border-t border-gray-100">
        <%= link_to "+ タスクを追加", new_task_path,
              class: "text-xs text-blue-600 hover:underline" %>
      </div>
    <% end %>
  </div>

  <%# ── クイックリンク ──────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to habits_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">📊</span>
        <div>
          <p class="font-bold text-gray-800">習慣管理</p>
          <p class="text-xs text-gray-500">習慣の確認・管理</p>
        </div>
      </div>
    <% end %>
    <%= link_to weekly_reflections_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow #{'border-orange-300 bg-orange-50' if @locked}" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔄</span>
        <div>
          <p class="font-bold text-gray-800">
            週次振り返り
            <% if @locked %>
              <span class="ml-1 text-xs text-orange-600 bg-orange-100 px-1.5 py-0.5 rounded">要対応</span>
            <% end %>
          </p>
          <p class="text-xs text-gray-500">週のPDCAを振り返る</p>
        </div>
      </div>
    <% end %>
  </div>

</div>