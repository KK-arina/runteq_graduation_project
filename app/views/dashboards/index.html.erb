<%# app/views/dashboards/index.html.erb %>
<%#
  ═══════════════════════════════════════════════════════════════════
  【このファイルの役割】
    ダッシュボードのメインビュー。
    @locked が true の場合は警告バナーを表示し、
    習慣チェックリストはロック中でも使用できます。

  【Issue #26 で修正した箇所】
    1. 習慣名の truncate max-w-xs → max-w-[120px] sm:max-w-xs
       モバイルで長い習慣名が達成率表示と重なる問題を修正
    2. クイックリンクグリッドは grid-cols-1 sm:grid-cols-2 で既存対応済み
    3. ロックバナーのレイアウトをモバイルで縦積みに調整
  ═══════════════════════════════════════════════════════════════════
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ============================================================ %>
  <%# PDCA強制ロック警告バナー %>
  <%# ============================================================ %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <%# 警告アイコン（SVG） %>
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>

        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">
            ⚠️ 先週の振り返りが未完了のため、一部の操作が制限されています
          </p>
          <p class="text-xs text-orange-700 mt-1">
            習慣の新規追加・削除はできません。振り返りを完了すると制限が解除されます。
          </p>
          <%= link_to "今すぐ振り返る →",
                new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ============================================================ %>
  <%# ページタイトル %>
  <%# ============================================================ %>
  <h1 class="text-2xl font-bold text-gray-900 mb-6">ダッシュボード</h1>

  <%# ============================================================ %>
  <%# 今週の達成率サマリーカード %>
  <%# ============================================================ %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4">
      今週の達成率（月曜〜今日）
    </h2>

    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">まだ習慣が登録されていません。</p>
    <% else %>
      <%# 全体達成率 %>
      <div class="mb-4">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm text-gray-600">全体達成率</span>
          <span class="text-sm font-bold text-blue-600"><%= @overall_rate %>%</span>
        </div>
        <div class="h-3 bg-gray-200 rounded-full overflow-hidden">
          <div class="h-3 rounded-full transition-all duration-300
                      <%= @overall_rate >= 80 ? 'bg-green-500' : @overall_rate >= 50 ? 'bg-blue-500' : 'bg-red-400' %>"
               style="width: <%= @overall_rate %>%">
          </div>
        </div>
      </div>

      <%# 習慣ごとの達成率 %>
      <% @habits.each do |habit| %>
        <% stats = @habit_stats[habit.id] || { rate: 0, completed_count: 0 } %>
        <div class="mb-3">
          <%#
            習慣名と達成率を横並びにするエリア
            flex: 横並び
            justify-between: 左端（習慣名）と右端（達成率）に振り分け
            items-center: 縦方向中央揃え
          %>
          <div class="flex justify-between items-center mb-1 gap-2">
            <%#
              習慣名
              flex-1: 残りのスペースをすべて使う（達成率部分は flex-shrink-0 で固定幅）
              min-w-0: flex-1 が正しく truncate するために必要
                       flex アイテムはデフォルトで min-w がコンテンツ幅になり、
                       truncate が効かないことがある
              truncate: テキストが長すぎる場合は「...」で省略
            %>
            <span class="text-sm text-gray-700 flex-1 min-w-0 truncate">
              <%= habit.name %>
            </span>
            <%#
              達成率テキスト
              flex-shrink-0: 画面幅が小さくても幅を縮めない（押しつぶされない）
              ml-2: 習慣名との間に余白
              text-xs: 12px（小さめのテキスト）
              whitespace-nowrap: 改行させない（数字と単位が分かれないようにする）
            %>
            <span class="text-xs text-gray-500 flex-shrink-0 whitespace-nowrap">
              <%= stats[:completed_count] %>/<%= habit.weekly_target %>日
              （<%= stats[:rate] %>%）
            </span>
          </div>
          <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-2 rounded-full transition-all duration-300
                        <%= stats[:rate] >= 80 ? 'bg-green-500' : stats[:rate] >= 50 ? 'bg-blue-400' : 'bg-red-400' %>"
                 style="width: <%= stats[:rate] %>%">
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ============================================================ %>
  <%# 今日の習慣チェックリスト %>
  <%# ============================================================ %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wide">
        今日の習慣チェック
      </h2>
      <% if @locked %>
        <span class="text-xs text-green-600 bg-green-50 px-2 py-1 rounded">
          ✓ 記録は可能です
        </span>
      <% end %>
    </div>

    <% if @habits.empty? %>
      <p class="text-sm text-gray-400">
        習慣がまだ登録されていません。
        <% if @locked %>
          <span class="text-gray-400">（振り返り完了後に習慣を追加できます）</span>
        <% else %>
          <%= link_to "習慣を登録する", new_habit_path, class: "text-blue-600 hover:underline" %>
        <% end %>
      </p>
    <% else %>
      <% @habits.each do |habit| %>
        <%= render "habit_records/habit_record",
              habit: habit,
              habit_record: @today_records_hash[habit.id] %>
      <% end %>
    <% end %>
  </div>

  <%# ============================================================ %>
  <%# クイックリンク %>
  <%# grid-cols-1 sm:grid-cols-2: モバイルは1列、640px以上は2列 %>
  <%# ============================================================ %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= link_to habits_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">📊</span>
        <div>
          <p class="font-bold text-gray-800">習慣管理</p>
          <p class="text-xs text-gray-500">習慣の確認・管理</p>
        </div>
      </div>
    <% end %>

    <%= link_to weekly_reflections_path,
          class: "block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition-shadow #{'border-orange-300 bg-orange-50' if @locked}" do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔄</span>
        <div>
          <p class="font-bold text-gray-800">
            週次振り返り
            <% if @locked %>
              <span class="ml-1 text-xs text-orange-600 bg-orange-100 px-1.5 py-0.5 rounded">要対応</span>
            <% end %>
          </p>
          <p class="text-xs text-gray-500">週のPDCAを振り返る</p>
        </div>
      </div>
    <% end %>
  </div>

</div>