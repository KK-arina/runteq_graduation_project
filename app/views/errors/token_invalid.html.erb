<%# app/views/errors/token_invalid.html.erb %>
<%# ============================================================ %>
<%# 29番画面: トークン無効エラーページ %>
<%# ============================================================ %>
<%#
  【このビューの役割】
  パスワードリセットURLが無効（期限切れ・使用済み）の場合に表示するエラーページ。

  【表示される条件】
  PasswordResetsController の before_action validate_token が
  @token_record が nil または valid_token? が false の場合に
  render template: "errors/token_invalid" を呼ぶ。

  【なぜ errors/ ディレクトリに置くのか】
  ApplicationController の render_404 等と同じディレクトリに配置することで
  「エラー系のビュー」として整理できる。
  既存の errors/not_found.html.erb などと一貫した管理ができる。
%>
<% content_for :title, "リンクが無効です | HabitFlow" %>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">

  <%# エラーアイコン %>
  <div class="text-6xl mb-6">⏰</div>

  <h2 class="text-2xl font-bold text-gray-900 mb-4">
    リンクが無効または期限切れです
  </h2>

  <p class="text-gray-600 mb-2">
    このパスワードリセットリンクは以下の理由で使用できません：
  </p>

  <ul class="text-gray-600 text-sm mb-8 space-y-1 list-none">
    <li>✗ リンクの有効期限（24時間）が切れている</li>
    <li>✗ リンクがすでに使用済み</li>
    <li>✗ リンクが正しくコピーされていない</li>
  </ul>

  <%# 再申請ボタン %>
  <%= link_to "もう一度パスワードリセットを申請する",
      new_password_reset_path,
      class: "inline-block px-6 py-3 bg-blue-600 text-white rounded-md
              hover:bg-blue-700 transition font-medium" %>

  <div class="mt-4">
    <%= link_to "ログインページに戻る", login_path,
        class: "text-sm text-blue-600 hover:text-blue-700 hover:underline" %>
  </div>

</div>