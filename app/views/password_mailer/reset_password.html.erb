<%# app/views/password_mailer/reset_password.html.erb %>
<%#
  【このファイルの役割】
  パスワードリセットメールの HTML 版テンプレート。
  PasswordMailer#reset_password から参照される。

  【なぜ HTML と text の2種類作るのか】
  メールクライアントによって HTML を表示できないものがある。
  Rails のメイラーは同じ名前の .html.erb と .text.erb の両方があれば
  「multipart/alternative」形式で送信する。
  受信者のメールクライアントが HTML に対応していれば HTML 版を、
  未対応なら text 版を表示する（自動で切り替わる）。

  【インラインスタイルについて】
  メールクライアント（特に Gmail）は外部CSSや <style> タグを
  無視・削除することがある。
  このため style 属性にインラインで CSS を書く。
  Tailwind CSS はメールでは使えない（メールクライアントが未対応）。
%>
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <%#
    viewport メタタグ:
      モバイルでも読みやすいメールにするために必要。
      Gmail アプリなどスマートフォンのメールクライアントで
      コンテンツが小さく表示されるのを防ぐ。
  %>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>パスワードリセット | HabitFlow</title>
</head>

<%#
  body のインラインスタイル:
    font-family: メールクライアントで一般的なフォントを指定する。
    background-color: ページ全体の背景色（薄いグレー）。
    margin/padding: ブラウザのデフォルトスタイルを打ち消す。
%>
<body style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
             background-color: #f9fafb;
             margin: 0;
             padding: 0;">

  <%# 外側のコンテナ：中央寄せのための table レイアウト %>
  <%#
    【なぜ table を使うのか】
    div による CSS レイアウトはメールクライアントで崩れやすい。
    table は古いメールクライアントでも安定して表示される業界標準。
  %>
  <table width="100%" cellpadding="0" cellspacing="0"
         style="background-color: #f9fafb; padding: 32px 0;">
    <tr>
      <td align="center">
        <%# 本文カード %>
        <table width="600" cellpadding="0" cellspacing="0"
               style="background-color: #ffffff;
                      border-radius: 8px;
                      border: 1px solid #e5e7eb;
                      overflow: hidden;
                      max-width: 600px;
                      width: 100%;">

          <%# ヘッダー部分（青背景） %>
          <tr>
            <td style="background-color: #2563eb;
                       padding: 24px 32px;
                       text-align: center;">
              <h1 style="color: #ffffff;
                         font-size: 24px;
                         font-weight: bold;
                         margin: 0;">
                🔐 HabitFlow
              </h1>
            </td>
          </tr>

          <%# 本文 %>
          <tr>
            <td style="padding: 32px;">

              <%#
                @user.name について:
                  PasswordMailer#reset_password で設定したインスタンス変数。
                  ユーザーの名前をメール冒頭に表示して親しみやすくする。
                  html_escape （h） は XSS 対策のため常に使う。
                  ERB の = は自動エスケープしないため明示的に h() を呼ぶか、
                  ActionView で自動エスケープが有効な場合は = @user.name  でも安全。
                  メイラービューは ActionView を使うため =  で自動エスケープされる。
              %>
              <p style="font-size: 16px; color: #374151; margin: 0 0 16px;">
                <%= @user.name %> さん、こんにちは。
              </p>

              <p style="font-size: 15px; color: #374151; margin: 0 0 24px; line-height: 1.6;">
                HabitFlow のパスワードリセットのご依頼を受け付けました。<br>
                以下のボタンをクリックして、新しいパスワードを設定してください。
              </p>

              <%# リセットボタン %>
              <table cellpadding="0" cellspacing="0" style="margin: 0 auto 24px;">
                <tr>
                  <td style="background-color: #2563eb;
                             border-radius: 6px;
                             text-align: center;">
                    <%#
                      @reset_url について:
                        PasswordMailer#reset_password で設定したインスタンス変数。
                        edit_password_reset_url(raw_token) が返す絶対URL。
                        例: https://habitflow.onrender.com/password_resets/abc123/edit
                    %>
                    <a href="<%= @reset_url %>"
                       style="display: inline-block;
                              padding: 14px 32px;
                              color: #ffffff;
                              font-size: 16px;
                              font-weight: bold;
                              text-decoration: none;">
                      パスワードを再設定する
                    </a>
                  </td>
                </tr>
              </table>

              <%# URL が長い場合の代替テキスト %>
              <p style="font-size: 13px; color: #6b7280; margin: 0 0 16px; line-height: 1.6;">
                ボタンが機能しない場合は、以下のURLをコピーしてブラウザに貼り付けてください：
              </p>
              <p style="font-size: 12px;
                        color: #2563eb;
                        word-break: break-all;
                        margin: 0 0 24px;">
                <%= @reset_url %>
              </p>

              <%# 有効期限の注意書き %>
              <div style="background-color: #fef3c7;
                          border: 1px solid #fcd34d;
                          border-radius: 6px;
                          padding: 12px 16px;
                          margin-bottom: 24px;">
                <p style="font-size: 14px; color: #92400e; margin: 0;">
                  ⚠️ このリンクの有効期限は <strong>24時間</strong> です。
                  期限が切れた場合は、もう一度パスワードリセットをお申し込みください。
                </p>
              </div>

              <%# 注意書き %>
              <p style="font-size: 13px; color: #6b7280; margin: 0 0 8px; line-height: 1.6;">
                このメールに心当たりがない場合は、無視していただいて構いません。
                パスワードは変更されません。
              </p>

            </td>
          </tr>

          <%# フッター %>
          <tr>
            <td style="background-color: #f3f4f6;
                       padding: 16px 32px;
                       text-align: center;
                       border-top: 1px solid #e5e7eb;">
              <p style="font-size: 12px; color: #9ca3af; margin: 0;">
                © <%= Time.current.year %> HabitFlow. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>