<%# app/views/settings/show.html.erb %>
<%#
  ============================================================
  【このファイルの役割】
  アカウント設定ページ（M-4 退会確認モーダル付き）

  【G-4 での変更内容】
  - お休みモード設定へのナビゲーションセクションを追加

  【G-5 での変更内容】
  - CSVエクスポートセクションを追加（退会セクション直前）
  ============================================================
%>
<% content_for :title, "アカウント設定 | HabitFlow" %>

<div class="max-w-2xl mx-auto px-4 py-8">

  <h1 class="text-2xl font-bold text-gray-900 mb-8">アカウント設定</h1>

  <%# ── アカウント情報セクション ── %>
  <section class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">アカウント情報</h2>

    <dl class="space-y-3">
      <div class="flex items-center justify-between py-2 border-b border-gray-100">
        <dt class="text-sm font-medium text-gray-600">ユーザー名</dt>
        <dd class="text-sm text-gray-900"><%= @user.name %></dd>
      </div>

      <div class="flex items-center justify-between py-2 border-b border-gray-100">
        <dt class="text-sm font-medium text-gray-600">メールアドレス</dt>
        <dd class="text-sm text-gray-900">
          <%= @user.email.presence || "未設定（LINEログイン）" %>
        </dd>
      </div>

      <div class="flex items-center justify-between py-2">
        <dt class="text-sm font-medium text-gray-600">ログイン方法</dt>
        <dd class="text-sm text-gray-900">
          <%= case @user.provider
              when "google_oauth2" then "Google アカウント"
              when "line_v2_1"     then "LINE アカウント"
              else                      "メールアドレス"
              end %>
        </dd>
      </div>
    </dl>
  </section>

  <%# G-3 追加: 通知設定へのナビゲーションセクション %>
  <section class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">通知設定</h2>

    <%= link_to notification_settings_settings_path,
        class: "flex items-center justify-between p-4 rounded-lg border
                border-gray-200 hover:border-blue-300 hover:bg-blue-50
                transition-colors group
                focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
        aria: { label: "通知設定ページへ移動" } do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl" aria-hidden="true">🔔</span>
        <div>
          <p class="text-sm font-semibold text-gray-900
                    group-hover:text-blue-700 transition-colors">
            通知設定を管理する
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            LINE 通知・メール通知・週次レポート・通知上限数
          </p>
        </div>
      </div>
      <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 transition-colors"
           fill="none" stroke="currentColor" viewBox="0 0 24 24"
           aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <div class="mt-3 flex items-center gap-2">
      <% if current_user.line_user_id.present? %>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                     text-xs font-medium bg-green-100 text-green-700">
          ✅ LINE 連携済み
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                     text-xs font-medium bg-gray-100 text-gray-600">
          LINE 未連携
        </span>
      <% end %>
    </div>
  </section>

  <%# G-4 追加: お休みモード設定へのナビゲーションセクション %>
  <section class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">お休みモード</h2>

    <%= link_to rest_mode_settings_path,
        class: "flex items-center justify-between p-4 rounded-lg border
                border-gray-200 hover:border-green-300 hover:bg-green-50
                transition-colors group
                focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2",
        aria: { label: "お休みモード設定ページへ移動" } do %>
      <div class="flex items-center gap-3">
        <span class="text-2xl" aria-hidden="true">😴</span>
        <div>
          <p class="text-sm font-semibold text-gray-900
                    group-hover:text-green-700 transition-colors">
            お休みモード設定
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            旅行・病気・多忙な期間のストリーク維持
          </p>
        </div>
      </div>
      <svg class="w-5 h-5 text-gray-400 group-hover:text-green-500 transition-colors"
           fill="none" stroke="currentColor" viewBox="0 0 24 24"
           aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <div class="mt-3 flex items-center gap-2">
      <% if @user_setting&.rest_mode_active? %>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                     text-xs font-medium bg-green-100 text-green-700">
          😴 お休みモード中
        </span>
        <span class="text-xs text-gray-500">
          〜<%= l(@user_setting.rest_mode_until.to_date, format: :long) %>
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                     text-xs font-medium bg-gray-100 text-gray-600">
          通常モード
        </span>
      <% end %>
    </div>
  </section>

  <%# ============================================================
      G-5 追加: データエクスポートセクション
      お休みモードセクションの直後・退会セクションの直前に配置する。

      【Turbo Streamとの連携について】
        各ボタンは button_to（POSTリクエスト）でエクスポートを実行する。
        1000件以下: send_data で直接ファイルをダウンロード
        1000件超:   Turbo Streamでボタンを「生成中」状態に更新
        エラー時:   Turbo Streamでボタンを「エラー（再試行）」状態に更新
  ============================================================ %>
  <section class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-2">データエクスポート</h2>
    <p class="text-sm text-gray-500 mb-5">
      習慣記録・タスク・振り返りをCSV形式でダウンロードできます。
      ExcelでそのままB開ける形式（UTF-8 BOM付き）で出力します。<br>
      1,000件を超えるデータは、バックグラウンドで生成後にメールでご案内します。
    </p>

    <div class="space-y-3">
      <%# 習慣記録CSVエクスポートボタン %>
      <%# render partial を使う理由:
          Turbo Streamで差し替える対象になるため、パーシャルとして定義する。
          コントローラーの turbo_stream.replace のターゲットIDと
          パーシャル内の id 属性が対応している。 %>
      <%= render "settings/csv_export_button",
                 export_type: :habit_records,
                 state:       :idle,
                 label:       t("csv_exports.button.habit_records"),
                 count:       @habit_record_count %>

      <%# タスクCSVエクスポートボタン %>
      <%= render "settings/csv_export_button",
                 export_type: :tasks,
                 state:       :idle,
                 label:       t("csv_exports.button.tasks"),
                 count:       @task_count %>

      <%# 週次振り返りCSVエクスポートボタン %>
      <%= render "settings/csv_export_button",
                 export_type: :weekly_reflections,
                 state:       :idle,
                 label:       t("csv_exports.button.weekly_reflections"),
                 count:       @weekly_reflection_count %>
    </div>
  </section>

  <%# ── 危険ゾーン: 退会セクション ── %>
  <section class="bg-white rounded-lg shadow-sm border-2 border-red-200 p-6">
    <h2 class="text-lg font-semibold text-red-700 mb-2">退会（アカウント削除）</h2>
    <p class="text-sm text-gray-600 mb-4">
      退会すると、個人識別情報は即時に匿名化されます。この操作は取り消せません。
    </p>

    <button type="button"
            class="px-4 py-2 text-sm font-medium text-white bg-red-600
                   rounded-md hover:bg-red-700 transition-colors
                   focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2"
            onclick="document.getElementById('deactivate-modal').classList.remove('hidden'); document.body.classList.add('overflow-hidden');">
      退会する
    </button>
  </section>

</div>

<%# ── M-4: 退会確認モーダル ── %>
<% content_for :modals do %>
  <div id="deactivate-modal"
       class="fixed inset-0 z-50 hidden"
       role="dialog"
       aria-modal="true"
       aria-labelledby="deactivate-modal-title">

    <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"
         onclick="document.getElementById('deactivate-modal').classList.add('hidden'); document.body.classList.remove('overflow-hidden');"
         aria-hidden="true"></div>

    <div class="fixed inset-0 flex items-center justify-center p-4 pointer-events-none">
      <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-md
                  max-h-screen overflow-y-auto pointer-events-auto"
           onclick="event.stopPropagation();">

        <div class="flex items-center justify-between p-6 border-b border-gray-200">
          <h3 id="deactivate-modal-title"
              class="text-lg font-bold text-red-700">
            ⚠️ 退会の確認
          </h3>
          <button type="button"
                  class="p-1 rounded text-gray-400 hover:text-gray-600
                         focus:outline-none focus:ring-2 focus:ring-gray-400"
                  onclick="document.getElementById('deactivate-modal').classList.add('hidden'); document.body.classList.remove('overflow-hidden');"
                  aria-label="モーダルを閉じる">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                 aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <div class="p-6 space-y-5">
          <p class="text-sm text-gray-700 font-medium">
            退会すると以下のデータが処理されます。この操作は取り消しできません。
          </p>

          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <h4 class="text-sm font-semibold text-red-800 mb-2">
              🗑️ 即時に匿名化・削除されるデータ
            </h4>
            <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
              <li>ユーザー名・メールアドレス・LINE ID</li>
              <li>パスワード情報</li>
              <li>パスワードリセットトークン</li>
              <li>プッシュ通知の宛先情報</li>
            </ul>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
            <h4 class="text-sm font-semibold text-gray-700 mb-2">
              📊 匿名化して保持されるデータ（統計・AI改善目的）
            </h4>
            <ul class="text-sm text-gray-600 space-y-1 list-disc list-inside">
              <li>習慣の達成記録・習慣一覧</li>
              <li>タスクの完了・未完了記録</li>
              <li>週次振り返りデータ</li>
              <li>AI分析結果</li>
            </ul>
            <p class="text-xs text-gray-500 mt-2">
              ※ 保持されるデータは個人を特定できない匿名の状態で保管され、
              サービス改善・AI精度向上のために活用されます。
            </p>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
            <p class="text-xs text-blue-700">
              ℹ️ 退会後は同じメールアドレスで再登録いただけます。
            </p>
          </div>
        </div>

        <div class="flex gap-3 p-6 border-t border-gray-200">
          <button type="button"
                  class="flex-1 px-4 py-2 text-sm font-medium text-gray-700
                         bg-white border border-gray-300 rounded-md
                         hover:bg-gray-50 transition-colors
                         focus:outline-none focus:ring-2 focus:ring-gray-400"
                  onclick="document.getElementById('deactivate-modal').classList.add('hidden'); document.body.classList.remove('overflow-hidden');">
            キャンセル
          </button>

          <%= button_to t("settings.destroy.confirm_button"),
              settings_path,
              method: :delete,
              class: "flex-1 px-4 py-2 text-sm font-medium text-white
                      bg-red-600 rounded-md hover:bg-red-700 transition-colors
                      focus:outline-none focus:ring-2 focus:ring-red-500
                      focus:ring-offset-2",
              data: { disable_with: "退会処理中..." } %>
        </div>

      </div>
    </div>
  </div>
<% end %>