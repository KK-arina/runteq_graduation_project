<%# app/views/sessions/new.html.erb %>
<% content_for :title, "ログイン | HabitFlow" %>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <h2 class="text-2xl font-bold mb-6 text-gray-900 text-center">
    ログイン
  </h2>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <%= form_with url: login_path,
                  scope: :session,
                  local: true,
                  data: {
                    controller: "form-submit",
                    action: "submit->form-submit#submit"
                  } do |f| %>

      <%= hidden_field_tag :redirect_to, params[:redirect_to] %>

      <%# メールアドレス入力エリア %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email,
            placeholder: "email@example.com",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%# パスワード入力エリア %>
      <div class="mb-6">
        <%= f.label :password, "パスワード",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password,
            placeholder: "パスワードを入力",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%= f.submit "ログイン",
          class: "w-full px-4 py-2 bg-blue-600 text-white rounded-md
                  hover:bg-blue-700 transition font-medium",
          data: {
            "form-submit-target": "button",
            "loading-text": "ログイン中..."
          } %>
    <% end %>

    <%# ============================================================ %>
    <%# F-1 追加: Google ログインボタン %>
    <%# ============================================================ %>

    <%# メールログインと Google ログインの視覚的な区切り線 %>
    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-200"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-2 bg-white text-gray-500">または</span>
      </div>
    </div>

    <%# 共通部分テンプレートを呼び出す。button_text でボタンのラベルを渡す %>
    <%= render "shared/google_auth_button", button_text: "Google アカウントでログイン" %>

    <%#
      omniauth_error パラメータが URL に存在する場合のエラーメッセージ表示。
      config/initializers/omniauth.rb の on_failure または
      OmniauthCallbacksController#failure からリダイレクトされた場合に付与される。
      ja.yml の omniauth.google.login_error から日本語メッセージを取得する。
    %>
    <% if params[:omniauth_error].present? %>
      <p class="mt-3 text-center text-sm text-red-600">
        <%= t("omniauth.google.login_error") %>
      </p>
    <% end %>

  </div>

  <%# 新規登録へのリンク %>
  <div class="mt-4 text-center text-sm text-gray-600">
    アカウントをお持ちでない方は
    <%= link_to "新規登録", new_user_path,
        class: "text-blue-600 hover:text-blue-700 hover:underline" %>
  </div>

</div>