<%# app/views/sessions/new.html.erb の先頭（最初の行）に追加 %>
<% content_for :title, "ログイン | HabitFlow" %>
<%#
  【このファイルの役割】
    ログインページのビュー。
    SessionsController の new アクション（GET /login）で表示される。

  【Issue #32 での変更点】
    ・フォームをカード（白い枠付きボックス）で囲み、users/new.html.erb と
      デザインを統一した。
      変更前: フォームが背景に直接置かれていた（カードなし）
      変更後: bg-white rounded-xl shadow-sm border で囲んだカード内にフォームを配置

    ・送信ボタンに font-medium を追加（users/new と揃える）
      変更前: class に font-medium がなかった
      変更後: font-medium を追加

    ・フォーム送信ローディングを form-submit コントローラーで実装
      送信ボタン押下後に「ログイン中...」と表示し、二重送信を防止する
%>

<%#
  max-w-md: 最大幅 448px
    ログインフォームに適した幅（入力欄が広すぎず、狭すぎない）
  mx-auto: 左右マージン auto → 中央揃え
  px-4 sm:px-6 lg:px-8: レスポンシブパディング
    px-4 = デフォルト(モバイル)16px
    sm:px-6 = 640px以上 24px
    lg:px-8 = 1024px以上 32px
  py-8: 上下パディング 32px
%>
<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%#
    ページタイトル
    text-2xl: 24px（users/new.html.erb と統一）
    font-bold: 太字
    mb-6: 下マージン 24px
    text-gray-900: 濃いグレー（ほぼ黒）。ページタイトルは高コントラストにする
    text-center: 中央揃え
  %>
  <h2 class="text-2xl font-bold mb-6 text-gray-900 text-center">
    ログイン
  </h2>

  <%#
    【Issue #32 追加】フォームを囲むカードコンテナ
    bg-white: 白背景でコンテンツを背景の bg-gray-50 から浮かび上がらせる
    rounded-xl: 角丸 12px（users/new.html.erb の角丸と統一）
    shadow-sm: 薄いドロップシャドウ（カードの立体感）
    border border-gray-200: 薄いグレーの枠線（カードの輪郭を明確化）
    p-6: 内側パディング 24px（コンテンツと枠線の余白）
  %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <%#
      form_with: Rails のフォームヘルパー
      url: login_path: 送信先 POST /login
      scope: :session: パラメータを params[:session][:email] の形にまとめる
      local: true: Turbo の非同期送信を無効化し、通常のHTMLフォーム送信にする
      data-controller="form-submit": フォーム送信ローディングコントローラーを紐付ける
      data-action="submit->form-submit#submit":
        フォームの submit イベントで form-submit コントローラーの submit() を呼ぶ
        ※ data-action をフォームタグに書くことで submit イベントを検知できる
    %>
    <%= form_with url: login_path,
                  scope: :session,
                  local: true,
                  data: {
                    controller: "form-submit",
                    action: "submit->form-submit#submit"
                  } do |f| %>

      <%# メールアドレス入力エリア %>
      <%# mb-4: 各フィールド間の余白 16px %>
      <div class="mb-4">
        <%#
          f.label: ラベルタグを生成する Rails ヘルパー
          block: ブロック要素にしてラベルとフィールドを縦並びにする
          text-sm font-medium text-gray-700: ラベルの標準スタイル（全フォームで統一）
          mb-2: ラベルとフィールドの間の余白 8px
        %>
        <%= f.label :email, "メールアドレス",
            class: "block text-sm font-medium text-gray-700 mb-2" %>

        <%#
          f.email_field: type="email" の input タグを生成
          w-full: 幅 100%（親要素いっぱいに広がる）
          px-4 py-2: 内側の余白（左右 16px, 上下 8px）
          border border-gray-300: 薄いグレーの枠線
          rounded-md: 角丸 6px（全フォームフィールドで統一）
          focus:ring-2 focus:ring-blue-500: フォーカス時に青いリング
          focus:border-blue-500: フォーカス時にボーダーも青に
        %>
        <%= f.email_field :email,
            placeholder: "email@example.com",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%# パスワード入力エリア %>
      <%# mb-6: ボタンとの間に広めの余白 24px %>
      <div class="mb-6">
        <%= f.label :password, "パスワード",
            class: "block text-sm font-medium text-gray-700 mb-2" %>

        <%#
          f.password_field: type="password" の input タグを生成
          入力内容が「●●●」に隠れる（セキュリティ対策）
        %>
        <%= f.password_field :password,
            placeholder: "パスワードを入力",
            class: "w-full px-4 py-2 border border-gray-300 rounded-md
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%#
        送信ボタン
        w-full: 入力欄と同じ幅に揃える
        py-2 px-4: ボタンの内側余白
        bg-blue-600: 青背景（主要アクションを示す）
        text-white: 白文字（青背景に対してコントラスト比 4.5:1 以上を確保）
        rounded-md: 角丸 6px（フォームフィールドと統一）
        hover:bg-blue-700: ホバー時に一段濃い青（インタラクティブであることを示す）
        transition: 色変化をアニメーション（滑らかに切り替わる）
        font-medium: 500 の太さ（ボタンテキストの視認性向上）
        【Issue #32 追加】
        data-form-submit-target="button":
          form-submit コントローラーから this.buttonTarget で参照できるようにする
        data-loading-text="ログイン中...":
          送信後に表示するローディングテキストをビュー側から指定する
      %>
      <%= f.submit "ログイン",
          class: "w-full px-4 py-2 bg-blue-600 text-white rounded-md
                  hover:bg-blue-700 transition font-medium",
          data: {
            "form-submit-target": "button",
            "loading-text": "ログイン中..."
          } %>
    <% end %>

  </div><%# end カードコンテナ %>

  <%#
    新規登録へのリンク
    mt-4: カードとの間に余白 16px
    text-center: 中央揃え
    text-sm: 14px（補足テキストは本文より小さめ）
    text-gray-600: 中間グレー
      【コントラスト確認】
      text-gray-600 (#4b5563) on white (#ffffff) = 7.0:1 → AA基準(4.5:1)クリア
  %>
  <div class="mt-4 text-center text-sm text-gray-600">
    アカウントをお持ちでない方は
    <%#
      link_to: リンクを生成する Rails ヘルパー
      text-blue-600: リンクを示す青色
        【コントラスト確認】
        text-blue-600 (#2563eb) on white (#ffffff) = 5.9:1 → AA基準クリア
      hover:underline: ホバー時に下線を表示（リンクであることをより明確化）
      hover:text-blue-700: ホバー時に濃い青
    %>
    <%= link_to "新規登録", new_user_path,
        class: "text-blue-600 hover:text-blue-700 hover:underline" %>
  </div>
</div>