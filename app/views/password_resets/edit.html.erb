<%# app/views/password_resets/edit.html.erb %>
<%# ============================================================ %>
<%# 26番画面: 新しいパスワード入力フォーム %>
<%# ============================================================ %>
<%#
  【このビューの役割】
  メールのリセットURLをクリックしてきたユーザーに
  新しいパスワードを入力させるフォームを表示する。

  【before_action の保証】
  set_token_by_id と validate_token が通過済みなので
  @token_record は有効なレコードが保証されている。
  @user は PasswordResetsController#edit で設定される。

  【:id について】
  URL の :id（生トークン）をフォームの送信先に含める必要がある。
  form_with url: password_reset_path(params[:id]) で
  PATCH /password_resets/abc123 に送信する。

  ============================================================
  【H-6 レスポンシブ調整での変更点】
  ============================================================

  ① password inputのフォントサイズ text-base（16px）を明示
     【理由】
       iOS Safari では 16px 未満の input をタップするとページがズームされる。
       text-base を明示することでズームを防止できる。

  ② password inputの縦余白を py-2 → py-3 に変更
     【理由】
       タップ領域を WCAG 2.1 推奨の 44px 以上確保するため。
       py-2（上下8px）+ テキスト高さ ≈ 38px → py-3（上下12px）+ テキスト高さ ≈ 46px

  ③ submitボタンの縦余白を py-2 → py-3 に変更
     【理由】同上（タップ領域 44px 確保のため）
%>
<% content_for :title, "新しいパスワードの設定 | HabitFlow" %>

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <h2 class="text-2xl font-bold mb-2 text-gray-900 text-center">
    新しいパスワードの設定
  </h2>
  <p class="text-sm text-gray-600 text-center mb-6">
    <%= @user.name %> さんの新しいパスワードを入力してください。
  </p>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <%#
      バリデーションエラーの表示:
        @user.errors.any? で1件以上エラーがある場合に表示する。
        full_messages は「パスワードは8文字以上で入力してください」のような
        属性名込みのメッセージ一覧を返す。
    %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-md">
        <p class="text-sm font-medium text-red-800 mb-2">
          以下のエラーを修正してください：
        </p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%#
      form_with のURL設定:
        url: password_reset_path(params[:id])
          → PATCH /password_resets/abc123 に送信
          → params[:id] は URL の :id（生トークン文字列）
        method: :patch
          → HTTP メソッドを PATCH に指定（更新操作）
        scope: :password_reset
          → { password_reset: { password: "...", password_confirmation: "..." } }
    %>
    <%= form_with url: password_reset_path(params[:id]),
                  method: :patch,
                  scope: :password_reset,
                  local: true do |f| %>

      <div class="mb-4">
        <%= f.label :password, "新しいパスワード",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%#
          text-base（16px）: iOS自動ズーム防止のため明示指定する
          py-3: タップ領域 44px 以上確保（WCAG 2.1 達成基準 2.5.5 準拠）
        %>
        <%= f.password_field :password,
            placeholder: "8文字以上で入力してください",
            autofocus: true,
            required: true,
            class: "w-full px-4 py-3 border border-gray-300 rounded-md
                    text-base
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-gray-500">8文字以上で入力してください</p>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "新しいパスワード（確認）",
            class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%# text-base / py-3: 上記と同様（iOS ズーム防止・タップ領域確保） %>
        <%= f.password_field :password_confirmation,
            placeholder: "もう一度入力してください",
            required: true,
            class: "w-full px-4 py-3 border border-gray-300 rounded-md
                    text-base
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <%#
        py-3: submitボタンもタップ領域 44px 以上を確保するため変更する
      %>
      <%= f.submit "パスワードを変更する",
          class: "w-full px-4 py-3 bg-blue-600 text-white rounded-md
                  hover:bg-blue-700 transition font-medium cursor-pointer" %>
    <% end %>

  </div>

</div>
