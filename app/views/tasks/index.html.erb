<%# app/views/tasks/index.html.erb %>
<%#
  ==============================================================================
  タスク一覧ページ（C-2 修正: リスト ID を修正）
  ==============================================================================
  【C-2 修正内容】
    タスクリストの id を以下のルールに統一する。

    active リスト（未完了タスク）:
      id="active-tasks-list-all"    → 「全て」タブ
      id="active-tasks-list-must"   → Must タブ
      id="active-tasks-list-should" → Should タブ
      id="active-tasks-list-could"  → Could タブ

    done リスト（完了済みタスク）:
      id="done-tasks-list" → 完了済みタブ（archive_all_done のターゲット）

    【なぜタブ名を id に含めるのか】
      toggle_complete で「完了→未完了」に戻す際、
      prepend 先のリストを特定するために id が必要。
      「全て」タブと「Must」タブでは別の ul 要素に追加する必要があるため
      タブ名を含む id で識別する。
  ==============================================================================
%>
<% content_for :title, "タスク管理 | HabitFlow" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ── PDCA強制ロック警告バナー ──────────────────────────────────────── %>
  <% if @locked %>
    <div class="mb-6 bg-orange-50 border border-orange-200 border-l-4 border-l-orange-500 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm font-bold text-orange-800">⚠️ ロック中：新規追加・削除はできません</p>
          <p class="text-xs text-orange-700 mt-1">完了チェックは操作できます。振り返りを完了すると解除されます。</p>
          <%= link_to "振り返りページへ →", new_weekly_reflection_path,
                class: "mt-2 inline-block text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 px-4 py-2 rounded transition-colors" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── ページヘッダー ─────────────────────────────────────────────────── %>
  <div class="flex flex-wrap justify-between items-center mb-6 gap-3">
    <h1 class="text-2xl font-bold text-gray-900">タスク管理</h1>
    <% if @locked %>
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium
                   bg-gray-200 text-gray-400 cursor-not-allowed"
            aria-disabled="true"
            title="先週の振り返りを完了するとタスクを追加できます">
        🔒 + タスクを追加
      </span>
    <% else %>
      <%= link_to new_task_path,
            class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium
                    bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
        + タスクを追加
      <% end %>
    <% end %>
  </div>

  <%# ── フィルタタブ ─────────────────────────────────────────────────────── %>
  <%= render partial: "tasks/tab_counts", locals: {
        current_tab:  @current_tab,
        must_count:   @must_count,
        should_count: @should_count,
        could_count:  @could_count,
        all_count:    @all_count
      } %>

  <%# ── タスク一覧 ──────────────────────────────────────────────────────── %>
  <% if @tasks.empty? %>
    <div class="text-center py-16 border-2 border-dashed border-gray-300 rounded-xl">
      <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
        <span class="text-3xl" aria-hidden="true">✅</span>
      </div>
      <% if @current_tab == "done" %>
        <p class="text-gray-500 mb-2">完了済みのタスクはありません</p>
        <p class="text-sm text-gray-400">タスクを完了すると、ここに表示されます</p>
      <% else %>
        <p class="text-gray-500 mb-4">
          <%= @current_tab == "all" ? "タスクはまだ登録されていません" : "#{@current_tab.upcase} のタスクはありません" %>
        </p>
        <% unless @locked %>
          <%= link_to "+ タスクを追加する", new_task_path,
                class: "px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
        <% end %>
      <% end %>
    </div>

  <% else %>

    <%# ── 完了タブの「すべてアーカイブ」ボタン ────────────────────────── %>
    <%#
      【修正】 data: { confirm: "..." } → data: { turbo_confirm: "..." }
      
      Rails 7 + Turbo では確認ダイアログのキーが変わっている。
      
      修正前: data: { confirm: "..." }
        → Rails 6 以前の書き方。Turbo を使う環境では動作しない。
      
      修正後: data: { turbo_confirm: "..." }
        → Turbo が提供する確認ダイアログ機能。
        → クリック時にブラウザのネイティブ confirm ダイアログを表示する。
        → OK を押した場合のみリクエストを送信する。
    %>
    <% if @current_tab == "done" && @tasks.any?(&:done?) %>
      <div class="flex justify-end mb-3">
        <%= button_to "すべてアーカイブ",
              archive_all_done_tasks_path,
              method: :patch,
              data: {
                turbo_stream: true,
                turbo_confirm: "完了済みのタスクをすべてアーカイブしますか？"
              },
              form: { style: "display:inline" },
              class: "text-xs text-gray-500 bg-gray-100 hover:bg-gray-200
                      px-3 py-1.5 rounded-lg transition-colors
                      border border-gray-200 cursor-pointer" %>
      </div>
    <% end %>

    <%#
      ── タスクカード一覧 ──────────────────────────────────────────────────
      【id の設計】
        done タブ  → id="done-tasks-list"
          archive_all_done の Turbo Stream ターゲット
        それ以外   → id="active-tasks-list-{タブ名}"
          toggle_complete の「完了→未完了」prepend ターゲット

        例:
          全て タブ  → id="active-tasks-list-all"
          Must タブ  → id="active-tasks-list-must"
          Should タブ → id="active-tasks-list-should"
          Could タブ → id="active-tasks-list-could"
    %>
    <div id="<%= @current_tab == 'done' ? 'done-tasks-list' : "active-tasks-list-#{@current_tab}" %>"
         class="space-y-3">
      <% @tasks.each do |task| %>
        <%#
          タスクの状態に応じてパーシャルを切り替える。
          done → 完了タスク行（_done_task_row）
          todo / doing → 未完了タスク行（_task_row）

          【C-2 修正: archived を done タブから除外】
            archived タスクは done タブには表示しない。
            done タブのクエリを where(status: :done) のみに変更するため、
            ここの条件も task.done? のみ確認すれば十分。
            task.archived? は done タブには到達しないので判定不要。
        %>
        <% if task.done? %>
          <%= render partial: "tasks/done_task_row",
                locals: { task: task, locked: @locked } %>
        <% else %>
          <%= render partial: "tasks/task_row",
                locals: { task: task, locked: @locked } %>
        <% end %>
      <% end %>
    </div>

    <%# ── タスク件数表示（Turbo Stream 更新対象） %>
    <%#
      id="task-count-display":
        toggle_complete / archive アクションの Turbo Stream で
        この要素の件数テキストを更新するために必要な id。
        id がないと Turbo Stream の replace ターゲットが見つからず
        件数が更新されない。
    %>
    <div id="task-count-display" class="mt-4 text-center text-xs text-gray-400">
      <%= @tasks.count %>件のタスク
    </div>
  <% end %>

</div><%# max-w-7xl mx-auto の閉じタグ %>

<%#
  モーダル専用コンテナ
  ────────────────────────────────────────────────────────────────
  【役割】
    _task_row から render される _task_modal のモーダル HTML は
    フルレンダリング時にここではなくインラインで出力される。

    toggle_complete の Turbo Stream で
    turbo_stream.replace("task-modal-#{@task.id}", ...) を発行するとき、
    DOM に task-modal-#{id} 要素が存在しないケース（初回toggle時）に備えて
    このコンテナを upsert 先として使う。

    また fixed inset-0 のモーダルが正しく全画面表示されるよう、
    transition / transform を持つ祖先要素の外に置く必要があるため
    max-w-7xl div の外側に配置する。
%>
<div id="task-modals-container"></div>