<%# app/views/tasks/_tab_counts.html.erb %>
<%#
  ==============================================================================
  タブ件数バッジパーシャル（修正: 複数行文字列の #{} 評価問題を修正）
  ==============================================================================
  【修正内容】
    link_to の class: オプションで複数行文字列 + #{} を使うと、
    Turbo Stream 経由での再描画時に #{} がそのまま文字列として出力される。
    原因: ERB パーサーが複数行文字列内の #{} を正しく処理できないケースがある。

    解決策: class: の文字列を1行にまとめる。
    または文字列結合（"..." + (条件式)）を使う。

  【受け取るローカル変数】
    current_tab  : 現在選択中のタブ名（"all" / "must" / "should" / "could" / "done"）
    must_count   : Must タスクの件数
    should_count : Should タスクの件数
    could_count  : Could タスクの件数
    all_count    : 未完了タスクの合計件数
  ==============================================================================
%>

<div id="task-tab-counts"
     class="flex gap-2 mb-6 overflow-x-auto pb-1"
     role="tablist"
     aria-label="タスクのフィルタタブ">

  <%# ── all タブ ──────────────────────────────────────────────────────── %>
  <%#
    【修正ポイント】
    class: の文字列を1行にまとめる。
    複数行にすると Turbo Stream 再描画時に #{} が評価されないバグがある。
    "共通クラス " + (条件式) の形で文字列結合することで確実に評価される。
  %>
  <%= link_to tasks_path(tab: "all"),
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-colors " + (current_tab == "all" ? "bg-blue-600 text-white" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50"),
        role: "tab",
        aria: { selected: current_tab == "all" } do %>
    全て
    <% if all_count > 0 %>
      <span class="ml-1.5 inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold <%= current_tab == 'all' ? 'bg-white text-blue-600' : 'bg-blue-100 text-blue-700' %>">
        <%= all_count %>
      </span>
    <% end %>
  <% end %>

  <%# ── Must タブ ─────────────────────────────────────────────────────── %>
  <%= link_to tasks_path(tab: "must"),
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-colors " + (current_tab == "must" ? "bg-red-600 text-white" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50"),
        role: "tab",
        aria: { selected: current_tab == "must" } do %>
    <span class="inline-flex items-center gap-1.5">
      <span class="w-2 h-2 rounded-full <%= current_tab == 'must' ? 'bg-white' : 'bg-red-500' %>"></span>
      Must
      <% if must_count > 0 %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold <%= current_tab == 'must' ? 'bg-white text-red-600' : 'bg-red-100 text-red-700' %>">
          <%= must_count %>
        </span>
      <% end %>
    </span>
  <% end %>

  <%# ── Should タブ ───────────────────────────────────────────────────── %>
  <%= link_to tasks_path(tab: "should"),
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-colors " + (current_tab == "should" ? "bg-blue-600 text-white" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50"),
        role: "tab",
        aria: { selected: current_tab == "should" } do %>
    <span class="inline-flex items-center gap-1.5">
      <span class="w-2 h-2 rounded-full <%= current_tab == 'should' ? 'bg-white' : 'bg-blue-500' %>"></span>
      Should
      <% if should_count > 0 %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold <%= current_tab == 'should' ? 'bg-white text-blue-600' : 'bg-blue-100 text-blue-700' %>">
          <%= should_count %>
        </span>
      <% end %>
    </span>
  <% end %>

  <%# ── Could タブ ─────────────────────────────────────────────────────── %>
  <%= link_to tasks_path(tab: "could"),
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-colors " + (current_tab == "could" ? "bg-green-600 text-white" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50"),
        role: "tab",
        aria: { selected: current_tab == "could" } do %>
    <span class="inline-flex items-center gap-1.5">
      <span class="w-2 h-2 rounded-full <%= current_tab == 'could' ? 'bg-white' : 'bg-green-500' %>"></span>
      Could
      <% if could_count > 0 %>
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold <%= current_tab == 'could' ? 'bg-white text-green-600' : 'bg-green-100 text-green-700' %>">
          <%= could_count %>
        </span>
      <% end %>
    </span>
  <% end %>

  <%# ── 完了済みタブ ────────────────────────────────────────────────────── %>
  <%= link_to tasks_path(tab: "done"),
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium transition-colors " + (current_tab == "done" ? "bg-gray-600 text-white" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50"),
        role: "tab",
        aria: { selected: current_tab == "done" } do %>
    完了済み ✓
  <% end %>
</div>