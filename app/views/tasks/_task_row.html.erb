<%# app/views/tasks/_task_row.html.erb %>
<%#
  ==============================================================================
  未完了タスク行パーシャル（C-3修正版: レビュー指摘対応）
  ==============================================================================
  【C-3修正での変更点】
    レビュー指摘④対応:
    button_to に data: { turbo_submits_with: "削除中..." } を追加する。

    【turbo_submits_with とは】
      Turbo が提供するフォーム送信時のボタン制御機能。
      送信中はボタンのテキストを指定した文字列に変更し、
      同時にボタンを disabled にする。
      これにより連打（二重送信）を防ぐことができる。

      turbo_confirm と組み合わせることも可能だが、
      今回はモーダルで確認するため turbo_confirm は使わない。
  ==============================================================================
%>

<div id="<%= dom_id(task) %>"
     class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow
            border-l-4 <%= task.must? ? 'border-l-red-500' : task.should? ? 'border-l-blue-500' : 'border-l-green-500' %>">
  <div class="flex items-start gap-3 p-4">

    <%#
      ── 完了チェックボックス ────────────────────────────────────────────────
      data-controller="task-toggle":
        task_toggle_controller.js をこの div に紐付ける。
      data-task-toggle-url-value:
        Stimulus Values API で fetch 先の URL を渡す。
        toggle_complete_task_path(task) → "/tasks/1/toggle_complete"
      data-task-toggle-task-id-value:
        タスクIDをデバッグ・ログ用に渡す。
    %>
    <div class="flex-shrink-0 mt-0.5"
         data-controller="task-toggle"
         data-task-toggle-url-value="<%= toggle_complete_task_path(task) %>"
         data-task-toggle-task-id-value="<%= task.id %>">

      <%#
        チェックボックス本体
        data-action="change->task-toggle#toggle":
          change イベント発生時に task_toggle_controller.js の toggle() を呼ぶ。
        aria-label:
          スクリーンリーダー向けに「○○を完了にする」と読み上げさせる。
      %>
      <input type="checkbox"
             class="w-5 h-5 rounded border-gray-300 text-blue-600 cursor-pointer
                    focus:ring-2 focus:ring-blue-500"
             data-action="change->task-toggle#toggle"
             aria-label="<%= task.title %>を完了にする">
    </div>

    <%# ── タスク詳細情報 ──────────────────────────────────────────────────── %>
    <div class="flex-1 min-w-0">
      <div class="flex items-start gap-2 flex-wrap">

        <%# 優先度バッジ（Must=赤 / Should=青 / Could=緑） %>
        <span class="flex-shrink-0 text-xs font-bold px-2 py-0.5 rounded
                     <%= task.must? ? 'bg-red-100 text-red-700' : task.should? ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
          <%= task.must? ? "Must" : task.should? ? "Should" : "Could" %>
        </span>

        <%# タスクタイトル %>
        <h3 class="text-sm font-semibold text-gray-800 leading-snug flex-1">
          <%= task.title %>
        </h3>
      </div>

      <%# メタ情報（期限・AI生成フラグ・見積時間） %>
      <div class="flex items-center gap-3 mt-1.5 flex-wrap">
        <% if task.due_date.present? %>
          <span class="text-xs flex items-center gap-1
                       <%= task.overdue? ? 'text-red-600 font-bold' : task.due_today? ? 'text-orange-600 font-semibold' : 'text-gray-400' %>">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <% if task.overdue? %>
              期限切れ（<%= task.due_date.strftime("%-m/%-d") %>）
            <% elsif task.due_today? %>
              今日期限
            <% else %>
              <%= task.due_date.strftime("%-m/%-d") %>
            <% end %>
          </span>
        <% end %>

        <% if task.ai_generated? %>
          <%#
            AI生成バッジ
            このバッジが表示されているタスクには「⋯」メニューが表示されない。
            AI生成タスクはAI提案モーダル経由でのみ削除できる設計。
          %>
          <span class="text-xs text-purple-600 bg-purple-50 px-1.5 py-0.5 rounded">
            🤖 AI生成
          </span>
        <% end %>

        <% if task.estimated_hours.present? %>
          <span class="text-xs text-gray-400 flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= format("%g", task.estimated_hours) %>時間
          </span>
        <% end %>
      </div>
    </div>

    <%#
      ── C-3: 「⋯」メニューボタン ─────────────────────────────────────────
      表示条件: 手動作成タスク（!ai_generated?）かつロック解除中（!locked）

      【data-controller="task-menu" の配置について】
        チェックボックスの div とは別に独立して配置する。
        Stimulus のスコープはこのボタン要素のみに適用される。

      【data-task-menu-task-id-value】
        モーダル・ボトムシートの DOM ID 構築に使う。
        例: task.id=1 → モーダルID "task-modal-1"、シートID "task-sheet-1"

      【data-task-menu-task-title-value】
        モーダルのタイトルに「「○○を削除しますか？」と表示するためのタスク名。

      【data-action="keydown@window->task-menu#keydown"】
        ウィンドウ全体のキーボードイベントを監視する。
        Escape キーが押されたときに task_menu_controller.js の keydown() を呼び出す。
        @window を使うことでモーダル外にフォーカスがあっても Escape で閉じられる。
    %>
    <% unless task.ai_generated? || locked %>
      <div data-controller="task-menu"
           data-task-menu-task-id-value="<%= task.id %>"
           data-task-menu-task-title-value="<%= task.title %>"
           data-action="keydown@window->task-menu#keydown">

        <%#
          「⋯」ボタン
          クリックで openMenu() を呼び出してモーダルまたはボトムシートを開く。
          aria-label: スクリーンリーダーに「メニューを開く」と伝える。
          aria-haspopup="dialog": このボタンがダイアログ（モーダル）を開くことを伝える。
        %>
        <button type="button"
                data-action="click->task-menu#openMenu"
                class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600
                       hover:bg-gray-100 transition-colors flex-shrink-0"
                aria-label="<%= task.title %>のメニューを開く"
                aria-haspopup="dialog">
          <%# 縦3点ドット（⋯）アイコン %>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
        </button>
      </div>
    <% end %>

    <%#
      ── モーダル・ボトムシートの出力（バグ修正）────────────────────────
      【変更前】
        content_for :modals do
          ... モーダル HTML ...
        end

      【変更後】
        = render "tasks/task_modal", task: task

      【変更理由】
        content_for :modals は Turbo Stream の replace では
        yield :modals に反映されない。
        toggle_complete 後にモーダル HTML が DOM から消え、
        document.getElementById("task-modal-#{task.id}") が null を返すため
        「⋯」ボタンを押してもモーダルが開かなくなっていた。

        _task_modal パーシャルに切り出してインラインで出力することで、
        フルレンダリング時は _task_row の一部として直接DOMに出力される。
        toggle_complete 後は tasks_controller.rb から
        turbo_stream.replace("task-modal-#{@task.id}", ...) で再注入される。
    %>
    <% unless task.ai_generated? %>
      <%= render "tasks/task_modal", task: task %>
    <% end %><%# unless task.ai_generated? の終わり %>

  </div>
</div>