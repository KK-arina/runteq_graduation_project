<%# app/views/tasks/new.html.erb %>
<%#
  ==============================================================================
  タスク新規作成ページ（C-1: 基本CRUD実装）
  ==============================================================================
  【このファイルの役割】
    タスクを新規登録するフォームを表示する。
    バリデーションエラー時はこのページを再表示してエラーメッセージを見せる。

  【フォームの構成】
    ① タスク名（必須）
    ② 優先度（Must/Should/Could の選択）
    ③ 期限日（任意）
    ④ 見積時間（任意）
    ⑤ タスク種別（任意）

  【使用するインスタンス変数（TasksController#new / #create で設定）】
    @task: Task.new で作成した空のインスタンス
           バリデーションエラー時は入力値とエラーメッセージを保持している

  ============================================================
  【H-6 レスポンシブ調整での変更点】
  ============================================================

  ① タスク名 inputのフォントサイズを（指定なし）→ text-base（16px）に追加
     【理由】iOS Safari は 16px 未満の input をタップするとページがズームされる。
             text-base（16px）を明示することでズームを防止できる。

  ② 期限日 date inputにも text-base を追加（理由は①と同様）

  ③ 見積時間 number inputにも text-base を追加（理由は①と同様）

  ④ タスク種別 selectにも text-base を追加（理由は①と同様）

  ⑤ 保存ボタンの縦余白を py-2.5 → py-3 に変更
     【理由】タップ領域を WCAG 2.1 推奨の 44px 以上確保するため。
             py-2.5（10px×2=20px）+ テキスト高さ ≈ 40px で基準未満のため
             py-3（12px×2=24px）+ テキスト高さ ≈ 44px 以上に変更する。

  ⑥ キャンセルボタンの縦余白を py-2.5 → py-3 に変更（理由は⑤と同様）
==============================================================================
%>
<% content_for :title, "タスクを追加 | HabitFlow" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ── ページヘッダー ─────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-6">
    <%# 「← タスク一覧」戻るリンク %>
    <%= link_to tasks_path,
          class: "text-gray-400 hover:text-gray-600 transition-colors",
          aria: { label: "タスク一覧に戻る" } do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">タスクを追加</h1>
  </div>

  <%#
    ── バリデーションエラーメッセージ ─────────────────────────────────────
    @task.errors.any? で1件以上エラーがある場合に表示する。
    div[role="alert"]: スクリーンリーダーにエラーメッセージを通知するための ARIA 属性。
  %>
  <% if @task.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4" role="alert">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm font-bold text-red-800">入力内容に問題があります</p>
      </div>
      <ul class="list-disc list-inside space-y-1">
        <% @task.errors.full_messages.each do |message| %>
          <li class="text-sm text-red-700"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%#
    ── フォーム ─────────────────────────────────────────────────────────────
    form_with model: @task:
      @task が新規（未保存）のインスタンスなので、
      action="/tasks" method="POST" のフォームを生成する。
    local: true: Turbo Drive の非同期送信を無効にする。
  %>
  <%= form_with model: @task, local: true,
        class: "bg-white border border-gray-200 rounded-xl shadow-sm p-6" do |f| %>

    <%# ── ① タスク名 ──────────────────────────────────────────────────── %>
    <div class="mb-5">
      <%= f.label :title, "タスク名",
            class: "block text-sm font-bold text-gray-700 mb-1" %>
      <span class="text-red-500 text-xs ml-1" aria-hidden="true">必須</span>

      <%#
        text-base（16px）を追加する理由（H-6）:
          iOS Safari は 16px 未満の input をタップするとページがズームされる。
          text-base を明示することでズームを防止できる。
        py-3 を使う理由（H-6）:
          タップ領域を WCAG 2.1 推奨の 44px 以上確保するため。
          py-2.5（上下10px）+ テキスト高さ ≈ 40px から
          py-3（上下12px）+ テキスト高さ ≈ 44px に変更する。
      %>
      <%= f.text_field :title,
            placeholder: "例: 企画書作成、メール返信",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
                    #{ @task.errors[:title].any? ? 'border-red-400 bg-red-50' : '' }",
            maxlength: 100,
            aria: { required: true, describedby: "title-hint" } %>
      <p id="title-hint" class="mt-1 text-xs text-gray-400">100文字以内</p>
    </div>

    <%# ── ② 優先度（Must/Should/Could）──────────────────────────────── %>
    <div class="mb-5">
      <p class="block text-sm font-bold text-gray-700 mb-2">
        優先度 <span class="text-red-500 text-xs ml-1" aria-hidden="true">必須</span>
      </p>

      <%#
        data-controller="priority-card":
          priority_card_controller.js をこの div に紐付ける。
          この div 内の全 label・card が Stimulus のターゲットとして管理される。
        role="radiogroup" aria-label="...":
          スクリーンリーダーに「これはラジオボタングループ」と伝える。
      %>
      <div class="grid grid-cols-3 gap-3"
           role="radiogroup"
           aria-label="優先度を選択してください"
           data-controller="priority-card">

        <%#
          優先度カード: p-3 で内側余白を確保している。
          grid-cols-3 により 375px / 3 ≈ 125px 幅になり
          タップしやすいサイズが確保されている。

          【H-6 追加修正】カードの高さ統一
          label に h-full を付ける理由:
            grid の各セルは最も高いセルに揃う（CSS Grid の仕様）。
            label が h-full でセルいっぱいに広がることで
            内側の div も stretch される。
          内側 div に h-full を付ける理由:
            flex flex-col items-center justify-center と組み合わせることで
            アイコン・タイトル・説明文が縦方向に中央揃えになる。
            「できればやる」が2行になっても他のカードと高さが統一される。
        %>
        <label class="cursor-pointer h-full"
               data-priority-card-target="label">
          <%= f.radio_button :priority, "must",
                class: "sr-only",
                id:    "task_priority_must",
                data:  { action: "change->priority-card#select" } %>
          <%#
            h-full: label の高さいっぱいに広がる
            flex flex-col items-center justify-center: コンテンツを縦中央揃えにする
          %>
          <div class="border-2 rounded-lg p-3 text-center transition-all h-full
                      flex flex-col items-center justify-center"
               data-priority-card-target="card"
               data-active-class="border-red-500 bg-red-50"
               data-inactive-class="border-gray-200">
            <div class="text-lg mb-1" aria-hidden="true">🔴</div>
            <div class="text-sm font-bold text-gray-700">Must</div>
            <div class="text-xs text-gray-400 mt-0.5">絶対にやる</div>
          </div>
        </label>

        <label class="cursor-pointer h-full"
               data-priority-card-target="label">
          <%= f.radio_button :priority, "should",
                class: "sr-only",
                id:    "task_priority_should",
                data:  { action: "change->priority-card#select" } %>
          <%# h-full + flex: Must カードと同じ理由で高さを統一する %>
          <div class="border-2 rounded-lg p-3 text-center transition-all h-full
                      flex flex-col items-center justify-center"
               data-priority-card-target="card"
               data-active-class="border-blue-500 bg-blue-50"
               data-inactive-class="border-gray-200">
            <div class="text-lg mb-1" aria-hidden="true">🔵</div>
            <div class="text-sm font-bold text-gray-700">Should</div>
            <div class="text-xs text-gray-400 mt-0.5">できればやる</div>
          </div>
        </label>

        <label class="cursor-pointer h-full"
               data-priority-card-target="label">
          <%= f.radio_button :priority, "could",
                class: "sr-only",
                id:    "task_priority_could",
                data:  { action: "change->priority-card#select" } %>
          <%# h-full + flex: Must カードと同じ理由で高さを統一する %>
          <div class="border-2 rounded-lg p-3 text-center transition-all h-full
                      flex flex-col items-center justify-center"
               data-priority-card-target="card"
               data-active-class="border-green-500 bg-green-50"
               data-inactive-class="border-gray-200">
            <div class="text-lg mb-1" aria-hidden="true">🟢</div>
            <div class="text-sm font-bold text-gray-700">Could</div>
            <div class="text-xs text-gray-400 mt-0.5">余裕があれば</div>
          </div>
        </label>
      </div>
    </div>

    <%# ── ③ 期限日 ──────────────────────────────────────────────────────── %>
    <div class="mb-5">
      <%= f.label :due_date, "期限日",
            class: "block text-sm font-bold text-gray-700 mb-1" %>
      <span class="text-xs text-gray-400 ml-1">任意</span>
      <%#
        text-base（16px）を追加する理由（H-6）:
          date input も 16px 未満だと iOS で自動ズームが発生する。
          text-base を明示してズームを防止する。
        py-3: タップ領域 44px 確保のため（H-6 変更）
      %>
      <%= f.date_field :due_date,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
            min: Date.current.to_s %>
    </div>

    <%# ── ④ 見積時間 ────────────────────────────────────────────────────── %>
    <div class="mb-5">
      <%= f.label :estimated_hours, "見積時間（時間）",
            class: "block text-sm font-bold text-gray-700 mb-1" %>
      <span class="text-xs text-gray-400 ml-1">任意</span>
      <%#
        text-base（16px）を追加する理由（H-6）:
          number input も 16px 未満だと iOS で自動ズームが発生する。
          text-base を明示してズームを防止する。
        py-3: タップ領域 44px 確保のため（H-6 変更）
      %>
      <%= f.number_field :estimated_hours,
            placeholder: "例: 1.5",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
            step: "0.5",
            min: "0.5" %>
    </div>

    <%# ── ⑤ タスク種別 ────────────────────────────────────────────────── %>
    <div class="mb-6">
      <%= f.label :task_type, "タスク種別",
            class: "block text-sm font-bold text-gray-700 mb-1" %>
      <span class="text-xs text-gray-400 ml-1">任意</span>
      <%#
        text-base（16px）を追加する理由（H-6）:
          select 要素も 16px 未満だと iOS で自動ズームが発生する。
          text-base を明示してズームを防止する。
        py-3: タップ領域 44px 確保のため（H-6 変更）
        bg-white: select 要素のデフォルト背景を白に固定する（iOS ではグレーになる場合がある）。
      %>
      <%= f.select :task_type,
            [["通常タスク", "normal"], ["習慣関連", "habit"], ["改善タスク", "improve"]],
            { selected: @task.task_type.presence || "normal" },
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-base
                    focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent
                    bg-white" %>
    </div>

    <%# ── 送信ボタンエリア ────────────────────────────────────────────── %>
    <div class="flex gap-3">
      <%#
        キャンセルボタン: py-3 でタップ領域 44px 以上を確保する（H-6 変更）
          py-2.5（20px余白）→ py-3（24px余白）で合計高さ約44px以上になる。
      %>
      <%= link_to "キャンセル", tasks_path,
            class: "flex-1 text-center px-4 py-3 border border-gray-300 rounded-lg
                    text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>

      <%#
        保存ボタン: py-3 でタップ領域 44px 以上を確保する（H-6 変更）
          FormSubmitController と連携して送信中はローディング表示になる。
      %>
      <%= f.submit "タスクを保存する",
            class: "flex-2 flex-grow px-6 py-3 bg-blue-600 text-white rounded-lg
                    text-sm font-bold hover:bg-blue-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
